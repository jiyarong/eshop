<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>电商管理平台</title>
    <script type="module" src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.13/+esm"></script>
    <style>
      :root {
        color-scheme: light;
        --bg: #f5f7fb;
        --panel: #ffffff;
        --line: #dde3ee;
        --text: #172033;
        --muted: #657084;
        --brand: #176b87;
        --brand-dark: #0f4f64;
        --danger-bg: #fff1f0;
        --danger-line: #ffccc7;
        --danger-text: #a8071a;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      .app-shell {
        min-height: 100vh;
      }

      .app-header {
        display: flex;
        align-items: center;
        gap: 28px;
        min-height: 58px;
        padding: 0 28px;
        background: #172033;
        color: #fff;
      }

      .app-brand {
        font-weight: 700;
        white-space: nowrap;
      }

      .app-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
        font-size: 14px;
      }

      .app-nav a {
        color: rgba(255, 255, 255, 0.78);
        text-decoration: none;
      }

      .app-nav a[aria-current="page"] {
        color: #fff;
        font-weight: 600;
      }

      .app-nav-group {
        display: flex;
        gap: 12px;
      }

      .page {
        width: min(1440px, calc(100vw - 48px));
        margin: 24px auto 40px;
      }

      .page-title {
        margin: 0 0 18px;
        font-size: 24px;
        line-height: 1.25;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 18px;
        box-shadow: 0 8px 20px rgba(23, 32, 51, 0.05);
      }

      .report-form {
        display: flex;
        flex-wrap: wrap;
        align-items: end;
        gap: 14px;
      }

      .field {
        display: grid;
        gap: 6px;
      }

      .field label {
        color: var(--muted);
        font-size: 13px;
      }

      select,
      input {
        min-height: 36px;
        border: 1px solid #c8d0dc;
        border-radius: 6px;
        padding: 0 10px;
        background: #fff;
        color: var(--text);
        font: inherit;
      }

      .button {
        min-height: 36px;
        border: 0;
        border-radius: 6px;
        padding: 0 18px;
        background: var(--brand);
        color: #fff;
        font-weight: 600;
        cursor: pointer;
      }

      .button:hover {
        background: var(--brand-dark);
      }

      .empty-state,
      .error-box {
        margin-top: 16px;
      }

      .empty-state {
        color: var(--muted);
        text-align: center;
        padding: 34px;
      }

      .error-box {
        border: 1px solid var(--danger-line);
        background: var(--danger-bg);
        color: var(--danger-text);
      }

      .report-stack {
        display: grid;
        gap: 16px;
        margin-top: 16px;
      }

      .report-meta {
        margin: 0 0 12px;
        color: var(--muted);
      }

      .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 12px;
      }

      .weekly-profit-summary-card {
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 12px;
        background: #fbfcff;
      }

      .summary-label {
        color: var(--muted);
        font-size: 12px;
      }

      .summary-value {
        margin-top: 6px;
        font-size: 20px;
        font-weight: 700;
      }

      .section-title {
        margin: 0 0 12px;
        font-size: 16px;
      }

      .status-pill {
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        border-radius: 999px;
        padding: 0 10px;
        font-size: 12px;
        font-weight: 700;
      }

      .status-pill.is-active {
        background: #e7f6ed;
        color: #167044;
      }

      .status-pill.is-muted {
        background: #eef1f6;
        color: var(--muted);
      }

      .table-scroll {
        overflow-x: auto;
      }

      table {
        width: 100%;
        min-width: 760px;
        border-collapse: collapse;
      }

      th,
      td {
        border-bottom: 1px solid var(--line);
        padding: 10px;
        text-align: left;
        white-space: nowrap;
      }

      th {
        color: var(--muted);
        font-size: 12px;
        font-weight: 600;
        background: #f8fafc;
      }

      @media (max-width: 720px) {
        .app-header {
          align-items: flex-start;
          flex-direction: column;
          gap: 8px;
          padding: 14px 18px;
        }

        .page {
          width: calc(100vw - 24px);
          margin-top: 14px;
        }

        .report-form {
          display: grid;
        }

        .app-nav,
        .app-nav-group {
          gap: 10px;
        }
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <header class="app-header">
        <div class="app-brand">电商管理平台</div>
        <nav class="app-nav">
          <span class="app-nav-group">
            <a href="/weekly_profit_reports" <%= 'aria-current="page"'.html_safe if request.path == "/weekly_profit_reports" %>>周利润报表</a>
            <a href="/reports/inventory" <%= 'aria-current="page"'.html_safe if request.path == "/reports/inventory" %>>库存</a>
            <a href="/reports/skus" <%= 'aria-current="page"'.html_safe if request.path == "/reports/skus" %>>SKU</a>
            <a href="/reports/costs" <%= 'aria-current="page"'.html_safe if request.path == "/reports/costs" %>>成本</a>
            <a href="/erp/skus" <%= 'aria-current="page"'.html_safe if request.path.start_with?("/erp/skus") %>>SKU 管理</a>
            <a href="/erp/sku_categories" <%= 'aria-current="page"'.html_safe if request.path.start_with?("/erp/sku_categories") %>>SKU 类别</a>
            <a href="/erp/sku_batches" <%= 'aria-current="page"'.html_safe if request.path.start_with?("/erp/sku_batches") %>>ERP 批次</a>
            <a href="/erp/purchase_orders" <%= 'aria-current="page"'.html_safe if request.path.start_with?("/erp/purchase_orders") %>>采购单</a>
            <a href="/erp/cost_allocations" <%= 'aria-current="page"'.html_safe if request.path.start_with?("/erp/cost_allocations") %>>费用分摊</a>
          </span>
        </nav>
      </header>
      <main class="page">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
