<!DOCTYPE html>
<html lang="<%= I18n.locale == :zh ? "zh-CN" : I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-preview">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <title><%= content_for?(:title) ? "#{yield(:title)} · #{t("app.name")}" : t("app.name") %></title>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", type: "module", "data-turbo-track": "reload", defer: true %>
  </head>
  <body class="erp-shell">
    <% current_path = request.path %>
    <% active_link = ->(prefixes) { Array(prefixes).any? { |prefix| current_path == prefix || current_path.start_with?("#{prefix}/") } } %>
    <% nav_sections = [
      {
        label: t("navigation.sections.dashboard"),
        links: [
          { label: t("navigation.weekly_profit_reports"), path: "/weekly_profit_reports", icon: "bi-graph-up-arrow", active: active_link.call("/weekly_profit_reports") }
        ]
      },
      {
        label: t("navigation.sections.operations"),
        links: [
          { label: t("navigation.inventory"), path: "/reports/inventory", icon: "bi-box-seam", active: current_path == "/reports/inventory" },
          { label: t("navigation.orders"), path: "/orders", icon: "bi-receipt", active: active_link.call("/orders") },
          { label: t("navigation.skus"), path: "/reports/skus", icon: "bi-tags", active: current_path == "/reports/skus" },
          { label: t("navigation.sku_sales"), path: "/reports/sku_sales", icon: "bi-bar-chart-line", active: current_path == "/reports/sku_sales" },
          { label: t("navigation.costs"), path: "/reports/costs", icon: "bi-cash-coin", active: current_path == "/reports/costs" }
        ]
      },
      {
        label: t("navigation.sections.erp"),
        links: [
          { label: t("navigation.erp_skus"), path: "/erp/skus", icon: "bi-grid-3x3-gap", active: active_link.call("/erp/skus") },
          { label: t("navigation.sku_categories"), path: "/erp/sku_categories", icon: "bi-diagram-3", active: active_link.call("/erp/sku_categories") },
          { label: t("navigation.sku_batches"), path: "/erp/sku_batches", icon: "bi-layers", active: active_link.call("/erp/sku_batches") },
          { label: t("navigation.purchase_orders"), path: "/erp/purchase_orders", icon: "bi-cart-check", active: active_link.call("/erp/purchase_orders") },
          { label: t("navigation.cost_allocations"), path: "/erp/cost_allocations", icon: "bi-calculator", active: active_link.call("/erp/cost_allocations") },
          { label: t("navigation.operation_tasks"), path: "/erp/operation_tasks", icon: "bi-list-task", active: active_link.call("/erp/operation_tasks") }
        ]
      }
    ] %>
    <% admin_links = [] %>
    <% if can?(:manage_users) %>
      <% admin_links << { label: t("navigation.users"), path: "/admin/users", icon: "bi-people", active: active_link.call("/admin/users") } %>
      <% admin_links << { label: t("navigation.agents"), path: "/admin/agents", icon: "bi-cpu", active: active_link.call("/admin/agents") } %>
    <% end %>
    <% if can?(:manage_feedback_tasks) %>
      <% admin_links << { label: t("navigation.feedback_tasks"), path: "/admin/feedback_tasks", icon: "bi-chat-square-text", active: active_link.call("/admin/feedback_tasks") } %>
    <% end %>
    <% nav_sections << { label: t("navigation.sections.administration"), links: admin_links } if admin_links.any? %>
    <% locale_path = ->(locale) { url_for(request.query_parameters.merge(locale: locale)) } %>

    <div
      class="erp-shell__frame"
      data-controller="shell feedback"
      data-action="mouseover@document->feedback#hover click@document->feedback#choose">
      <aside class="erp-sidebar" data-shell-target="sidebar">
        <div class="erp-brand">
          <span class="erp-brand__mark" aria-hidden="true">Y</span>
          <span>
            <span class="erp-brand__name">Yuanlong ERP</span>
            <span class="erp-brand__meta"><%= t("app.subtitle") %></span>
          </span>
        </div>

        <nav class="erp-nav" aria-label="Main navigation">
          <% nav_sections.each do |section| %>
            <section class="erp-nav__section">
              <p class="erp-nav__label"><%= section[:label] %></p>
              <% section[:links].each do |link| %>
                <%= link_to link[:path], class: "erp-nav__link", aria: (link[:active] ? { current: "page" } : nil), data: { action: "shell#closeSidebar" } do %>
                  <i class="bi <%= link[:icon] %>" aria-hidden="true"></i>
                  <span><%= link[:label] %></span>
                <% end %>
              <% end %>
            </section>
          <% end %>
        </nav>

        <div class="erp-sidebar__foot"><%= t("app.version") %></div>
      </aside>

      <div class="erp-main">
        <header class="erp-topbar">
          <button class="erp-topbar__menu" type="button" data-action="shell#toggleSidebar" aria-label="打开导航">
            <i class="bi bi-list" aria-hidden="true"></i>
          </button>
          <div class="erp-topbar__title">
            <span class="erp-topbar__eyebrow"><%= t("app.topbar_eyebrow") %></span>
            <span class="erp-topbar__heading"><%= content_for?(:page_heading) ? yield(:page_heading) : t("app.name") %></span>
          </div>
          <div class="erp-topbar__actions">
            <nav class="locale-switcher" aria-label="<%= t("locale.switcher_label") %>">
              <% available_locales.each do |locale| %>
                <%= link_to t("locale.#{locale}"), locale_path.call(locale), class: "locale-switcher__link", aria: (I18n.locale == locale ? { current: "page" } : nil) %>
              <% end %>
            </nav>
            <% if user_signed_in? %>
              <div class="erp-user">
                <span class="erp-user__avatar" aria-hidden="true"><%= current_user.email.first.upcase %></span>
                <span><%= current_user.email %></span>
              </div>
              <%= button_to t("app.sign_out"), destroy_user_session_path, method: :delete, class: "link-button" %>
            <% end %>
          </div>
        </header>

        <main class="erp-content">
          <div class="page">
            <%= yield %>
          </div>
        </main>
      </div>

      <% if user_signed_in? %>
        <button
          class="button feedback-fab"
          type="button"
          data-feedback-target="start"
          data-action="feedback#start"
          data-default-label="<%= t("app.feedback") %>"
          data-selecting-label="<%= t("app.select_feedback_element") %>"><%= t("app.feedback") %></button>
        <div class="feedback-modal-backdrop" data-feedback-target="modal">
          <section class="feedback-modal">
            <h2 class="section-title"><%= t("feedback.title") %></h2>
            <form class="report-stack" data-feedback-target="form" data-action="submit->feedback#submit">
              <div class="field">
                <label for="feedback_issue_type"><%= t("feedback.issue_type") %></label>
                <select id="feedback_issue_type" name="issue_type">
                  <% %w[layout copy data interaction performance other].each do |type| %>
                    <option value="<%= type %>"><%= t("feedback.types.#{type}") %></option>
                  <% end %>
                </select>
              </div>
              <div class="field">
                <label for="feedback_description"><%= t("feedback.description") %></label>
                <textarea id="feedback_description" name="description" required></textarea>
              </div>
              <div class="field">
                <label for="feedback_suggestion"><%= t("feedback.suggestion") %></label>
                <textarea id="feedback_suggestion" name="suggestion"></textarea>
              </div>
              <div class="report-form">
                <button class="button" type="submit"><%= t("feedback.submit") %></button>
                <button class="button" type="button" data-action="feedback#cancel"><%= t("feedback.cancel") %></button>
              </div>
            </form>
          </section>
        </div>
      <% end %>
    </div>
  </body>
</html>
