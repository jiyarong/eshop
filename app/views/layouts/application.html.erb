<!DOCTYPE html>
<html lang="<%= I18n.locale == :zh ? "zh-CN" : I18n.locale %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="turbo-cache-control" content="no-preview">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <title><%= content_for?(:title) ? "#{yield(:title)} · #{t("app.name")}" : t("app.name") %></title>
    <%= favicon_link_tag "/favicon.png", type: "image/png" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", type: "module", "data-turbo-track": "reload", defer: true %>
  </head>
  <body class="erp-shell">
    <% current_path = request.path %>
    <% active_link = ->(prefixes) { Array(prefixes).any? { |prefix| current_path == prefix || current_path.start_with?("#{prefix}/") } } %>
    <% nav_sections = [
      {
        label: t("navigation.sections.sku"),
        links: [
          { label: t("navigation.erp_spus"), path: "/erp/spus", icon: "bi-grid-3x3-gap", active: active_link.call("/erp/spus") },
          { label: t("navigation.erp_skus"), path: "/erp/skus", icon: "bi-tags", active: active_link.call("/erp/skus") },
          { label: t("navigation.weekly_profit_reports"), path: "/weekly_profit_reports", icon: "bi-graph-up-arrow", active: active_link.call("/weekly_profit_reports") },
          { label: t("navigation.inventory"), path: "/reports/inventory", icon: "bi-box-seam", active: current_path == "/reports/inventory" },
          { label: t("navigation.tools"), path: "/reports/tools", icon: "bi-sliders2", active: active_link.call("/reports/tools") }
        ]
      },
      {
        label: t("navigation.sections.draft"),
        links: [
          { label: t("navigation.orders"), path: "/orders", icon: "bi-receipt", active: active_link.call("/orders") },
          { label: t("navigation.sku_sales"), path: "/reports/sku_sales", icon: "bi-bar-chart-line", active: current_path == "/reports/sku_sales" },
          { label: t("navigation.costs"), path: "/reports/costs", icon: "bi-cash-coin", active: current_path == "/reports/costs" },
          { label: t("navigation.erp_stores"), path: "/erp/stores", icon: "bi-shop", active: active_link.call("/erp/stores") },
          # { label: t("navigation.sku_categories"), path: "/erp/sku_categories", icon: "bi-diagram-3", active: active_link.call("/erp/sku_categories") },
          { label: t("navigation.sku_batches"), path: "/erp/sku_batches", icon: "bi-layers", active: active_link.call("/erp/sku_batches") },
          # { label: t("navigation.purchase_orders"), path: "/erp/purchase_orders", icon: "bi-cart-check", active: active_link.call("/erp/purchase_orders") },
          # { label: t("navigation.cost_allocations"), path: "/erp/cost_allocations", icon: "bi-calculator", active: active_link.call("/erp/cost_allocations") },
          # { label: t("navigation.operation_tasks"), path: "/erp/operation_tasks", icon: "bi-list-task", active: active_link.call("/erp/operation_tasks") }
        ]
      }
    ] %>
    <% admin_links = [] %>
    <% if can?(:manage_users) %>
      <% admin_links << { label: t("navigation.sub2_usage"), path: "/admin/sub2_usage", icon: "bi-speedometer2", active: active_link.call("/admin/sub2_usage") } %>
      <% admin_links << { label: t("navigation.users"), path: "/admin/users", icon: "bi-people", active: active_link.call("/admin/users") } %>
      <% admin_links << { label: t("navigation.agents"), path: "/admin/agents", icon: "bi-cpu", active: active_link.call("/admin/agents") } %>
      <% admin_links << { label: t("navigation.skills"), path: "/admin/skills", icon: "bi-puzzle", active: active_link.call("/admin/skills") } %>
      <% admin_links << { label: t("navigation.operation_logs"), path: "/admin/operation_logs", icon: "bi-clock-history", active: active_link.call("/admin/operation_logs") } %>
      <% admin_links << { label: t("navigation.gbrain"), path: "/admin/gbrain_pages", icon: "bi-journal-text", active: active_link.call("/admin/gbrain_pages") } %>
      <% admin_links << { label: t("navigation.mcp_debug"), path: "/admin/mcp_debug", icon: "bi-braces", active: active_link.call("/admin/mcp_debug") } %>
    <% end %>
    <% if can?(:manage_feedback_tasks) %>
      <% admin_links << { label: t("navigation.feedback_tasks"), path: "/admin/feedback_tasks", icon: "bi-chat-square-text", active: active_link.call("/admin/feedback_tasks") } %>
    <% end %>
    <% nav_sections.find { |section| section[:label] == t("navigation.sections.draft") }[:links].concat(admin_links) if admin_links.any? %>
    <% locale_path = ->(locale) { url_for(request.query_parameters.merge(locale: locale)) } %>

    <div
      class="app erp-shell__frame"
      data-controller="shell feedback"
      data-action="mouseover@document->feedback#hover click@document->feedback#choose">
      <aside class="sidebar erp-sidebar" data-shell-target="sidebar">
        <div class="sidebar-brand erp-brand">
          <span class="erp-brand__mark" aria-hidden="true">Y</span>
          <span>
            <span class="erp-brand__name">Yuanlong ERP</span>
            <span class="erp-brand__meta"><%= t("app.subtitle") %></span>
          </span>
        </div>

        <nav class="erp-nav" aria-label="Main navigation">
          <% nav_sections.each do |section| %>
            <section class="erp-nav__section">
              <p class="erp-nav__label"><%= section[:label] %></p>
              <% section[:links].each do |link| %>
                <%= link_to link[:path], class: "erp-nav__link", aria: (link[:active] ? { current: "page" } : nil), data: { action: "shell#closeSidebar", turbo_prefetch: false } do %>
                  <i class="bi <%= link[:icon] %>" aria-hidden="true"></i>
                  <span><%= link[:label] %></span>
                <% end %>
              <% end %>
            </section>
          <% end %>
        </nav>

        <div class="erp-sidebar__foot"><%= t("app.version") %></div>
      </aside>

      <div class="erp-main">
        <header class="header erp-topbar">
          <div class="hd-inner">
            <button
              class="sidebar-toggle erp-topbar__menu"
              type="button"
              data-action="shell#toggleSidebar"
              aria-label="折叠左侧菜单"
              aria-expanded="true"
              data-shell-target="toggle">
              <i class="bi bi-layout-sidebar" aria-hidden="true"></i>
            </button>
            <a class="brand" href="/" aria-label="<%= t("app.name") %>">
              <span class="erp-brand__mark" aria-hidden="true">Y</span>
              <span>Yuanlong ERP</span>
            </a>
            <div class="erp-topbar__title">
              <span class="erp-topbar__eyebrow"><%= t("app.topbar_eyebrow") %></span>
              <span class="erp-topbar__heading"><%= content_for?(:page_heading) ? yield(:page_heading) : t("app.name") %></span>
            </div>
            <div class="hd-right erp-topbar__actions">
              <details class="topbar-dropdown locale-switcher" aria-label="<%= t("locale.switcher_label") %>">
                <summary>
                  <span class="topbar-dropdown__label"><%= t("locale.switcher_label") %></span>
                  <span class="topbar-dropdown__value"><%= t("locale.#{I18n.locale}") %></span>
                  <i class="bi bi-chevron-down" aria-hidden="true"></i>
                </summary>
                <div class="topbar-dropdown__panel locale-switcher__panel">
                  <% available_locales.each do |locale| %>
                    <%= link_to locale_path.call(locale), class: "topbar-dropdown__item locale-switcher__item", aria: (I18n.locale == locale ? { current: "page" } : nil) do %>
                      <span><%= t("locale.names.#{locale}") %></span>
                      <% if I18n.locale == locale %>
                        <i class="bi bi-check2" aria-hidden="true"></i>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </details>
              <% if user_signed_in? %>
                <details
                  class="topbar-dropdown page-translation-controls"
                  data-controller="page-translation"
                  data-page-translation-target-locale-value="<%= I18n.locale %>"
                  data-page-translation-ignore>
                  <summary data-page-translation-target="summary">
                    <i class="bi bi-translate" aria-hidden="true"></i>
                    <span class="page-translation-controls__copy">
                      <span class="page-translation-controls__title"><%= t("page_translation.title") %></span>
                      <span
                        class="page-translation-controls__summary-status"
                        data-page-translation-target="summaryStatus"
                        data-idle-label="<%= t("page_translation.idle") %>"
                        data-loading-label="<%= t("page_translation.loading") %>"
                        data-done-label="<%= t("page_translation.done") %>"
                        data-error-label="<%= t("page_translation.error") %>"
                        data-json-error-label="<%= t("page_translation.json_error") %>"
                        data-no-change-label="<%= t("page_translation.no_change") %>"><%= t("page_translation.idle") %></span>
                    </span>
                    <i class="bi bi-chevron-down" aria-hidden="true"></i>
                  </summary>
                  <div class="topbar-dropdown__panel page-translation-controls__panel">
                  <button
                    class="topbar-dropdown__item page-translation-controls__button"
                    type="button"
                    data-page-translation-target="translateButton"
                    data-action="page-translation#translate"
                    data-loading-label="<%= t("page_translation.loading") %>"
                    data-done-label="<%= t("page_translation.done") %>"
                    data-error-label="<%= t("page_translation.error") %>"
                    data-json-error-label="<%= t("page_translation.json_error") %>"
                    data-no-change-label="<%= t("page_translation.no_change") %>">
                    <i class="bi bi-stars" aria-hidden="true"></i>
                    <span><%= t("page_translation.translate") %></span>
                  </button>
                  <button
                    class="topbar-dropdown__item page-translation-controls__button"
                    type="button"
                    data-page-translation-target="originalButton"
                    data-action="page-translation#showOriginal"
                    disabled>
                    <i class="bi bi-file-text" aria-hidden="true"></i>
                    <span><%= t("page_translation.original") %></span>
                  </button>
                  <button
                    class="topbar-dropdown__item page-translation-controls__button"
                    type="button"
                    data-page-translation-target="translationButton"
                    data-action="page-translation#showTranslation"
                    disabled>
                    <i class="bi bi-translate" aria-hidden="true"></i>
                    <span><%= t("page_translation.translation") %></span>
                  </button>
                  <span class="page-translation-controls__status" data-page-translation-target="status"></span>
                  </div>
                </details>
              <% end %>
              <% if user_signed_in? %>
                <div class="hd-divider" aria-hidden="true"></div>
                <details class="erp-account-menu">
                  <summary>
                    <span class="erp-user__avatar" aria-hidden="true"><%= current_user.display_name.first.upcase %></span>
                    <span class="erp-account-menu__email"><%= current_user.display_name %></span>
                    <i class="bi bi-chevron-down" aria-hidden="true"></i>
                  </summary>
                  <div class="erp-account-menu__panel">
                    <%= link_to "个人设置", edit_profile_path, class: "erp-account-menu__item" %>
                    <%= link_to t("app.change_password"), password_profile_path, class: "erp-account-menu__item" %>
                    <%= button_to t("app.sign_out"), destroy_user_session_path, class: "erp-account-menu__item erp-account-menu__button" %>
                  </div>
                </details>
              <% end %>
            </div>
          </div>
          <button class="erp-topbar__mobile-menu" type="button" data-action="shell#openSidebar" aria-label="打开导航">
            <i class="bi bi-list" aria-hidden="true"></i>
          </button>
        </header>

        <main class="main erp-content">
          <div id="global_toast" class="global-toast-stack" aria-live="polite" aria-atomic="true">
            <%= render "shared/flash_toasts" %>
          </div>
          <div class="page">
            <%= yield %>
          </div>
        </main>
      </div>

      <% if user_signed_in? %>
        <button
          class="button feedback-fab"
          type="button"
          data-feedback-target="start"
          data-action="feedback#start"
          data-default-label="<%= t("app.feedback") %>"
          data-selecting-label="<%= t("app.select_feedback_element") %>"><%= t("app.feedback") %></button>
        <div class="feedback-modal-backdrop" data-feedback-target="modal">
          <section class="feedback-modal">
            <h2 class="section-title"><%= t("feedback.title") %></h2>
            <form class="report-stack" data-feedback-target="form" data-action="submit->feedback#submit">
              <div class="field">
                <label for="feedback_issue_type"><%= t("feedback.issue_type") %></label>
                <select id="feedback_issue_type" name="issue_type">
                  <% %w[layout copy data interaction performance other].each do |type| %>
                    <option value="<%= type %>"><%= t("feedback.types.#{type}") %></option>
                  <% end %>
                </select>
              </div>
              <div class="field">
                <label for="feedback_description"><%= t("feedback.description") %></label>
                <textarea id="feedback_description" name="description" required></textarea>
              </div>
              <div class="field">
                <label for="feedback_suggestion"><%= t("feedback.suggestion") %></label>
                <textarea id="feedback_suggestion" name="suggestion"></textarea>
              </div>
              <div class="report-form">
                <button class="button" type="submit"><%= t("feedback.submit") %></button>
                <button class="button" type="button" data-action="feedback#cancel"><%= t("feedback.cancel") %></button>
              </div>
            </form>
          </section>
        </div>
      <% end %>
    </div>
  </body>
</html>
