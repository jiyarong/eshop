<h1 class="page-title">改动任务 #<%= @feedback_task.id %></h1>

<div class="report-stack">
  <section class="panel">
    <dl class="definition-list">
      <dt>页面 URL</dt>
      <dd><%= @feedback_task.page_url %></dd>
      <dt>页面标题</dt>
      <dd><%= @feedback_task.page_title || "-" %></dd>
      <dt>提交人</dt>
      <dd><%= @feedback_task.user.email %></dd>
      <dt>问题类型</dt>
      <dd><%= @feedback_task.issue_type %></dd>
      <dt>状态</dt>
      <dd><%= @feedback_task.status %></dd>
      <dt>问题描述</dt>
      <dd><%= @feedback_task.description %></dd>
      <dt>改善建议</dt>
      <dd><%= @feedback_task.suggestion.presence || "-" %></dd>
      <dt>元素选择器</dt>
      <dd><%= @feedback_task.selector.presence || "-" %></dd>
      <dt>元素文本</dt>
      <dd><%= @feedback_task.element_text.presence || "-" %></dd>
      <dt>元素位置</dt>
      <dd><%= @feedback_task.element_rect.presence || "-" %></dd>
      <dt>页面滚动</dt>
      <dd>x=<%= @feedback_task.scroll_x %>, y=<%= @feedback_task.scroll_y %></dd>
      <dt>视口</dt>
      <dd><%= @feedback_task.viewport_width || "-" %> x <%= @feedback_task.viewport_height || "-" %></dd>
      <dt>User Agent</dt>
      <dd><%= @feedback_task.user_agent.presence || "-" %></dd>
    </dl>
  </section>

  <section class="panel">
    <h2 class="section-title">处理</h2>
    <%= form_with model: [:admin, @feedback_task], class: "report-form" do |form| %>
      <% if @feedback_task.errors.any? %>
        <div class="panel error-box">
          <%= @feedback_task.errors.full_messages.join("；") %>
        </div>
      <% end %>
      <div class="field">
        <%= form.label :status, "状态" %>
        <%= form.select :status, FeedbackTask::STATUSES %>
      </div>
      <div class="field">
        <%= form.label :assignee_note, "处理备注" %>
        <%= form.text_field :assignee_note %>
      </div>
      <%= form.submit "保存", class: "button" %>
    <% end %>
  </section>
</div>
