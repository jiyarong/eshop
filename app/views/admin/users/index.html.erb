<h1 class="page-title">用户管理</h1>

<section class="panel">
  <p><%= link_to "新增用户", admin_new_user_path, class: "button" %></p>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th><%= t("admin.users.fields.name") %></th>
          <th><%= t("admin.users.fields.email") %></th>
          <th>角色</th>
          <th>状态</th>
          <th>最后登录</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= link_to user.display_name, admin_user_path(user) %></td>
            <td><%= user.email %></td>
            <td><%= user.roles.order(:position).map(&:name).join(" / ") %></td>
            <td><%= user.active? ? "启用" : "停用" %></td>
            <td><%= user.last_sign_in_at || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
