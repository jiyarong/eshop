<%= form_with model: agent,
  url: agent.persisted? ? admin_agent_path(agent.code) : admin_agents_path,
  method: agent.persisted? ? :patch : :post,
  multipart: true,
  class: "ai-agent-form" do |form| %>
  <% if agent.errors.any? %>
    <div class="error-box ai-form-errors" role="alert">
      <i class="bi bi-exclamation-circle" aria-hidden="true"></i>
      <span><%= agent.errors.full_messages.join(t("common.list_separator")) %></span>
    </div>
  <% end %>

  <div class="ai-editor-layout">
    <div class="panel ai-editor-main">
      <section class="ai-form-section">
        <div class="ai-form-section__heading">
          <i class="bi bi-person-badge" aria-hidden="true"></i>
          <h2><%= t("admin.agents.sections.identity") %></h2>
        </div>
        <div class="ai-form-grid ai-form-grid--identity">
          <div class="field">
            <%= form.label :code, t("admin.agents.fields.code") %>
            <% if agent.persisted? %>
              <%= form.text_field :code, disabled: true, class: "code-input" %>
            <% else %>
              <%= form.text_field :code, required: true, class: "code-input" %>
            <% end %>
          </div>
          <div class="field">
            <%= form.label :name, t("admin.agents.fields.name") %>
            <%= form.text_field :name, required: true %>
          </div>
          <div class="field field--full">
            <%= form.label :description, t("admin.agents.fields.description") %>
            <%= form.text_field :description %>
          </div>
        </div>
      </section>

      <section class="ai-form-section">
        <div class="ai-form-section__heading">
          <i class="bi bi-sliders" aria-hidden="true"></i>
          <h2><%= t("admin.agents.sections.model") %></h2>
        </div>
        <div class="ai-form-grid ai-form-grid--model">
          <div class="field">
            <%= form.label :model_id, t("admin.agents.fields.model_id") %>
            <%= form.text_field :model_id, required: true, class: "code-input" %>
          </div>
          <div class="field">
            <%= form.label :temperature, t("admin.agents.fields.temperature") %>
            <%= form.number_field :temperature, min: 0, max: 1, step: 0.01, required: true %>
          </div>
          <div class="ai-toggle-grid">
            <label class="checkbox-option ai-toggle-option">
              <%= form.check_box :thinking_enabled %>
              <span>
                <strong><%= t("admin.agents.fields.thinking_enabled") %></strong>
                <small><%= t("admin.agents.hints.thinking") %></small>
              </span>
            </label>
            <label class="checkbox-option ai-toggle-option">
              <%= form.check_box :enabled %>
              <span>
                <strong><%= t("admin.agents.fields.enabled") %></strong>
                <small><%= t("admin.agents.hints.enabled") %></small>
              </span>
            </label>
          </div>
        </div>
      </section>

      <section class="ai-form-section">
        <div class="ai-form-section__heading">
          <i class="bi bi-chat-square-text" aria-hidden="true"></i>
          <h2><%= t("admin.agents.sections.prompts") %></h2>
        </div>
        <div class="field field--full">
          <%= form.label :system_prompt, t("admin.agents.fields.system_prompt") %>
          <%= form.text_area :system_prompt, rows: 13, required: true, class: "ai-prompt-editor" %>
        </div>
        <div class="field field--full">
          <%= form.label :recommended_prompts_text, t("admin.agents.fields.recommended_prompts") %>
          <%= form.text_area :recommended_prompts_text,
            rows: 5,
            placeholder: t("admin.agents.placeholders.recommended_prompts") %>
        </div>
      </section>
    </div>

    <aside class="ai-editor-sidebar">
      <section class="panel ai-side-panel">
        <div class="ai-form-section__heading">
          <i class="bi bi-puzzle" aria-hidden="true"></i>
          <h2><%= t("admin.agents.fields.skills") %></h2>
          <span class="ai-section-count"><%= skills.size %></span>
        </div>
        <% if skills.any? %>
          <div class="ai-skill-options">
            <%= form.collection_check_boxes :skill_ids, skills, :id, :name do |checkbox| %>
              <% skill = checkbox.object %>
              <%= checkbox.label(class: "checkbox-option ai-skill-option") do %>
                <%= checkbox.check_box %>
                <span>
                  <strong><%= checkbox.text %></strong>
                  <small><%= skill.description %></small>
                </span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="ai-side-empty">
            <span><%= t("admin.agents.empty_skills") %></span>
            <%= link_to t("admin.skills.actions.new"), new_admin_skill_path %>
          </div>
        <% end %>
      </section>

      <section class="panel ai-side-panel">
        <div class="ai-form-section__heading">
          <i class="bi bi-image" aria-hidden="true"></i>
          <h2><%= t("admin.agents.fields.avatar") %></h2>
        </div>
        <div class="ai-avatar-field">
          <% if agent.avatar.attached? %>
            <%= image_tag agent.avatar, class: "agent-avatar-preview", alt: t("admin.agents.avatar_alt", name: agent.name) %>
          <% else %>
            <span class="agent-avatar-preview agent-avatar-preview--fallback" aria-hidden="true"><%= agent.name.to_s.first&.upcase.presence || "AI" %></span>
          <% end %>
          <%= form.file_field :avatar, accept: "image/*" %>
        </div>
      </section>
    </aside>
  </div>

  <div class="ai-form-actions">
    <%= link_to admin_agents_path, class: "button button-secondary" do %>
      <i class="bi bi-x-lg" aria-hidden="true"></i>
      <span><%= t("common.actions.cancel") %></span>
    <% end %>
    <%= form.button class: "button", type: "submit" do %>
      <i class="bi bi-check-lg" aria-hidden="true"></i>
      <span><%= t("common.actions.save") %></span>
    <% end %>
  </div>
<% end %>
