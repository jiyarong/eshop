<div class="page-heading-row">
  <h1 class="page-title"><%= t("admin.agents.index.title") %></h1>
  <div class="page-actions">
    <%= link_to t("admin.skills.index.title"), admin_skills_path, class: "button button-secondary" %>
    <%= link_to t("admin.agents.actions.new"), new_admin_agent_path, class: "button" %>
  </div>
</div>

<section class="panel">
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th><%= t("admin.agents.fields.code") %></th>
          <th><%= t("admin.agents.fields.name") %></th>
          <th><%= t("admin.agents.fields.model_id") %></th>
          <th><%= t("admin.agents.fields.skills") %></th>
          <th><%= t("admin.agents.fields.status") %></th>
          <th><%= t("admin.agents.fields.updated_at") %></th>
          <th><%= t("admin.agents.fields.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @agents.each do |agent| %>
          <tr>
            <td><%= agent.code %></td>
            <td><%= agent.name %></td>
            <td><%= agent.model_id %></td>
            <td><%= agent.skills.sort_by(&:name).map(&:name).join(" / ").presence || t("common.empty_value") %></td>
            <td><%= agent.enabled? ? t("admin.agents.statuses.enabled") : t("admin.agents.statuses.disabled") %></td>
            <td><%= display_time(agent.updated_at) %></td>
            <td><%= link_to t("common.actions.edit"), edit_admin_agent_path(agent.code) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
