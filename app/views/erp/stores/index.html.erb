<% content_for :page_heading, t("erp.stores.index.title") %>

<div class="store-management product-management">
  <%= turbo_frame_tag "erp_modal" %>

  <div class="page-h">
    <div>
      <h1><%= t("erp.stores.index.title") %></h1>
      <p class="sub">Shop Platform · Company Scale · Registration Country</p>
    </div>
    <div class="hstack product-page-actions">
      <%= link_to erp_new_store_path(current_locale_params), class: "btn btn-primary", data: { turbo_frame: "erp_modal" } do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        <%= t("erp.stores.actions.add_store") %>
      <% end %>
    </div>
  </div>

  <section class="product-summary-grid" aria-label="<%= t("erp.stores.index.store_overview") %>">
    <div class="product-summary-card">
      <span class="summary-label"><%= t("erp.stores.index.all_stores") %></span>
      <strong class="summary-value"><%= @store_counts[:total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label"><%= t("erp.common.statuses.active") %></span>
      <strong class="summary-value"><%= @store_counts[:active] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label">Ozon</span>
      <strong class="summary-value"><%= @store_counts[:ozon] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label">WB</span>
      <strong class="summary-value"><%= @store_counts[:wb] %></strong>
    </div>
  </section>

  <section class="card product-filter-card">
    <%= form_with url: erp_stores_path, method: :get, local: true, class: "product-filter-form" do |form| %>
      <div class="product-search-control">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= form.search_field :q, value: @q, placeholder: t("erp.stores.filters.search_placeholder"), class: "input" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :platform, t("erp.common.platform"), class: "label" %>
        <%= form.select :platform, store_platform_options, { include_blank: t("erp.stores.filters.all_platforms"), selected: @platform }, class: "select" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :company_type, t("erp.stores.fields.scale"), class: "label" %>
        <%= form.select :company_type, store_company_type_options, { include_blank: t("erp.stores.filters.all_scales"), selected: @company_type }, class: "select" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :registration_country, t("erp.stores.fields.country"), class: "label" %>
        <%= form.select :registration_country, store_country_options, { include_blank: t("erp.stores.filters.all_countries"), selected: @registration_country }, class: "select" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :status, t("erp.common.status"), class: "label" %>
        <%= form.select :status, [[t("erp.common.filter_options.all"), "all"], [t("erp.common.statuses.active"), "active"], [t("erp.common.statuses.inactive"), "inactive"]], { selected: @status }, class: "select" %>
      </div>
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= t("erp.common.actions.filter") %>
      </button>
      <%= link_to erp_stores_path, class: "btn btn-outline" do %>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
        <%= t("erp.common.actions.reset") %>
      <% end %>
      <div class="spacer"></div>
      <span class="text-sm text-muted"><%= t("erp.stores.index.store_count", count: @stores.size) %></span>
    <% end %>
  </section>

  <section class="card product-list-card">
    <table class="prod-tbl store-tbl">
      <thead>
        <tr>
          <th style="width: 120px"><%= t("erp.stores.fields.store_id") %></th>
          <th style="width: 110px"><%= t("erp.common.platform") %></th>
          <th style="min-width: 220px"><%= t("erp.common.name") %></th>
          <th style="width: 150px"><%= t("erp.stores.fields.company_scale") %></th>
          <th style="width: 150px"><%= t("erp.stores.fields.registration_country") %></th>
          <th style="width: 120px"><%= t("erp.stores.fields.is_active") %></th>
          <th style="min-width: 180px"><%= t("erp.common.memo") %></th>
          <th style="width: 110px; text-align: right"><%= t("erp.common.actions.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @stores.each do |store| %>
          <tr class="master">
            <td><span class="code-text"><%= store_public_id(store) %></span></td>
            <td><span class="badge badge-pri"><%= store_platform_label(store.platform).upcase %></span></td>
            <td><%= link_to store.store_name, erp_store_path(store, current_locale_params), class: "zh-name" %></td>
            <td><%= store_company_type_label(store.company_type) %></td>
            <td><%= store_country_label(store.registration_country) %></td>
            <td>
              <% if store.is_active %>
                <span class="badge badge-suc"><span class="dot"></span><%= t("erp.common.statuses.active") %></span>
              <% else %>
                <span class="badge badge-sec"><span class="dot dot-muted"></span><%= t("erp.common.statuses.inactive") %></span>
              <% end %>
            </td>
            <td><span class="text-muted"><%= erp_value(store.memo) %></span></td>
            <td>
              <div class="row-actions">
                <%= link_to erp_store_path(store, current_locale_params), class: "btn btn-ghost btn-sm" do %>
                  <i class="bi bi-eye" aria-hidden="true"></i>
                  <%= t("erp.common.actions.view") %>
                <% end %>
                <%= link_to erp_edit_store_path(store, current_locale_params), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-pencil-square" aria-hidden="true"></i>
                  <%= t("erp.common.actions.edit") %>
                <% end if can?(:manage_skus) %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @stores.empty? %>
          <tr>
            <td colspan="8">
              <div class="nested-empty-state"><%= t("erp.stores.empty.no_stores") %></div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>
