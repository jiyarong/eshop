<%= form_with model: store, url: store.persisted? ? erp_store_path(store) : erp_stores_path, data: (local_assigns[:modal] ? { turbo_frame: "_top" } : {}) do |form| %>
  <% if store.errors.any? %>
    <div class="panel error-box">
      <%= store.errors.full_messages.join("；") %>
    </div>
  <% end %>

  <div class="report-form modal-form-grid">
    <div class="field">
      <%= form.label :platform, t("erp.common.platform") %>
      <%= form.select :platform, store_platform_options %>
    </div>
    <div class="field">
      <%= form.label :company_type, t("erp.stores.fields.company_scale") %>
      <%= form.select :company_type, store_company_type_options %>
    </div>
    <div class="field modal-form-grid__wide">
      <%= form.label :store_name, t("erp.common.name") %>
      <%= form.text_field :store_name, placeholder: t("erp.stores.form.store_name_placeholder") %>
    </div>
    <div class="field">
      <%= form.label :registration_country, t("erp.stores.fields.registration_country") %>
      <%= form.select :registration_country, store_country_options, { include_blank: t("erp.common.please_select") } %>
    </div>
    <div class="field">
      <%= form.label :is_active, t("erp.stores.fields.is_active") %>
      <label class="switch-checkbox">
        <%= form.check_box :is_active %>
        <span><%= t("erp.stores.form.inactive_hint") %></span>
      </label>
    </div>
    <div class="field modal-form-grid__wide">
      <%= form.label :memo, t("erp.common.memo") %>
      <%= form.text_field :memo %>
    </div>
    <%= form.submit t("common.actions.save"), class: "button" %>
  </div>
<% end %>
