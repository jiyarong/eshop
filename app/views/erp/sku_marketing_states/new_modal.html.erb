<%= turbo_frame_tag "erp_modal" do %>
  <div class="erp-modal-backdrop" data-controller="modal" data-action="click->modal#closeOnBackdrop">
    <section class="erp-modal erp-modal--wide" role="dialog" aria-modal="true" aria-labelledby="sku-marketing-state-modal-title">
      <div class="erp-modal__header">
        <h2 id="sku-marketing-state-modal-title"><%= t("erp.sku_marketing_states.actions.adjust", sku: @sku.sku_code) %></h2>
        <button class="icon-button" type="button" aria-label="<%= t("common.actions.close") %>" data-action="modal#close">
          <i class="bi bi-x-lg" aria-hidden="true"></i>
        </button>
      </div>
      <%= render "form", sku: @sku, marketing_state: @marketing_state, modal: true %>
      <%= render "history", marketing_states: @marketing_states %>
    </section>
  </div>
<% end %>
