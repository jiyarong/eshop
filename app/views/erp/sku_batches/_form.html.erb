<%= form_with model: batch, url: batch.persisted? ? erp_sku_batch_path(batch) : erp_sku_batches_path, data: (local_assigns[:modal] ? { turbo_frame: "_top" } : {}) do |form| %>
  <% if batch.errors.any? %>
    <div class="panel error-box">
      <%= batch.errors.full_messages.join("；") %>
    </div>
  <% end %>

  <div class="report-form">
    <div class="field">
      <%= form.label :sku_code, "SKU" %>
      <%= form.collection_select :sku_code, sku_options, :sku_code, :sku_code %>
    </div>
    <div class="field">
      <%= form.label :batch_code, t("erp.sku_batches.fields.batch_code") %>
      <%= form.text_field :batch_code %>
    </div>
    <div class="field">
      <%= form.label :status, t("erp.common.status") %>
      <%= form.select :status, Ec::SkuBatch::STATUSES %>
    </div>
    <div class="field">
      <%= form.label :purchased_quantity, t("erp.sku_batches.fields.purchased_quantity") %>
      <%= form.number_field :purchased_quantity, min: 0 %>
    </div>
    <div class="field">
      <%= form.label :received_quantity, t("erp.sku_batches.fields.received_quantity") %>
      <%= form.number_field :received_quantity, min: 0 %>
    </div>
    <div class="field">
      <%= form.label :purchase_unit_price_cny, t("erp.sku_batches.fields.purchase_unit_price") %>
      <%= form.number_field :purchase_unit_price_cny, min: 0, step: "0.0001" %>
    </div>
    <div class="field">
      <%= form.label :expected_arrival_on, t("erp.sku_batches.fields.expected_arrival") %>
      <%= form.date_field :expected_arrival_on %>
    </div>
    <div class="field">
      <%= form.label :received_on, t("erp.sku_batches.fields.actual_arrival") %>
      <%= form.date_field :received_on %>
    </div>
    <div class="field">
      <%= form.label :memo, t("erp.common.memo") %>
      <%= form.text_field :memo %>
    </div>
    <%= form.submit t("common.actions.save"), class: "button" %>
  </div>
<% end %>
