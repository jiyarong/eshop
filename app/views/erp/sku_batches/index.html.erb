<h1 class="page-title"><%= t("erp.sku_batches.index.title") %></h1>

<section class="panel">
  <p><%= link_to t("erp.sku_batches.actions.add_sku_batch"), erp_new_sku_batch_path(current_locale_params), class: "button" %></p>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th><%= t("erp.sku_batches.fields.batch_code") %></th>
          <th>SKU</th>
          <th><%= t("erp.sku_batches.fields.product_name") %></th>
          <th><%= t("erp.common.status") %></th>
          <th><%= t("erp.sku_batches.fields.purchased_quantity") %></th>
          <th><%= t("erp.sku_batches.fields.received_quantity") %></th>
          <th><%= t("erp.sku_batches.fields.purchase_unit_price") %></th>
        </tr>
      </thead>
      <tbody>
        <% @batches.each do |batch| %>
          <tr>
            <td><%= link_to batch.batch_code, erp_sku_batch_path(batch) %></td>
            <td><%= batch.sku_code %></td>
            <td><%= batch.sku&.product_name %></td>
            <td><%= batch.status %></td>
            <td><%= batch.purchased_quantity %></td>
            <td><%= batch.received_quantity %></td>
            <td><%= erp_value(batch.purchase_unit_price_cny) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
