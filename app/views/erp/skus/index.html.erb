<% content_for :page_heading, "产品管理" %>

<% total_visible_skus = @master_sku_entries.sum { |entry| entry[:skus].size } + @orphan_skus.size %>

<div class="product-management">
  <%= turbo_frame_tag "erp_modal" %>

  <div class="page-h">
    <div>
      <h1>产品管理</h1>
      <p class="sub">Master Product · SKU Variant · Batch Inventory</p>
    </div>
    <div class="hstack product-page-actions">
      <%#= link_to erp_sku_categories_path, class: "btn btn-outline" do %>
<!--        <i class="bi bi-diagram-3" aria-hidden="true"></i>-->
<!--        类别管理-->
      <%# end %>
      <%= link_to erp_new_master_sku_path, class: "btn btn-primary", data: { turbo_frame: "erp_modal" } do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        新增产品
      <% end %>
    </div>
  </div>

  <section class="product-summary-grid" aria-label="产品概览">
    <div class="product-summary-card">
      <span class="summary-label">Master SKU</span>
      <strong class="summary-value"><%= @product_counts[:master_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label">SKU</span>
      <strong class="summary-value"><%= @product_counts[:sku_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label">批次</span>
      <strong class="summary-value"><%= @product_counts[:batch_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label">启用产品</span>
      <strong class="summary-value"><%= @product_counts[:active_master_total] %></strong>
    </div>
  </section>

  <section class="card product-filter-card">
    <%= form_with url: erp_skus_path, method: :get, local: true, class: "product-filter-form" do |form| %>
      <div class="product-search-control">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= form.search_field :q, value: @q, placeholder: "搜索 Master SKU、中文名或俄文名…", class: "input" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :status, "状态", class: "label" %>
        <%= form.select :status, [["全部", "all"], ["启用", "active"], ["停用", "inactive"]], { selected: @status }, class: "select" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :category_id, "类别", class: "label" %>
        <%= form.collection_select :category_id, @categories, :id, :name, { include_blank: "全部类别", selected: @category_id }, class: "select" %>
      </div>
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-search" aria-hidden="true"></i>
        筛选
      </button>
      <%= link_to erp_skus_path, class: "btn btn-outline" do %>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
        重置
      <% end %>
      <div class="spacer"></div>
      <span class="text-sm text-muted"><%= @master_sku_entries.size %> · <%= total_visible_skus %> SKU</span>
    <% end %>
  </section>

  <section class="card product-list-card" data-controller="product-tree">
    <table class="prod-tbl">
      <thead>
        <tr>
          <th style="width: 36px"></th>
          <th style="width: 160px">Master SKU</th>
          <th style="min-width: 220px">中文名</th>
          <th style="min-width: 260px">俄文名</th>
          <th style="width: 120px">SKU</th>
          <th style="width: 120px">批次</th>
          <th style="width: 120px">状态</th>
          <th style="width: 150px; text-align: right">操作</th>
        </tr>
      </thead>
      <tbody>
        <% @master_sku_entries.each do |entry| %>
          <% master_sku = entry[:master_sku] %>
          <% skus = entry[:skus] %>
          <% batch_total = skus.sum { |sku| sku.batches.size } %>
          <tr class="master open">
            <td>
              <button class="chev product-tree-toggle" type="button" data-action="product-tree#toggleMaster" data-label="<%= master_sku.master_sku_code %>" aria-label="收起 <%= master_sku.master_sku_code %>" aria-expanded="true">
                <i class="bi bi-chevron-down" aria-hidden="true"></i>
              </button>
            </td>
            <td><span class="code-text"><%= master_sku.master_sku_code %></span></td>
            <td><span class="zh-name"><%= erp_value(master_sku.product_name) %></span></td>
            <td><span class="ru-name"><%= erp_value(master_sku.product_name_ru) %></span></td>
            <td><span class="num"><%= skus.size %></span> 个 SKU</td>
            <td><span class="num"><%= batch_total %></span> 个批次</td>
            <td>
              <% if master_sku.is_active %>
                <span class="badge badge-suc">Active</span>
              <% else %>
                <span class="badge badge-sec">停用</span>
              <% end %>
            </td>
            <td>
              <div class="row-actions">
                <%= link_to erp_edit_master_sku_path(master_sku), class: "ico-btn", title: "编辑产品", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-pencil" aria-hidden="true"></i>
                  <span class="sr-only">编辑产品</span>
                <% end if can?(:manage_skus) %>
                <%= link_to erp_new_sku_path(master_sku_id: master_sku.id), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-plus-lg" aria-hidden="true"></i>
                  新增 SKU
                <% end %>
              </div>
            </td>
          </tr>
          <tr class="sub-row">
            <td colspan="8">
              <div class="sub-shell">
                <div class="sub-h">
                  <span>SKU 变体 · <%= skus.size %> 个</span>
                </div>
                <% if skus.any? %>
                  <table class="sub-tbl">
                    <thead>
                      <tr>
                        <th style="width: 180px">SKU</th>
                        <th>属性</th>
                        <th style="width: 120px; text-align: right">采购</th>
                        <th style="width: 120px; text-align: right">入库</th>
                        <th style="width: 110px">批次</th>
                        <th style="width: 170px; text-align: right">操作</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% skus.each do |sku| %>
                        <% batches = sku.batches.sort_by { |batch| [batch.received_on || Date.new(1900, 1, 1), batch.id || 0] }.reverse.first(10) %>
                        <% purchased_quantity = sku.batches.sum(&:purchased_quantity) %>
                        <% received_quantity = sku.batches.sum(&:received_quantity) %>
                        <tr class="sku-row open">
                          <td>
                            <button class="chev product-tree-toggle" type="button" data-action="product-tree#toggleSku" data-label="<%= sku.sku_code %> 批次" aria-label="收起 <%= sku.sku_code %> 批次" aria-expanded="true">
                              <i class="bi bi-chevron-down" aria-hidden="true"></i>
                            </button>
                            <%= link_to sku.sku_code, erp_sku_path(sku), class: "code-text sub" %>
                          </td>
                          <td>
                            <div class="attr-zh"><%= erp_value(sku.sku_category&.name) %></div>
                            <div class="attr-ru text-xs"><%= [erp_value(sku.color), erp_value(sku.spec), erp_value(sku.model)].reject { |value| value == "-" }.join(" · ").presence || "#{erp_value(sku.product_name)} · #{erp_value(sku.product_name_ru)}" %></div>
                          </td>
                          <td style="text-align: right"><span class="stock-num"><%= purchased_quantity %></span></td>
                          <td style="text-align: right"><span class="stock-num"><%= received_quantity %></span></td>
                          <td><span class="badge badge-sec"><%= sku.batches.size %> 批</span></td>
                          <td>
                            <div class="row-actions">
                              <%= link_to "查看", erp_sku_path(sku), class: "btn btn-ghost btn-sm" %>
                              <%= link_to erp_edit_sku_path(sku), class: "ico-btn", title: "编辑", data: { turbo_frame: "erp_modal" } do %>
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                <span class="sr-only">编辑</span>
                              <% end if can?(:manage_skus) %>
                              <%= link_to erp_new_sku_batch_path(sku_code: sku.sku_code), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                新增批次
                              <% end %>
                            </div>
                          </td>
                        </tr>
                        <tr class="batch-row">
                          <td colspan="6">
                            <div class="batch-shell">
                              <div class="batch-h">
                                <div>
                                  <span class="batch-title">批次清单</span>
                                  <span><%= sku.batches.size %> 个批次</span>
                                </div>
                                <span>已展示最近 <%= batches.size %> / <%= sku.batches.size %> 个批次</span>
                              </div>
                              <% if batches.any? %>
                                <table class="batch-tbl">
                                  <thead>
                                    <tr>
                                      <th>批号</th>
                                      <th style="width: 112px">采购日期</th>
                                      <th style="width: 112px">出境日期</th>
                                      <th style="width: 126px">境外交付日期</th>
                                      <th style="width: 100px; text-align: right">采购数量</th>
                                      <th style="width: 100px; text-align: right">入库数量</th>
                                      <th style="width: 110px">状态</th>
                                      <th style="width: 80px; text-align: right">操作</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% batches.each do |batch| %>
                                      <tr>
                                        <td><span class="barcode"><%= batch.batch_code %></span></td>
                                        <td><span class="barcode"><%= erp_value(batch.created_at&.to_date) %></span></td>
                                        <td><span class="barcode"><%= erp_value(batch.expected_arrival_on) %></span></td>
                                        <td><span class="barcode"><%= erp_value(batch.received_on) %></span></td>
                                        <td style="text-align: right"><%= batch.purchased_quantity %></td>
                                        <td style="text-align: right"><%= batch.received_quantity %></td>
                                        <td><span class="badge badge-sec"><%= batch.status %></span></td>
                                        <td>
                                          <div class="row-actions">
                                            <%= link_to erp_edit_sku_batch_path(batch), class: "ico-btn", title: "编辑", data: { turbo_frame: "erp_modal" } do %>
                                              <i class="bi bi-pencil" aria-hidden="true"></i>
                                              <span class="sr-only">编辑</span>
                                            <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                                          </div>
                                        </td>
                                      </tr>
                                    <% end %>
                                  </tbody>
                                </table>
                              <% else %>
                                <div class="nested-empty-state">还没有批次记录。</div>
                              <% end %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                <% else %>
                  <div class="nested-empty-state">当前筛选条件下没有 SKU。</div>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>

        <% @orphan_skus.each do |sku| %>
          <% batches = sku.batches.sort_by { |batch| [batch.received_on || Date.new(1900, 1, 1), batch.id || 0] }.reverse.first(10) %>
          <tr class="master open">
            <td>
              <button class="chev product-tree-toggle" type="button" data-action="product-tree#toggleMaster" data-label="<%= sku.sku_code %> 批次" aria-label="收起 <%= sku.sku_code %> 批次" aria-expanded="true">
                <i class="bi bi-chevron-down" aria-hidden="true"></i>
              </button>
            </td>
            <td><span class="code-text">未归档</span></td>
            <td><span class="zh-name"><%= erp_value(sku.product_name) %></span></td>
            <td><span class="ru-name"><%= erp_value(sku.product_name_ru) %></span></td>
            <td><span class="code-text sub"><%= sku.sku_code %></span></td>
            <td><span class="num"><%= sku.batches.size %></span> 个批次</td>
            <td>
              <% if sku.is_active %>
                <span class="badge badge-suc">Active</span>
              <% else %>
                <span class="badge badge-sec">下架</span>
              <% end %>
            </td>
            <td>
              <div class="row-actions">
                <%= link_to "查看", erp_sku_path(sku), class: "btn btn-ghost btn-sm" %>
                <%= link_to erp_edit_sku_path(sku), class: "ico-btn", title: "编辑", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-pencil" aria-hidden="true"></i>
                  <span class="sr-only">编辑</span>
                <% end if can?(:manage_skus) %>
                <%= link_to erp_new_sku_batch_path(sku_code: sku.sku_code), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-plus-lg" aria-hidden="true"></i>
                  新增批次
                <% end %>
              </div>
            </td>
          </tr>
          <% if batches.any? %>
            <tr class="batch-row">
              <td colspan="8">
                <div class="batch-shell batch-shell--orphan">
                  <div class="batch-h">
                    <div>
                      <span class="batch-title">批次清单</span>
                      <span><%= sku.batches.size %> 个批次</span>
                    </div>
                  </div>
                  <table class="batch-tbl">
                    <thead>
                      <tr>
                        <th>批号</th>
                        <th>采购日期</th>
                        <th>出境日期</th>
                        <th>境外交付日期</th>
                        <th style="text-align: right">采购数量</th>
                        <th style="text-align: right">入库数量</th>
                        <th>状态</th>
                        <th style="text-align: right">操作</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% batches.each do |batch| %>
                        <tr>
                          <td><span class="barcode"><%= batch.batch_code %></span></td>
                          <td><span class="barcode"><%= erp_value(batch.created_at&.to_date) %></span></td>
                          <td><span class="barcode"><%= erp_value(batch.expected_arrival_on) %></span></td>
                          <td><span class="barcode"><%= erp_value(batch.received_on) %></span></td>
                          <td style="text-align: right"><%= batch.purchased_quantity %></td>
                          <td style="text-align: right"><%= batch.received_quantity %></td>
                          <td><span class="badge badge-sec"><%= batch.status %></span></td>
                          <td>
                            <div class="row-actions">
                              <%= link_to erp_edit_sku_batch_path(batch), class: "ico-btn", title: "编辑", data: { turbo_frame: "erp_modal" } do %>
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                <span class="sr-only">编辑</span>
                              <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>

        <% if @master_sku_entries.empty? && @orphan_skus.empty? %>
          <tr>
            <td colspan="8" class="empty-state">
              <i class="bi bi-inbox" aria-hidden="true"></i>
              没有找到匹配的产品。
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>
