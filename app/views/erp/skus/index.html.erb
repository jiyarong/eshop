<% content_for :page_heading, t("erp.skus.index.title") %>

<div class="product-management sku-management">
  <%= turbo_frame_tag "erp_modal" %>

  <div class="page-h">
    <div>
      <h1><%= t("erp.skus.index.title") %></h1>
      <p class="sub"><%= t("erp.skus.index.hierarchy") %></p>
    </div>
    <div class="hstack product-page-actions">
      <%= link_to erp_new_sku_path(current_locale_params.merge(return_to: current_page_return_to)), class: "btn btn-primary", data: { turbo_frame: "erp_modal" } do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        <%= t("erp.skus.actions.add_sku") %>
      <% end %>
    </div>
  </div>

  <section class="product-summary-grid" aria-label="<%= t("erp.skus.index.sku_overview") %>">
    <div class="product-summary-card">
      <span class="summary-label">SKU</span>
      <strong class="summary-value"><%= @sku_counts[:sku_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label"><%= t("erp.skus.fields.master_sku") %></span>
      <strong class="summary-value"><%= @sku_counts[:master_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label"><%= t("erp.common.batches") %></span>
      <strong class="summary-value"><%= @sku_counts[:batch_total] %></strong>
    </div>
  </section>

  <section class="card product-filter-card">
    <%= form_with url: erp_skus_path, method: :get, local: true, class: "product-filter-form" do |form| %>
      <div class="product-search-control">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= form.search_field :q, value: @q, placeholder: t("erp.skus.filters.sku_search_placeholder"), class: "input" %>
      </div>
      <%= render "shared/master_sku_category_filter",
        field_class: "product-filter-field" %>
      <%= render "shared/spu_sku_filter",
        field_class: "product-filter-field",
        dom_id_prefix: "sku-spu-sku-filter" %>
      <%= render "shared/popover_multiselect_filter",
        dom_id_prefix: "sku-grade-filter",
        param_name: "grades",
        label: t("erp.sku_marketing_states.fields.grade"),
        all_label: t("erp.skus.filters.all_grades"),
        selected_values: @grades,
        options: Ec::SkuMarketingState::GRADES.map { |grade| [grade, grade] } %>
      <%= render "shared/popover_multiselect_filter",
        dom_id_prefix: "sku-stage-filter",
        param_name: "stages",
        label: t("erp.sku_marketing_states.fields.stage"),
        all_label: t("erp.skus.filters.all_stages"),
        selected_values: @stages,
        options: Ec::SkuMarketingState::STAGES.map { |stage| [stage.upcase, stage] } %>
      <%= render "shared/responsible_user_filters",
        field_class: "product-filter-field",
        dom_id_prefix: "sku-responsible-user-filter" %>
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= t("erp.common.actions.filter") %>
      </button>
      <%= link_to erp_skus_path(current_locale_params), class: "btn btn-outline" do %>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
        <%= t("erp.common.actions.reset") %>
      <% end %>
      <div class="spacer"></div>
      <span class="text-sm text-muted"><%= @skus.respond_to?(:total_count) ? @skus.total_count : @skus.size %> SKU</span>
    <% end %>
  </section>

  <section class="card product-list-card" data-controller="product-tree">
    <table class="prod-tbl">
      <thead>
        <tr>
          <th style="width: 36px"></th>
          <th style="width: 180px">SKU</th>
          <th style="min-width: 180px"><%= t("erp.skus.fields.master_sku") %></th>
          <th style="min-width: 260px"><%= t("erp.skus.fields.product_name") %></th>
          <th style="min-width: 210px"><%= t("erp.sku_marketing_states.fields.marketing_state") %></th>
          <th style="min-width: 150px"><%= t("erp.skus.fields.developers") %></th>
          <th style="min-width: 170px"><%= t("erp.skus.fields.operators") %></th>
          <th style="width: 120px; text-align: right"><%= t("erp.skus.fields.purchased") %></th>
          <th style="width: 120px; text-align: right"><%= t("erp.skus.fields.received") %></th>
          <th style="width: 110px"><%= t("erp.common.batches") %></th>
          <th style="width: 170px; text-align: right"><%= t("erp.common.actions.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @skus.each do |sku| %>
          <% batches = sku.batches.sort_by { |batch| [batch.received_on || Date.new(1900, 1, 1), batch.id || 0] }.reverse.first(10) %>
          <% purchased_quantity = sku.batches.sum(&:purchased_quantity) %>
          <% received_quantity = sku.batches.sum(&:received_quantity) %>
          <tr class="sku-row master">
            <td>
              <% if batches.any? %>
                <button class="chev product-tree-toggle" type="button" data-action="product-tree#toggleMaster" data-label="<%= t("erp.skus.index.sku_batches_label", sku: sku.sku_code) %>" data-tree-key="sku-list-<%= sku.id %>" aria-label="<%= t("erp.common.actions.expand_named", name: t("erp.skus.index.sku_batches_label", sku: sku.sku_code)) %>" aria-expanded="false">
                  <i class="bi bi-chevron-right" aria-hidden="true"></i>
                </button>
              <% end %>
            </td>
            <td><%= link_to sku.sku_code, erp_sku_path(sku), class: "code-text sub" %></td>
            <td><span class="code-text"><%= erp_value(sku.master_sku&.master_sku_code) %></span></td>
            <td>
              <div class="product-name-stack">
                <span class="zh-name"><%= erp_value(sku.product_name) %></span>
                <span class="ru-name"><%= erp_value(sku.product_name_ru) %></span>
              </div>
            </td>
            <td><%= render "erp/sku_marketing_states/marketing_state", sku: sku, locale_params: current_locale_params, return_to: current_page_return_to %></td>
            <td>
              <% developer_names = sku_developer_names(sku) || t("erp.skus.empty.no_developers") %>
              <% if can?(:manage_skus) %>
                <%= link_to edit_erp_sku_developer_path(sku, current_locale_params.merge(return_to: current_page_return_to)), class: "responsible-user-list responsible-user-list--editable sku-developers", title: t("erp.skus.actions.edit_developer"), data: { turbo_frame: "erp_modal" } do %>
                  <span><%= developer_names %></span>
                  <i class="bi bi-pencil-square" aria-hidden="true"></i>
                <% end %>
              <% else %>
                <span class="responsible-user-list sku-developers"><%= developer_names %></span>
              <% end %>
            </td>
            <td>
              <% operator_names = sku_operator_names(sku) || t("erp.skus.empty.no_operators") %>
              <% if can?(:manage_skus) %>
                <%= link_to edit_erp_sku_operator_path(sku, current_locale_params.merge(return_to: current_page_return_to)), class: "responsible-user-list responsible-user-list--editable sku-operators", title: t("erp.skus.actions.edit_operator"), data: { turbo_frame: "erp_modal" } do %>
                  <span><%= operator_names %></span>
                  <i class="bi bi-pencil-square" aria-hidden="true"></i>
                <% end %>
              <% else %>
                <span class="responsible-user-list sku-operators"><%= operator_names %></span>
              <% end %>
            </td>
            <td style="text-align: right"><span class="stock-num"><%= purchased_quantity %></span></td>
            <td style="text-align: right"><span class="stock-num"><%= received_quantity %></span></td>
            <td><span class="badge badge-sec"><%= sku.batches.size %> <%= t("erp.skus.units.batch_short", count: sku.batches.size) %></span></td>
            <td>
              <div class="row-actions">
                <%= link_to t("erp.common.actions.view"), erp_sku_path(sku, current_locale_params), class: "btn btn-ghost btn-sm" %>
                <%= link_to erp_edit_sku_path(sku, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.common.actions.edit"), data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-pencil" aria-hidden="true"></i>
                  <span class="sr-only"><%= t("erp.common.actions.edit") %></span>
                <% end if can?(:manage_skus) %>
                <%= link_to erp_sku_path(sku, current_locale_params), class: "ico-btn", title: t("erp.skus.actions.delete_sku"), data: { turbo_method: :delete, turbo_confirm: t("erp.skus.actions.confirm_delete_sku") } do %>
                  <i class="bi bi-trash" aria-hidden="true"></i>
                  <span class="sr-only"><%= t("erp.skus.actions.delete_sku") %></span>
                <% end if can?(:manage_skus) %>
                <%= link_to erp_new_sku_batch_path(current_locale_params.merge(sku_code: sku.sku_code, return_to: current_page_return_to)), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-plus-lg" aria-hidden="true"></i>
                  <%= t("erp.sku_batches.actions.add_batch") %>
                <% end %>
              </div>
            </td>
          </tr>
          <% if batches.any? %>
            <tr class="batch-row" hidden>
              <td colspan="11">
                <div class="batch-shell">
                  <div class="batch-h">
                    <div>
                      <span class="batch-title"><%= t("erp.skus.index.batch_list") %></span>
                      <span><%= sku.batches.size %> <%= t("erp.skus.units.batch", count: sku.batches.size) %></span>
                    </div>
                    <span><%= t("erp.skus.index.showing_recent_batches", shown: batches.size, total: sku.batches.size) %></span>
                  </div>
                  <table class="batch-tbl">
                    <thead>
                      <tr>
                        <th><%= t("erp.sku_batches.fields.batch_code") %></th>
                        <th style="width: 112px"><%= t("erp.sku_batches.fields.purchase_date") %></th>
                        <th style="width: 112px"><%= t("erp.sku_batches.fields.departure_date") %></th>
                        <th style="width: 126px"><%= t("erp.sku_batches.fields.overseas_delivery_date") %></th>
                        <th style="width: 100px; text-align: right"><%= t("erp.sku_batches.fields.purchased_quantity") %></th>
                        <th style="width: 100px; text-align: right"><%= t("erp.sku_batches.fields.received_quantity") %></th>
                        <th style="width: 110px"><%= t("erp.common.status") %></th>
                        <th style="width: 80px; text-align: right"><%= t("erp.common.actions.actions") %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% batches.each do |batch| %>
                        <tr>
                          <td><%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :batch_code) %></td>
                          <td><%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :purchase_date) %></td>
                          <td><%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :expected_arrival_on) %></td>
                          <td><%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :received_on) %></td>
                          <td><%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :purchased_quantity) %></td>
                          <td><%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :received_quantity) %></td>
                          <td><%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :status) %></td>
                          <td>
                            <div class="row-actions">
                              <%= link_to erp_edit_sku_batch_path(batch, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.common.actions.edit"), data: { turbo_frame: "erp_modal" } do %>
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                <span class="sr-only"><%= t("erp.common.actions.edit") %></span>
                              <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                              <%= link_to erp_sku_batch_path(batch, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.sku_batches.actions.delete_batch"), data: { turbo_method: :delete, turbo_confirm: t("erp.sku_batches.actions.confirm_delete_batch") } do %>
                                <i class="bi bi-trash" aria-hidden="true"></i>
                                <span class="sr-only"><%= t("erp.sku_batches.actions.delete_batch") %></span>
                              <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>

        <% if @skus.empty? %>
          <tr>
            <td colspan="11" class="empty-state">
              <i class="bi bi-inbox" aria-hidden="true"></i>
              <%= t("erp.skus.empty.no_skus") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @skus.respond_to?(:total_pages) && @skus.total_pages > 1 %>
      <%= render "pagination", skus: @skus %>
    <% end %>
  </section>
</div>
