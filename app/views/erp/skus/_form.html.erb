<%= form_with model: sku, url: sku.persisted? ? erp_sku_path(sku) : erp_skus_path, data: (local_assigns[:modal] ? { turbo_frame: "_top" } : {}) do |form| %>
  <% if sku.errors.any? %>
    <div class="panel error-box">
      <%= sku.errors.full_messages.join("；") %>
    </div>
  <% end %>

  <div class="report-form">
    <div class="field">
      <%= form.label :master_sku_id, "Master SKU" %>
      <%= form.collection_select :master_sku_id, master_sku_options, :id, :master_sku_code, { include_blank: "无" } %>
    </div>
    <div class="field">
      <%= form.label :sku_code, "SKU 编码" %>
      <%= form.text_field :sku_code %>
    </div>
    <div class="field">
      <%= form.label :product_name, "中文名" %>
      <%= form.text_field :product_name %>
    </div>
    <div class="field">
      <%= form.label :product_name_ru, "俄文名" %>
      <%= form.text_field :product_name_ru %>
    </div>
    <div class="field">
      <%= form.label :sku_category_id, "类别" %>
      <%= form.collection_select :sku_category_id, category_options, :id, :name, { include_blank: "无" } %>
    </div>
    <div class="field">
      <%= form.label :color, "颜色" %>
      <%= form.text_field :color %>
    </div>
    <div class="field">
      <%= form.label :spec, "规格" %>
      <%= form.text_field :spec %>
    </div>
    <div class="field">
      <%= form.label :size, "尺寸" %>
      <%= form.text_field :size %>
    </div>
    <div class="field">
      <%= form.label :weight_kg, "重量 kg" %>
      <%= form.number_field :weight_kg, step: "0.0001" %>
    </div>
    <div class="field">
      <%= form.label :volume_l, "体积 L" %>
      <%= form.number_field :volume_l, step: "0.0001" %>
    </div>
    <div class="field">
      <%= form.label :model, "型号" %>
      <%= form.text_field :model %>
    </div>
    <div class="field">
      <%= form.label :quality_grade, "品质" %>
      <%= form.text_field :quality_grade %>
    </div>
    <div class="field">
      <%= form.label :features, "特点" %>
      <%= form.text_field :features %>
    </div>
    <div class="field">
      <%= form.label :owner_name, "负责人" %>
      <%= form.text_field :owner_name %>
    </div>
    <div class="field">
      <%= form.label :is_active, "上架" %>
      <%= form.check_box :is_active %>
    </div>
    <div class="field">
      <%= form.label :memo, "备注" %>
      <%= form.text_field :memo %>
    </div>
    <%= form.submit "保存", class: "button" %>
  </div>
<% end %>
