<%= form_with model: sku, url: sku.persisted? ? erp_sku_path(sku) : erp_skus_path, data: (local_assigns[:modal] ? { turbo_frame: "_top" } : {}) do |form| %>
  <% if sku.errors.any? %>
    <div class="panel error-box">
      <%= sku.errors.full_messages.join("；") %>
    </div>
  <% end %>

  <div class="report-form">
    <div class="field">
      <%= form.label :master_sku_id, "Master SKU" %>
      <%= form.collection_select :master_sku_id, master_sku_options, :id, :master_sku_code, { include_blank: t("erp.common.none") } %>
    </div>
    <div class="field">
      <%= form.label :sku_code, t("erp.skus.fields.sku_code") %>
      <%= form.text_field :sku_code %>
    </div>
    <div class="field">
      <%= form.label :product_name, t("erp.common.chinese_name") %>
      <%= form.text_field :product_name %>
    </div>
    <div class="field">
      <%= form.label :product_name_ru, t("erp.common.russian_name") %>
      <%= form.text_field :product_name_ru %>
    </div>
    <div class="field">
      <%= form.label :sku_category_id, t("erp.common.category") %>
      <%= form.collection_select :sku_category_id, category_options, :id, :name, { include_blank: t("erp.common.none") } %>
    </div>
    <div class="field">
      <%= form.label :color, t("erp.skus.fields.color") %>
      <%= form.text_field :color %>
    </div>
    <div class="field">
      <%= form.label :spec, t("erp.skus.fields.spec") %>
      <%= form.text_field :spec %>
    </div>
    <div class="field">
      <%= form.label :size, t("erp.skus.fields.size") %>
      <%= form.text_field :size %>
    </div>
    <div class="field">
      <%= form.label :weight_kg, t("erp.skus.fields.weight_kg") %>
      <%= form.number_field :weight_kg, step: "0.0001" %>
    </div>
    <div class="field">
      <%= form.label :volume_l, t("erp.skus.fields.volume_l") %>
      <%= form.number_field :volume_l, step: "0.0001" %>
    </div>
    <div class="field">
      <%= form.label :model, t("erp.skus.fields.model") %>
      <%= form.text_field :model %>
    </div>
    <div class="field">
      <%= form.label :quality_grade, t("erp.skus.fields.quality_grade") %>
      <%= form.text_field :quality_grade %>
    </div>
    <div class="field">
      <%= form.label :features, t("erp.skus.fields.features") %>
      <%= form.text_field :features %>
    </div>
    <div class="field">
      <%= form.label :owner_name, t("erp.common.owner") %>
      <%= form.text_field :owner_name %>
    </div>
    <div class="field">
      <%= form.label :is_active, t("erp.skus.fields.listed") %>
      <%= form.check_box :is_active %>
    </div>
    <div class="field">
      <%= form.label :memo, t("erp.common.memo") %>
      <%= form.text_field :memo %>
    </div>
    <%= form.submit t("common.actions.save"), class: "button" %>
  </div>
<% end %>
