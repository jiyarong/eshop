<%= form_with model: sku, url: sku.persisted? ? erp_sku_path(sku) : erp_skus_path, data: (local_assigns[:modal] ? { turbo_frame: "_top" } : {}) do |form| %>
  <% if sku.errors.any? %>
    <div class="panel error-box">
      <%= sku.errors.full_messages.join("；") %>
    </div>
  <% end %>

  <% if params[:return_to].present? %>
    <%= hidden_field_tag :return_to, params[:return_to] %>
  <% end %>

  <div class="report-form">
    <div class="field">
      <%= form.label :master_sku_id, t("erp.skus.fields.master_sku") %>
      <%= form.collection_select :master_sku_id, master_sku_options, :id, :master_sku_code, { include_blank: t("erp.common.none") } %>
    </div>
    <div class="field">
      <%= form.label :sku_code, t("erp.skus.fields.sku_code") %>
      <%= form.text_field :sku_code %>
    </div>
    <div class="field">
      <%= form.label :product_name, t("erp.common.chinese_name") %>
      <%= form.text_field :product_name %>
    </div>
    <div class="field">
      <%= form.label :product_name_ru, t("erp.common.russian_name") %>
      <%= form.text_field :product_name_ru %>
    </div>
    <div class="field">
      <%= form.label :is_active, t("erp.skus.fields.listed") %>
      <%= form.check_box :is_active %>
    </div>
    <div class="field">
      <%= form.label :memo, t("erp.common.memo") %>
      <%= form.text_field :memo %>
    </div>
    <%= form.submit t("common.actions.save"), class: "button" %>
  </div>
<% end %>
