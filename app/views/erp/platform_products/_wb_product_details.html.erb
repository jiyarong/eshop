<section class="panel">
  <h2 class="section-title"><%= t("erp.sku_products.show.wb_attributes") %></h2>
  <dl class="definition-list">
    <dt><%= t("erp.sku_products.wb_fields.brand") %></dt>
    <dd><%= erp_value(@raw_product.brand) %></dd>
    <dt><%= t("erp.sku_products.wb_fields.wb_category") %></dt>
    <dd><%= erp_value(@raw_product.wb_category) %></dd>
    <dt><%= t("erp.sku_products.wb_fields.subject") %></dt>
    <dd><%= erp_value(@raw_product.subject_name || @raw_product.subject&.name) %></dd>
    <dt><%= t("erp.sku_products.wb_fields.subject_id") %></dt>
    <dd><%= erp_value(@raw_product.subject&.wb_id) %></dd>
    <dt><%= t("erp.sku_products.fields.synced_at") %></dt>
    <dd><%= display_time(@raw_product.synced_at) %></dd>
  </dl>
</section>

<section class="panel">
  <h2 class="section-title"><%= t("erp.sku_products.sections.product_attributes") %></h2>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th><%= t("erp.sku_products.fields.attribute_id") %></th>
          <th><%= t("erp.sku_products.fields.attribute_name") %></th>
          <th><%= t("erp.sku_products.fields.attribute_value") %></th>
        </tr>
      </thead>
      <tbody>
        <% characteristics = @raw_product.product_characteristics.sort_by { |characteristic| [characteristic.charc_id || 0, characteristic.charc_name.to_s] } %>
        <% if characteristics.any? %>
          <% characteristics.each do |characteristic| %>
            <tr>
              <td><%= erp_value(characteristic.charc_id) %></td>
              <td><%= erp_value(characteristic.charc_name) %></td>
              <td><%= sku_product_attribute_value(characteristic.value) %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="3" class="empty-state"><%= t("erp.sku_products.empty.no_attributes") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
