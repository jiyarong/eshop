<% content_for :page_heading, t("erp.sku_dimensions.index.title") %>

<div class="product-management sku-management">
  <div class="page-h">
    <div>
      <h1><%= t("erp.sku_dimensions.index.title") %></h1>
      <p class="sub"><%= t("erp.sku_dimensions.index.subtitle") %></p>
    </div>
  </div>

  <section class="card product-filter-card">
    <%= form_with url: erp_sku_dimensions_path, method: :get, local: true, class: "product-filter-form" do |form| %>
      <% current_locale_params.each do |key, value| %>
        <%= hidden_field_tag key, value %>
      <% end %>
      <div class="product-search-control">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= form.search_field :sku, value: @sku_query, placeholder: t("erp.sku_dimensions.filters.sku_placeholder"), class: "input" %>
      </div>
      <%= render "shared/master_sku_category_filter",
        field_class: "product-filter-field" %>
      <%= render "shared/spu_sku_filter",
        field_class: "product-filter-field",
        dom_id_prefix: "sku-dimension-spu-sku-filter" %>
      <%= render "shared/responsible_user_filters",
        field_class: "product-filter-field",
        dom_id_prefix: "sku-dimension-responsible-user-filter" %>
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= t("erp.common.actions.filter") %>
      </button>
      <%= link_to erp_sku_dimensions_path(current_locale_params), class: "btn btn-outline" do %>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
        <%= t("erp.common.actions.reset") %>
      <% end %>
      <div class="spacer"></div>
      <span class="text-sm text-muted"><%= @skus.respond_to?(:total_count) ? @skus.total_count : @skus.size %> SKU</span>
    <% end %>
  </section>

  <section class="card product-list-card">
    <table class="prod-tbl">
      <thead>
        <tr>
          <th style="width: 180px">SKU</th>
          <th style="min-width: 180px"><%= t("erp.common.chinese_name") %></th>
          <th style="width: 100px; text-align: right"><%= t("erp.sku_dimensions.fields.inner_length_cm") %></th>
          <th style="width: 100px; text-align: right"><%= t("erp.sku_dimensions.fields.inner_width_cm") %></th>
          <th style="width: 100px; text-align: right"><%= t("erp.sku_dimensions.fields.inner_height_cm") %></th>
          <th style="width: 110px; text-align: right"><%= t("erp.sku_dimensions.fields.inner_volume_l") %></th>
          <th style="width: 120px; text-align: right"><%= t("erp.sku_dimensions.fields.inner_box_weight_kg") %></th>
          <th style="width: 100px; text-align: right"><%= t("erp.sku_dimensions.fields.outer_length_cm") %></th>
          <th style="width: 100px; text-align: right"><%= t("erp.sku_dimensions.fields.outer_width_cm") %></th>
          <th style="width: 100px; text-align: right"><%= t("erp.sku_dimensions.fields.outer_height_cm") %></th>
          <th style="width: 110px; text-align: right"><%= t("erp.sku_dimensions.fields.outer_volume_l") %></th>
          <th style="width: 120px; text-align: right"><%= t("erp.sku_dimensions.fields.outer_box_weight_kg") %></th>
          <th style="width: 100px; text-align: right"><%= t("erp.sku_dimensions.fields.outer_box_pcs") %></th>
        </tr>
      </thead>
      <tbody>
        <% if @skus.any? %>
          <% @skus.each do |sku| %>
            <% dimension = sku.dimension || Ec::SkuDimension.new(sku_code: sku.sku_code) %>
            <tr class="sku-row master">
              <td><span class="code-text sub"><%= sku.sku_code %></span></td>
              <td><span class="zh-name"><%= erp_value(sku.product_name) %></span></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :inner_length_cm) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :inner_width_cm) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :inner_height_cm) %></td>
              <td class="num"><%= erp_value(dimension.inner_volume_l) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :inner_box_weight_kg) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :outer_length_cm) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :outer_width_cm) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :outer_height_cm) %></td>
              <td class="num"><%= erp_value(dimension.outer_volume_l) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :outer_box_weight_kg) %></td>
              <td><%= render "shared/inline_edit_cell", **sku_dimension_inline_cell_locals(dimension, :outer_box_pcs) %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="13" class="empty-state">
              <i class="bi bi-inbox" aria-hidden="true"></i>
              <%= t("erp.sku_dimensions.empty.no_skus") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @skus.respond_to?(:total_pages) && @skus.total_pages > 1 %>
      <%= render "pagination", skus: @skus %>
    <% end %>
  </section>
</div>
