<% content_for :page_heading, t("erp.sku_products.show.title") %>

<div class="resource-header">
  <div>
    <p class="resource-eyebrow"><%= t("erp.sku_products.show.eyebrow") %></p>
    <h1 class="page-title"><%= erp_value(@sku_product.product_name) %></h1>
  </div>
  <div class="resource-actions">
    <%= link_to t("erp.sku_products.actions.back_to_bindings"), erp_sku_sku_products_path(@sku), class: "button button-secondary" %>
    <% edit_url = product_edit_url(@sku_product.platform, @sku_product.platform_sku_id.presence || @sku_product.product_id) %>
    <% if edit_url %>
      <%= link_to t("erp.sku_products.actions.open_platform_product"), edit_url, target: "_blank", rel: "noreferrer noopener", class: "button" %>
    <% end %>
  </div>
</div>

<div class="report-stack">
  <section class="panel">
    <h2 class="section-title"><%= t("erp.sku_products.sections.binding_summary") %></h2>
    <dl class="definition-list">
      <dt><%= t("erp.skus.fields.sku_code") %></dt>
      <dd><%= @sku.sku_code %></dd>
      <dt><%= t("erp.common.platform") %></dt>
      <dd><%= t("common.platforms.#{@sku_product.platform}", default: @sku_product.platform) %></dd>
      <dt><%= t("erp.sku_products.fields.store") %></dt>
      <dd><%= @sku_product.store.store_name %></dd>
      <dt><%= t("erp.sku_products.fields.product_id") %></dt>
      <dd><%= @sku_product.product_id %></dd>
      <dt><%= t("erp.sku_products.fields.offer_id") %></dt>
      <dd><%= erp_value(@sku_product.offer_id) %></dd>
      <dt><%= t("erp.sku_products.fields.platform_sku_id") %></dt>
      <dd><%= erp_value(@sku_product.platform_sku_id) %></dd>
      <dt><%= t("erp.sku_products.fields.product_name") %></dt>
      <dd><%= erp_value(@sku_product.product_name) %></dd>
    </dl>
  </section>

  <% if @raw_product %>
    <%= render "erp/sku_products/#{@sku_product.platform}_product_details" %>
  <% else %>
    <section class="panel">
      <p class="empty-state"><%= t("erp.sku_products.empty.no_raw_product_details") %></p>
    </section>
  <% end %>
</div>
