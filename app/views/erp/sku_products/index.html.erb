<% content_for :page_heading, t("erp.sku_products.index.title") %>

<div class="resource-header">
  <div>
    <p class="resource-eyebrow"><%= t("erp.sku_products.index.eyebrow") %></p>
    <h1 class="page-title"><%= t("erp.sku_products.index.title") %></h1>
  </div>
  <div class="resource-actions">
    <%= link_to t("erp.sku_products.actions.back_to_sku"), report_sku_path(@sku.sku_code), class: "button button-secondary" %>
  </div>
</div>

<div class="report-stack">
  <section class="panel">
    <h2 class="section-title"><%= t("erp.sku_products.sections.erp_sku") %></h2>
    <dl class="definition-list">
      <dt><%= t("erp.skus.fields.sku_code") %></dt>
      <dd><%= @sku.sku_code %></dd>
      <dt><%= t("erp.common.chinese_name") %></dt>
      <dd><%= erp_value(@sku.product_name) %></dd>
      <dt><%= t("erp.common.russian_name") %></dt>
      <dd><%= erp_value(@sku.product_name_ru) %></dd>
    </dl>
  </section>

  <%= render "shared/sku_product_bindings",
             sku: @sku,
             sku_products: @sku_products,
             title_i18n_key: "erp.sku_products.sections.current_bindings",
             empty_i18n_key: "erp.sku_products.empty.no_bindings",
             show_sku_code: true,
             show_actions: true %>

  <section class="panel">
    <h2 class="section-title"><%= t("erp.sku_products.sections.add_binding") %></h2>

    <%= form_with url: erp_sku_sku_products_path(@sku), method: :get, local: true, html: { class: "report-form" } do |form| %>
      <div class="field">
        <%= form.label :raw_product_query, t("erp.sku_products.filters.raw_product_query") %>
        <%= form.search_field :raw_product_query, value: @raw_product_query, placeholder: t("erp.sku_products.filters.raw_product_query_placeholder") %>
      </div>

      <div class="field">
        <%= form.label :raw_product_platform, t("erp.sku_products.filters.platform") %>
        <%= form.select :raw_product_platform,
                        [["#{t("erp.sku_products.filters.all_platforms")}", ""], [t("common.platforms.ozon"), "ozon"], [t("common.platforms.wb"), "wb"]],
                        { selected: @raw_product_platform } %>
      </div>

      <div class="field">
        <label>
          <%= check_box_tag :available_only, "1", @available_only %>
          <%= t("erp.sku_products.filters.available_only") %>
        </label>
      </div>

      <button class="button button-secondary" type="submit"><%= t("erp.sku_products.actions.search") %></button>
      <%= link_to t("erp.common.actions.reset"), erp_sku_sku_products_path(@sku), class: "button button-secondary" %>
    <% end %>

    <% if @sku_product.errors.any? %>
      <div class="panel error-box">
        <ul>
          <% @sku_product.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: erp_sku_sku_products_path(@sku), method: :post, local: true do %>
      <div class="table-scroll">
        <table class="raw-product-options">
          <thead>
            <tr>
              <th><%= t("erp.sku_products.fields.select") %></th>
              <th><%= t("erp.common.platform") %></th>
              <th><%= t("erp.sku_products.fields.store") %></th>
              <th><%= t("erp.sku_products.fields.product_id") %></th>
              <th><%= t("erp.sku_products.fields.offer_id") %></th>
              <th><%= t("erp.sku_products.fields.product_name") %></th>
              <th><%= t("erp.sku_products.fields.product_attributes_link") %></th>
              <th><%= t("erp.sku_products.fields.store_link") %></th>
              <th><%= t("erp.common.status") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @raw_product_options.any? %>
              <% @raw_product_options.each do |product| %>
                <tr>
                  <td>
                    <% if product[:bound] %>
                      -
                    <% else %>
                      <%= check_box_tag "raw_product_keys[]", product[:key], false, id: "raw_product_#{product[:key].parameterize}" %>
                    <% end %>
                  </td>
                  <td><%= t("common.platforms.#{product[:platform]}", default: product[:platform]) %></td>
                  <td><%= product[:store_name] %></td>
                  <td><%= product[:product_id] %></td>
                  <td><%= erp_value(product[:offer_id]) %></td>
                  <td><span data-controller="long-text" data-long-text-limit-value="50"><%= erp_value(product[:product_name]) %></span></td>
                  <td><%= link_to t("erp.sku_products.actions.view_attributes"), erp_platform_product_path(product[:platform], product[:store_id], product[:product_id]) %></td>
                  <td>
                    <% edit_url = product_edit_url(product[:platform], product[:platform_sku_id].presence || product[:product_id]) %>
                    <% if edit_url %>
                      <%= link_to t("erp.sku_products.actions.open_platform_product"), edit_url, target: "_blank", rel: "noreferrer noopener" %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td><%= product[:bound] ? t("erp.sku_products.status.bound") : t("erp.sku_products.status.available") %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="10" class="empty-state"><%= t("erp.sku_products.empty.no_raw_products") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <button class="button" type="submit"><%= t("erp.sku_products.actions.add_binding") %></button>
    <% end %>
  </section>
</div>
