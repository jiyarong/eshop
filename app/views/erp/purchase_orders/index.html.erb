<h1 class="page-title">采购单</h1>

<section class="panel">
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>采购单号</th>
          <th>供应商</th>
          <th>状态</th>
          <th>采购日期</th>
          <th>币种</th>
          <th>采购金额</th>
          <th>已付款</th>
        </tr>
      </thead>
      <tbody>
        <% @purchase_orders.each do |order| %>
          <tr>
            <td><%= link_to order.order_no, erp_purchase_order_path(order) %></td>
            <td><%= order.supplier&.name %></td>
            <td><%= order.status %></td>
            <td><%= order.ordered_on %></td>
            <td><%= order.currency %></td>
            <td><%= erp_value(order.goods_amount_cny) %></td>
            <td><%= erp_value(order.paid_amount_cny) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
