<% content_for :page_heading, t("erp.spus.index.title") %>

<% total_visible_skus = @master_sku_entries.sum { |entry| entry[:skus].size } + @orphan_skus.size %>

<div class="product-management">
  <%= turbo_frame_tag "erp_modal" %>

  <div class="page-h">
    <div>
      <h1><%= t("erp.spus.index.title") %></h1>
      <p class="sub"><%= t("erp.spus.index.hierarchy") %></p>
    </div>
    <div class="hstack product-page-actions">
      <%#= link_to erp_sku_categories_path, class: "btn btn-outline" do %>
<!--        <i class="bi bi-diagram-3" aria-hidden="true"></i>-->
      <%# end %>
      <%= link_to erp_new_master_sku_path(current_locale_params), class: "btn btn-primary", data: { turbo_frame: "erp_modal" } do %>
        <i class="bi bi-plus-lg" aria-hidden="true"></i>
        <%= t("erp.skus.actions.add_product") %>
      <% end %>
    </div>
  </div>

  <section class="product-summary-grid" aria-label="<%= t("erp.spus.index.product_overview") %>">
    <div class="product-summary-card">
      <span class="summary-label"><%= t("erp.skus.fields.master_sku") %></span>
      <strong class="summary-value"><%= @product_counts[:master_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label">SKU</span>
      <strong class="summary-value"><%= @product_counts[:sku_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label"><%= t("erp.common.batches") %></span>
      <strong class="summary-value"><%= @product_counts[:batch_total] %></strong>
    </div>
    <div class="product-summary-card">
      <span class="summary-label"><%= t("erp.spus.index.active_products") %></span>
      <strong class="summary-value"><%= @product_counts[:active_master_total] %></strong>
    </div>
  </section>

  <section class="card product-filter-card">
    <%= form_with url: erp_spus_path, method: :get, local: true, class: "product-filter-form" do |form| %>
      <div class="product-search-control">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= form.search_field :q, value: @q, placeholder: t("erp.skus.filters.search_placeholder"), class: "input" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :status, t("erp.common.status"), class: "label" %>
        <%= form.select :status, [[t("erp.common.filter_options.all"), "all"], [t("erp.common.statuses.enabled"), "active"], [t("erp.common.statuses.disabled"), "inactive"]], { selected: @status }, class: "select" %>
      </div>
      <div class="field product-filter-field">
        <%= form.label :category_ids, t("erp.common.category"), class: "label" %>
        <% selected_category_labels = @category_options.select { |_label, id| @category_ids.include?(id) }.map(&:first) %>
        <% category_summary = if selected_category_labels.empty?
          t("erp.skus.filters.all_categories")
        elsif selected_category_labels.one?
          selected_category_labels.first
        else
          t("erp.skus.filters.selected_categories", count: selected_category_labels.size)
        end %>
        <div class="category-multiselect"
             data-controller="category-multiselect"
             data-all-label="<%= t("erp.skus.filters.all_categories") %>"
             data-selected-count-label="<%= t("erp.skus.filters.selected_categories", count: "%{count}") %>">
          <button class="category-multiselect__trigger"
                  type="button"
                  data-category-multiselect-target="trigger"
                  data-action="category-multiselect#toggle"
                  aria-expanded="false">
            <span data-category-multiselect-target="summary"><%= category_summary %></span>
            <i class="bi bi-chevron-down" aria-hidden="true"></i>
          </button>
          <div class="category-multiselect__panel" data-category-multiselect-target="panel" data-action="keydown->category-multiselect#closeOnEscape" hidden>
            <label class="category-multiselect__search">
              <span class="sr-only"><%= t("erp.skus.filters.category_search_placeholder") %></span>
              <input type="search"
                     placeholder="<%= t("erp.skus.filters.category_search_placeholder") %>"
                     data-category-multiselect-target="search"
                     data-action="input->category-multiselect#filter keydown.enter->category-multiselect#preventSubmit">
              <i class="bi bi-search" aria-hidden="true"></i>
            </label>
            <div class="category-multiselect__list" role="listbox" aria-multiselectable="true">
              <% @category_options.each do |label, id| %>
                <% selected = @category_ids.include?(id) %>
                <label class="category-multiselect__option <%= "is-selected" if selected %>"
                       role="option"
                       aria-selected="<%= selected ? "true" : "false" %>"
                       data-category-multiselect-target="option"
                       data-category-multiselect-label="<%= label.downcase %>">
                  <%= check_box_tag "category_ids[]", id, selected, data: { action: "category-multiselect#sync" } %>
                  <span class="category-multiselect__check" aria-hidden="true">
                    <i class="bi bi-check-lg"></i>
                  </span>
                  <span class="category-multiselect__label"><%= label %></span>
                </label>
              <% end %>
              <div class="category-multiselect__empty" data-category-multiselect-target="empty" hidden><%= t("erp.skus.filters.no_categories") %></div>
            </div>
          </div>
        </div>
      </div>
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-search" aria-hidden="true"></i>
        <%= t("erp.common.actions.filter") %>
      </button>
      <%= link_to erp_spus_path, class: "btn btn-outline" do %>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
        <%= t("erp.common.actions.reset") %>
      <% end %>
      <div class="spacer"></div>
      <span class="text-sm text-muted"><%= @master_sku_entries.size %> · <%= total_visible_skus %> SKU</span>
    <% end %>
  </section>

  <section class="card product-list-card" data-controller="product-tree">
    <table class="prod-tbl">
      <thead>
        <tr>
          <th style="width: 36px"></th>
          <th style="width: 160px"><%= t("erp.skus.fields.master_sku") %></th>
          <th style="min-width: 220px"><%= t("erp.common.chinese_name") %></th>
          <th style="min-width: 260px"><%= t("erp.common.russian_name") %></th>
          <th style="min-width: 180px"><%= t("erp.skus.fields.platform_category") %></th>
          <th style="width: 120px">SKU</th>
          <th style="min-width: 210px"><%= t("erp.sku_marketing_states.fields.marketing_state") %></th>
          <th style="width: 120px"><%= t("erp.common.batches") %></th>
          <th style="width: 120px"><%= t("erp.common.status") %></th>
          <th style="width: 150px; text-align: right"><%= t("erp.common.actions.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @master_sku_entries.each do |entry| %>
          <% master_sku = entry[:master_sku] %>
          <% skus = entry[:skus] %>
          <% batch_total = skus.sum { |sku| sku.batches.size } %>
          <% category_parts = [master_sku.primary_ec_category&.localized_name, master_sku.secondary_ec_category&.localized_name].compact %>
          <tr class="master">
            <td>
              <button class="chev product-tree-toggle" type="button" data-action="product-tree#toggleMaster" data-label="<%= master_sku.master_sku_code %>" data-tree-key="master-<%= master_sku.id %>" aria-label="<%= t("erp.common.actions.expand_named", name: master_sku.master_sku_code) %>" aria-expanded="false">
                <i class="bi bi-chevron-right" aria-hidden="true"></i>
              </button>
            </td>
            <td><span class="code-text"><%= master_sku.master_sku_code %></span></td>
            <td><span class="zh-name"><%= erp_value(master_sku.product_name) %></span></td>
            <td><span class="ru-name"><%= erp_value(master_sku.product_name_ru) %></span></td>
            <td><span class="platform-category"><%= category_parts.any? ? category_parts.join(" / ") : "-" %></span></td>
            <td><span class="num"><%= skus.size %></span> <%= t("erp.skus.units.sku", count: skus.size) %></td>
            <td>-</td>
            <td><span class="num"><%= batch_total %></span> <%= t("erp.skus.units.batch", count: batch_total) %></td>
            <td>
              <% if master_sku.is_active %>
                <span class="badge badge-suc">Active</span>
              <% else %>
                <span class="badge badge-sec"><%= t("erp.common.statuses.disabled") %></span>
              <% end %>
            </td>
            <td>
              <div class="row-actions">
                <%= link_to erp_edit_master_sku_path(master_sku, current_locale_params), class: "ico-btn", title: t("erp.skus.actions.edit_product"), data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-pencil" aria-hidden="true"></i>
                  <span class="sr-only"><%= t("erp.skus.actions.edit_product") %></span>
                <% end if can?(:manage_skus) %>
                <%= link_to erp_new_sku_path(current_locale_params.merge(master_sku_id: master_sku.id, return_to: current_page_return_to)), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-plus-lg" aria-hidden="true"></i>
                  <%= t("erp.skus.actions.add_sku") %>
                <% end %>
              </div>
            </td>
          </tr>
          <tr class="sub-row" hidden>
            <td colspan="10">
              <div class="sub-shell">
                <div class="sub-h">
                  <span><%= t("erp.skus.index.sku_variants", count: skus.size) %></span>
                </div>
                <% if skus.any? %>
                  <table class="sub-tbl">
                    <thead>
                      <tr>
                        <th style="width: 180px">SKU</th>
                        <th><%= t("erp.skus.fields.attributes") %></th>
                        <th style="min-width: 210px"><%= t("erp.sku_marketing_states.fields.marketing_state") %></th>
                        <th style="width: 120px; text-align: right"><%= t("erp.skus.fields.purchased") %></th>
                        <th style="width: 120px; text-align: right"><%= t("erp.skus.fields.received") %></th>
                        <th style="width: 110px"><%= t("erp.common.batches") %></th>
                        <th style="width: 170px; text-align: right"><%= t("erp.common.actions.actions") %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% skus.each do |sku| %>
                        <% batches = sku.batches.sort_by { |batch| [batch.received_on || Date.new(1900, 1, 1), batch.id || 0] }.reverse.first(10) %>
                        <% purchased_quantity = sku.batches.sum(&:purchased_quantity) %>
                        <% received_quantity = sku.batches.sum(&:received_quantity) %>
                        <tr class="sku-row">
                          <td>
                            <button class="chev product-tree-toggle" type="button" data-action="product-tree#toggleSku" data-label="<%= t("erp.skus.index.sku_batches_label", sku: sku.sku_code) %>" data-tree-key="sku-<%= sku.id %>" aria-label="<%= t("erp.common.actions.expand_named", name: t("erp.skus.index.sku_batches_label", sku: sku.sku_code)) %>" aria-expanded="false">
                              <i class="bi bi-chevron-right" aria-hidden="true"></i>
                            </button>
                            <%= link_to sku.sku_code, erp_sku_path(sku), class: "code-text sub" %>
                          </td>
                          <td>
                            <div class="attr-zh"><%= erp_value(sku.sku_category&.name) %></div>
                            <div class="attr-ru text-xs"><%= [erp_value(sku.color), erp_value(sku.spec), erp_value(sku.model)].reject { |value| value == "-" }.join(" · ").presence || "#{erp_value(sku.product_name)} · #{erp_value(sku.product_name_ru)}" %></div>
                          </td>
                          <td><%= render "erp/sku_marketing_states/marketing_state", sku: sku, locale_params: current_locale_params, return_to: current_page_return_to %></td>
                          <td style="text-align: right"><span class="stock-num"><%= purchased_quantity %></span></td>
                          <td style="text-align: right"><span class="stock-num"><%= received_quantity %></span></td>
                          <td><span class="badge badge-sec"><%= sku.batches.size %> <%= t("erp.skus.units.batch_short", count: sku.batches.size) %></span></td>
                          <td>
                            <div class="row-actions">
                              <%= link_to t("erp.common.actions.view"), erp_sku_path(sku, current_locale_params), class: "btn btn-ghost btn-sm" %>
                              <%= link_to erp_edit_sku_path(sku, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.common.actions.edit"), data: { turbo_frame: "erp_modal" } do %>
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                <span class="sr-only"><%= t("erp.common.actions.edit") %></span>
                              <% end if can?(:manage_skus) %>
                              <%= link_to erp_sku_path(sku, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.skus.actions.delete_sku"), data: { turbo_method: :delete, turbo_confirm: t("erp.skus.actions.confirm_delete_sku") } do %>
                                <i class="bi bi-trash" aria-hidden="true"></i>
                                <span class="sr-only"><%= t("erp.skus.actions.delete_sku") %></span>
                              <% end if can?(:manage_skus) %>
                              <%= link_to erp_new_sku_batch_path(current_locale_params.merge(sku_code: sku.sku_code, return_to: current_page_return_to)), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                <%= t("erp.sku_batches.actions.add_batch") %>
                              <% end %>
                            </div>
                          </td>
                        </tr>
                        <tr class="batch-row" hidden>
                          <td colspan="7">
                            <div class="batch-shell">
                              <div class="batch-h">
                                <div>
                                  <span class="batch-title"><%= t("erp.skus.index.batch_list") %></span>
                                  <span><%= sku.batches.size %> <%= t("erp.skus.units.batch", count: sku.batches.size) %></span>
                                </div>
                                <span><%= t("erp.skus.index.showing_recent_batches", shown: batches.size, total: sku.batches.size) %></span>
                              </div>
                              <% if batches.any? %>
                                <table class="batch-tbl">
                                  <thead>
                                    <tr>
                                      <th><%= t("erp.sku_batches.fields.batch_code") %></th>
                                      <th style="width: 112px"><%= t("erp.sku_batches.fields.purchase_date") %></th>
                                      <th style="width: 112px"><%= t("erp.sku_batches.fields.departure_date") %></th>
                                      <th style="width: 126px"><%= t("erp.sku_batches.fields.overseas_delivery_date") %></th>
                                      <th style="width: 100px; text-align: right"><%= t("erp.sku_batches.fields.purchased_quantity") %></th>
                                      <th style="width: 100px; text-align: right"><%= t("erp.sku_batches.fields.received_quantity") %></th>
                                      <th style="width: 110px"><%= t("erp.common.status") %></th>
                                      <th style="width: 80px; text-align: right"><%= t("erp.common.actions.actions") %></th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    <% batches.each do |batch| %>
                                      <tr>
                                        <td>
                                          <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :batch_code) %>
                                        </td>
                                        <td>
                                          <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :purchase_date) %>
                                        </td>
                                        <td>
                                          <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :expected_arrival_on) %>
                                        </td>
                                        <td>
                                          <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :received_on) %>
                                        </td>
                                        <td>
                                          <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :purchased_quantity) %>
                                        </td>
                                        <td>
                                          <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :received_quantity) %>
                                        </td>
                                        <td>
                                          <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :status) %>
                                        </td>
                                        <td>
                                          <div class="row-actions">
                                            <%= link_to erp_edit_sku_batch_path(batch, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.common.actions.edit"), data: { turbo_frame: "erp_modal" } do %>
                                              <i class="bi bi-pencil" aria-hidden="true"></i>
                                              <span class="sr-only"><%= t("erp.common.actions.edit") %></span>
                                            <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                                            <%= link_to erp_sku_batch_path(batch, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.sku_batches.actions.delete_batch"), data: { turbo_method: :delete, turbo_confirm: t("erp.sku_batches.actions.confirm_delete_batch") } do %>
                                              <i class="bi bi-trash" aria-hidden="true"></i>
                                              <span class="sr-only"><%= t("erp.sku_batches.actions.delete_batch") %></span>
                                            <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                                          </div>
                                        </td>
                                      </tr>
                                    <% end %>
                                  </tbody>
                                </table>
                              <% else %>
                                <div class="nested-empty-state"><%= t("erp.skus.empty.no_batches") %></div>
                              <% end %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                <% else %>
                  <div class="nested-empty-state"><%= t("erp.skus.empty.no_skus") %></div>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>

        <% @orphan_skus.each do |sku| %>
          <% batches = sku.batches.sort_by { |batch| [batch.received_on || Date.new(1900, 1, 1), batch.id || 0] }.reverse.first(10) %>
          <tr class="master">
            <td>
              <% if batches.any? %>
                <button class="chev product-tree-toggle" type="button" data-action="product-tree#toggleMaster" data-label="<%= t("erp.skus.index.sku_batches_label", sku: sku.sku_code) %>" data-tree-key="orphan-sku-<%= sku.id %>" aria-label="<%= t("erp.common.actions.expand_named", name: t("erp.skus.index.sku_batches_label", sku: sku.sku_code)) %>" aria-expanded="false">
                  <i class="bi bi-chevron-right" aria-hidden="true"></i>
                </button>
              <% end %>
            </td>
            <td><span class="code-text"><%= t("erp.skus.index.unfiled") %></span></td>
            <td><span class="zh-name"><%= erp_value(sku.product_name) %></span></td>
            <td><span class="ru-name"><%= erp_value(sku.product_name_ru) %></span></td>
            <td><span class="platform-category">-</span></td>
            <td><span class="code-text sub"><%= sku.sku_code %></span></td>
            <td><%= render "erp/sku_marketing_states/marketing_state", sku: sku, locale_params: current_locale_params, return_to: current_page_return_to %></td>
            <td><span class="num"><%= sku.batches.size %></span> <%= t("erp.skus.units.batch", count: sku.batches.size) %></td>
            <td>
              <% if sku.is_active %>
                <span class="badge badge-suc">Active</span>
              <% else %>
                <span class="badge badge-sec"><%= t("erp.skus.statuses.inactive") %></span>
              <% end %>
            </td>
            <td>
              <div class="row-actions">
                <%= link_to t("erp.common.actions.view"), erp_sku_path(sku, current_locale_params), class: "btn btn-ghost btn-sm" %>
                <%= link_to erp_edit_sku_path(sku, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.common.actions.edit"), data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-pencil" aria-hidden="true"></i>
                  <span class="sr-only"><%= t("erp.common.actions.edit") %></span>
                <% end if can?(:manage_skus) %>
                <%= link_to erp_sku_path(sku, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.skus.actions.delete_sku"), data: { turbo_method: :delete, turbo_confirm: t("erp.skus.actions.confirm_delete_sku") } do %>
                  <i class="bi bi-trash" aria-hidden="true"></i>
                  <span class="sr-only"><%= t("erp.skus.actions.delete_sku") %></span>
                <% end if can?(:manage_skus) %>
                <%= link_to erp_new_sku_batch_path(current_locale_params.merge(sku_code: sku.sku_code, return_to: current_page_return_to)), class: "btn btn-ghost btn-sm", data: { turbo_frame: "erp_modal" } do %>
                  <i class="bi bi-plus-lg" aria-hidden="true"></i>
                  <%= t("erp.sku_batches.actions.add_batch") %>
                <% end %>
              </div>
            </td>
          </tr>
          <% if batches.any? %>
            <tr class="batch-row" hidden>
              <td colspan="10">
                <div class="batch-shell batch-shell--orphan">
                  <div class="batch-h">
                    <div>
                      <span class="batch-title"><%= t("erp.skus.index.batch_list") %></span>
                      <span><%= sku.batches.size %> <%= t("erp.skus.units.batch", count: sku.batches.size) %></span>
                    </div>
                  </div>
                  <table class="batch-tbl">
                    <thead>
                      <tr>
                        <th><%= t("erp.sku_batches.fields.batch_code") %></th>
                        <th><%= t("erp.sku_batches.fields.purchase_date") %></th>
                        <th><%= t("erp.sku_batches.fields.departure_date") %></th>
                        <th><%= t("erp.sku_batches.fields.overseas_delivery_date") %></th>
                        <th style="text-align: right"><%= t("erp.sku_batches.fields.purchased_quantity") %></th>
                        <th style="text-align: right"><%= t("erp.sku_batches.fields.received_quantity") %></th>
                        <th><%= t("erp.common.status") %></th>
                        <th style="text-align: right"><%= t("erp.common.actions.actions") %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% batches.each do |batch| %>
                        <tr>
                          <td>
                            <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :batch_code) %>
                          </td>
                          <td>
                            <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :purchase_date) %>
                          </td>
                          <td>
                            <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :expected_arrival_on) %>
                          </td>
                          <td>
                            <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :received_on) %>
                          </td>
                          <td>
                            <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :purchased_quantity) %>
                          </td>
                          <td>
                            <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :received_quantity) %>
                          </td>
                          <td>
                            <%= render "shared/inline_edit_cell", **sku_batch_inline_cell_locals(batch, :status) %>
                          </td>
                          <td>
                            <div class="row-actions">
                              <%= link_to erp_edit_sku_batch_path(batch, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.common.actions.edit"), data: { turbo_frame: "erp_modal" } do %>
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                <span class="sr-only"><%= t("erp.common.actions.edit") %></span>
                              <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                              <%= link_to erp_sku_batch_path(batch, current_locale_params.merge(return_to: current_page_return_to)), class: "ico-btn", title: t("erp.sku_batches.actions.delete_batch"), data: { turbo_method: :delete, turbo_confirm: t("erp.sku_batches.actions.confirm_delete_batch") } do %>
                                <i class="bi bi-trash" aria-hidden="true"></i>
                                <span class="sr-only"><%= t("erp.sku_batches.actions.delete_batch") %></span>
                              <% end if can?(:manage_purchases) || can?(:manage_inventory) %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>

        <% if @master_sku_entries.empty? && @orphan_skus.empty? %>
          <tr>
            <td colspan="10" class="empty-state">
              <i class="bi bi-inbox" aria-hidden="true"></i>
              <%= t("erp.skus.empty.no_products") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>
