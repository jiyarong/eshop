<%= form_with model: cost_allocation, url: cost_allocation.persisted? ? erp_cost_allocation_path(cost_allocation) : erp_cost_allocations_path do |form| %>
  <% if cost_allocation.errors.any? %>
    <div class="panel error-box">
      <%= cost_allocation.errors.full_messages.join("；") %>
    </div>
  <% end %>

  <div class="report-form">
    <div class="field">
      <%= form.label :allocation_no, "分摊单号" %>
      <%= form.text_field :allocation_no %>
    </div>
    <div class="field">
      <%= form.label :cost_type, "费用类型" %>
      <%= form.select :cost_type, Ec::CostAllocation::COST_TYPES %>
    </div>
    <div class="field">
      <%= form.label :allocation_method, "分摊方式" %>
      <%= form.select :allocation_method, Ec::CostAllocation::ALLOCATION_METHODS %>
    </div>
    <div class="field">
      <%= form.label :total_amount_cny, "总金额" %>
      <%= form.number_field :total_amount_cny, min: 0, step: "0.0001" %>
    </div>
    <div class="field">
      <%= form.label :allocated_on, "分摊日期" %>
      <%= form.date_field :allocated_on %>
    </div>
    <div class="field">
      <%= form.label :status, "状态" %>
      <%= form.select :status, Ec::CostAllocation::STATUSES %>
    </div>
    <div class="field">
      <%= form.label :memo, "备注" %>
      <%= form.text_field :memo %>
    </div>
  </div>

  <div class="report-stack">
    <div>
      <h2 class="section-title">分摊明细</h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>批次</th>
              <th>金额</th>
              <th>备注</th>
            </tr>
          </thead>
          <tbody>
            <%= form.fields_for :items do |item_form| %>
              <tr>
                <td>
                  <%= item_form.hidden_field :id if item_form.object.persisted? %>
                  <%= item_form.collection_select :sku_batch_id, batch_options, :id, :batch_code, { include_blank: "选择批次" } %>
                </td>
                <td><%= item_form.number_field :amount_cny, min: 0, step: "0.0001" %></td>
                <td><%= item_form.text_field :memo %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%= form.submit "保存", class: "button" %>
  </div>
<% end %>
