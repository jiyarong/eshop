<%= turbo_frame_tag "erp_modal" do %>
  <div class="erp-modal-backdrop" data-controller="modal" data-action="click->modal#closeOnBackdrop">
    <section class="erp-modal" role="dialog" aria-modal="true" aria-labelledby="master-sku-modal-title">
      <div class="erp-modal__header">
        <h2 id="master-sku-modal-title"><%= t("erp.skus.actions.add_product") %></h2>
        <button class="icon-button" type="button" aria-label="关闭" data-action="modal#close">
          <i class="bi bi-x-lg" aria-hidden="true"></i>
        </button>
      </div>
      <%= render "form", master_sku: @master_sku, modal: true %>
    </section>
  </div>
<% end %>
