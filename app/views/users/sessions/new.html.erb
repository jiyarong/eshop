<% content_for :title, t("auth.sign_in.title") %>

<div class="auth-copy">
  <p class="auth-eyebrow"><%= t("auth.sign_in.eyebrow") %></p>
  <h1 id="auth_title"><%= t("auth.sign_in.title") %></h1>
  <p><%= t("auth.sign_in.subtitle") %></p>
</div>

<%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "auth-form", data: { turbo: false } do |form| %>
  <div class="field">
    <%= form.label :email, t("auth.fields.email") %>
    <div class="auth-input">
      <i class="bi bi-envelope" aria-hidden="true"></i>
      <%= form.text_field :email,
        autofocus: true,
        autocomplete: "email",
        inputmode: "email",
        data: {
          controller: "email-input",
          action: "input->email-input#normalize change->email-input#normalize blur->email-input#normalize"
        } %>
    </div>
  </div>

  <div class="field">
    <%= form.label :password, t("auth.fields.password") %>
    <div class="auth-input">
      <i class="bi bi-lock" aria-hidden="true"></i>
      <%= form.password_field :password, autocomplete: "current-password" %>
    </div>
  </div>

  <div class="auth-form__row">
    <label class="auth-check" for="user_remember_me">
      <%= form.check_box :remember_me %>
      <span><%= t("auth.fields.remember_me") %></span>
    </label>
    <%= link_to t("auth.sign_in.forgot_password"), new_password_path(resource_name, request.query_parameters.slice(:locale)), class: "auth-link" %>
  </div>

  <%= form.submit t("auth.sign_in.submit"), class: "button auth-submit" %>
<% end %>
