<h1 class="page-title"><%= t("weekly_profit_reports.title") %></h1>

<section class="panel">
  <form class="report-form" action="/weekly_profit_reports" method="get" data-turbo-frame="weekly_profit_report_results">
    <div class="field">
      <label for="weekly-profit-platform"><%= t("weekly_profit_reports.filters.platform") %></label>
      <select id="weekly-profit-platform" name="platform" required data-weekly-profit-platform>
        <option value="wb" <%= "selected" if @platform == "wb" %>>WB</option>
        <option value="ozon" <%= "selected" if @platform == "ozon" %>>Ozon</option>
      </select>
    </div>

    <div class="field">
      <label for="weekly-profit-account"><%= t("weekly_profit_reports.filters.store") %></label>
      <select id="weekly-profit-account" name="account_id" required>
        <optgroup label="WB">
          <% @accounts[:wb].each do |account| %>
            <option value="<%= account.id %>" data-platform="wb"><%= account.name %></option>
          <% end %>
        </optgroup>
        <optgroup label="Ozon">
          <% @accounts[:ozon].each do |account| %>
            <option value="<%= account.id %>" data-platform="ozon"><%= account.company_name %></option>
          <% end %>
        </optgroup>
      </select>
    </div>

    <div class="field field--time-range">
      <label for="weekly-profit-time-range-trigger"><%= t("weekly_profit_reports.filters.date_range") %></label>
      <%= render "shared/time_range_selector",
                 id: "weekly-profit-time-range",
                 from_date: @from_date,
                 to_date: @to_date,
                 submit_on_apply: true %>
    </div>

    <button class="button" type="submit"><%= t("weekly_profit_reports.filters.submit") %></button>
  </form>
</section>

<turbo-frame id="weekly_profit_report_results">
  <section class="panel empty-state">
    <%= t("weekly_profit_reports.empty_state") %>
  </section>
</turbo-frame>

<script>
  document.addEventListener("turbo:load", () => {
    const platformSelect = document.querySelector("[data-weekly-profit-platform]");
    const accountSelect = document.getElementById("weekly-profit-account");
    if (!platformSelect || !accountSelect) return;

    const syncAccounts = () => {
      const platform = platformSelect.value;
      Array.from(accountSelect.options).forEach((option) => {
        option.hidden = option.dataset.platform !== platform;
      });
      const selected = accountSelect.selectedOptions[0];
      if (!selected || selected.hidden) {
        const firstVisible = Array.from(accountSelect.options).find((option) => !option.hidden);
        accountSelect.value = firstVisible ? firstVisible.value : "";
      }
    };

    platformSelect.addEventListener("change", syncAccounts);
    syncAccounts();
  });
</script>
