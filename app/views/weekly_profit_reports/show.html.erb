<h1 class="page-title"><%= t("weekly_profit_reports.title") %></h1>

<section class="panel">
  <form class="report-form" action="/weekly_profit_reports" method="get" data-turbo-frame="weekly_profit_report_results" data-controller="weekly-profit-filter">
    <div class="field field--time-range">
      <label for="weekly-profit-time-range-trigger"><%= t("weekly_profit_reports.filters.date_range") %></label>
      <div class="weekly-profit-time-range-row">
        <%= render "shared/time_range_selector",
                   id: "weekly-profit-time-range",
                   from_date: @from_date,
                   to_date: @to_date,
                   submit_on_apply: true %>
        <button class="button weekly-profit-submit-button" type="submit"><%= t("weekly_profit_reports.filters.submit") %></button>
      </div>
    </div>

    <div class="weekly-profit-filter-block">
      <div class="field field--full">
        <span class="field-label"><%= t("weekly_profit_reports.filters.report_type") %></span>
        <input type="hidden" name="report_type" value="<%= @report_type %>" data-weekly-profit-filter-target="reportTypeInput">
        <div class="weekly-profit-tag-row" data-weekly-profit-tag-group="report-type" role="group" aria-label="<%= t("weekly_profit_reports.filters.report_type") %>">
          <% WeeklyProfitReportsController::REPORT_TYPES.each do |report_type| %>
            <% active = @report_type == report_type %>
            <button
              type="button"
              class="weekly-profit-filter-tag<%= " is-active" if active %>"
              data-weekly-profit-tag
              data-weekly-profit-filter-target="reportButton"
              data-value="<%= report_type %>"
              data-action="weekly-profit-filter#selectReportType"
              aria-pressed="<%= active ? "true" : "false" %>">
              <%= t("weekly_profit_reports.filters.report_type_options.#{report_type}") %>
            </button>
          <% end %>
        </div>
      </div>

      <% store_selection_enabled = @report_type == "wr" %>
      <div class="field field--full weekly-profit-store-field<%= " is-disabled" unless store_selection_enabled %>" data-weekly-profit-store-field data-weekly-profit-filter-target="storeField" aria-disabled="<%= store_selection_enabled ? "false" : "true" %>">
        <span class="field-label"><%= t("weekly_profit_reports.filters.store") %></span>
        <input type="hidden" name="store_ref" value="<%= @selected_store_ref %>" data-weekly-profit-filter-target="storeInput">
        <div class="weekly-profit-tag-row" data-weekly-profit-tag-group="store" role="group" aria-label="<%= t("weekly_profit_reports.filters.store") %>">
          <% @store_options.each do |store| %>
            <% active = @selected_store_ref == store[:ref] %>
            <button
              type="button"
              class="weekly-profit-filter-tag<%= " is-active" if active %>"
              data-weekly-profit-store-tag
              data-weekly-profit-filter-target="storeButton"
              data-value="<%= store[:ref] %>"
              data-action="weekly-profit-filter#selectStore"
              aria-pressed="<%= active ? "true" : "false" %>"
              <%= "disabled" unless store_selection_enabled %>>
              <%= store[:label] %>
            </button>
          <% end %>
        </div>
      </div>
    </div>
  </form>
</section>

<turbo-frame id="weekly_profit_report_results">
  <section class="panel empty-state">
    <%= t("weekly_profit_reports.empty_state") %>
  </section>
</turbo-frame>
