<div class="report-stack">
  <section class="panel">
    <p class="report-meta">
      <%= report.dig(:meta, :account, :name) %> · <%= report.dig(:meta, :platform).to_s.upcase %> ·
      <%= report.dig(:period, :from_date) %> ~ <%= report.dig(:period, :to_date) %>
    </p>
    <p class="weekly-profit-comparison-note"><%= weekly_profit_report_comparison_note(report) %></p>
    <%= render "weekly_profit_reports/summary_cards", cards: weekly_profit_report_summary_cards(report) %>
  </section>

  <section class="panel">
    <h2 class="section-title"><%= t("weekly_profit_reports.sections.wr_rows") %></h2>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <% weekly_profit_report_table_columns(report).each do |key, label| %>
              <th><%= label %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% report[:rows].each do |row| %>
            <tr>
              <% weekly_profit_report_table_columns(report).each do |key, _label| %>
                <% comparison = weekly_profit_report_row_comparison(report, row, key) %>
                <td>
                  <div class="weekly-profit-table-value"><%= weekly_profit_report_value(row, key) %></div>
                  <% if comparison.present? %>
                    <div class="weekly-profit-table-comparison <%= weekly_profit_report_comparison_class(comparison) %>">
                      <%= weekly_profit_report_comparison_label(comparison) %>
                    </div>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <h2 class="section-title"><%= t("weekly_profit_reports.sections.unallocated") %></h2>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <% weekly_profit_report_unallocated_columns(report).each do |_key, label| %>
              <th><%= label %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% rows = weekly_profit_report_unallocated_rows(report) %>
          <% if rows.empty? %>
            <tr>
              <td colspan="<%= weekly_profit_report_unallocated_columns(report).size %>"><%= t("weekly_profit_reports.empty_unallocated") %></td>
            </tr>
          <% else %>
            <% rows.each do |row| %>
              <tr>
                <% weekly_profit_report_unallocated_columns(report).each do |key, _label| %>
                  <% comparison = (key == :amount ? weekly_profit_report_unallocated_comparison(report, row) : nil) %>
                  <td>
                    <div class="weekly-profit-table-value"><%= weekly_profit_report_value(row, key) %></div>
                    <% if comparison.present? %>
                      <div class="weekly-profit-table-comparison <%= weekly_profit_report_comparison_class(comparison) %>">
                        <%= weekly_profit_report_comparison_label(comparison) %>
                      </div>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
