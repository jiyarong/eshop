<%= turbo_frame_tag "wb_ads_product_#{@nm_id}_campaigns" do %>
  <div class="wb-ads-product-campaigns">
    <table class="inventory-list-table wb-ads-product-campaigns__table">
      <tbody>
        <% @rows.each do |row| %>
          <% campaign = row[:campaign] %>
          <tr>
            <td>
              <%= link_to campaign.name.presence || t("reports.wb_ads.unnamed_campaign"),
                          reports_wb_ads_campaign_path(campaign.advert_id, store_id: @store.id, from_date: @from_date, to_date: @to_date),
                          class: "wb-ads-campaign-link", data: { turbo_frame: "wb_ads_drawer" } %>
              <span class="status-pill <%= wb_ads_status_class(campaign.status) %>"><%= wb_ads_status_label(campaign.status) %></span>
              <small class="wb-ads-subline"><%= t("reports.wb_ads.fields.campaign_id", id: campaign.advert_id) %></small>
            </td>
            <td><strong><%= wb_ads_bid_label(campaign) %></strong><small class="wb-ads-subline"><%= wb_ads_placement_label(campaign) %></small></td>
            <td class="numeric"><%= row[:budget] ? wb_ads_metric(row[:budget].total, type: :currency) : t("common.empty_value") %></td>
            <td class="numeric"><%= wb_ads_metric(row[:spend], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:views]) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:ctr], type: :percentage) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:orders]) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:drr], type: :percentage) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:avg_position], type: :decimal) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:clicks]) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:add_to_cart]) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:revenue], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:cpc], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:cpo], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:cr], type: :percentage) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:cpm], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(row[:canceled]) %></td>
          </tr>
        <% end %>
        <% if @other_row %>
          <tr class="wb-ads-other-attribution-row">
            <td><strong><%= t("reports.wb_ads.other_attribution") %></strong></td>
            <td colspan="2"></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:spend], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:views]) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:ctr], type: :percentage) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:orders]) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:drr], type: :percentage) %></td>
            <td></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:clicks]) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:add_to_cart]) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:revenue], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:cpc], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:cpo], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:cr], type: :percentage) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:cpm], type: :currency) %></td>
            <td class="numeric"><%= wb_ads_metric(@other_row[:canceled]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
