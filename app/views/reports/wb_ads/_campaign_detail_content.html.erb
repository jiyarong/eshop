<div class="inventory-drawer__content wb-ads-drawer-content">
  <div class="wb-ads-campaign-meta">
    <span class="status-pill <%= wb_ads_status_class(@campaign.status) %>"><%= wb_ads_status_label(@campaign.status) %></span>
    <span><%= wb_ads_bid_label(@campaign) %></span>
    <span><%= wb_ads_placement_label(@campaign) %></span>
    <span><%= t("reports.wb_ads.fields.budget_value", value: @budget ? wb_ads_metric(@budget.total, type: :currency) : t("common.empty_value")) %></span>
  </div>
  <%= render "summary", summary: @summary %>
  <section>
    <h3 class="section-title"><%= t("reports.wb_ads.detail.products") %></h3>
    <div class="table-scroll">
      <table class="inventory-list-table wb-ads-table wb-ads-detail-table">
        <thead><tr>
          <th><%= t("reports.wb_ads.fields.product") %></th>
          <th><%= t("reports.wb_ads.fields.bid") %></th>
          <th><%= t("reports.wb_ads.metrics.spend") %></th>
          <th><%= t("reports.wb_ads.metrics.views") %></th>
          <th><%= t("reports.wb_ads.metrics.clicks") %></th>
          <th><%= t("reports.wb_ads.metrics.add_to_cart") %></th>
          <th><%= t("reports.wb_ads.metrics.orders") %></th>
          <th><%= t("reports.wb_ads.metrics.revenue") %></th>
          <th><%= t("reports.wb_ads.metrics.ctr") %></th>
          <th><%= t("reports.wb_ads.metrics.cpc") %></th>
          <th><%= t("reports.wb_ads.metrics.avg_position") %></th>
        </tr></thead>
        <tbody>
          <% @rows.each do |row| %>
            <% product = row[:campaign_product] %>
            <tr>
              <td><strong><%= row[:product_name].presence || t("reports.wb_ads.unknown_product") %></strong><small class="wb-ads-subline"><%= t("reports.wb_ads.fields.nm_id", id: product.nm_id) %><% if row[:sku_product]&.sku %> · <%= row[:sku_product].sku.sku_code %><% end %></small></td>
              <td><span><%= t("reports.wb_ads.fields.search_bid", value: product.search_bid_kopecks ? wb_ads_metric(product.search_bid_kopecks.to_d / 100, type: :currency) : t("common.empty_value")) %></span><small class="wb-ads-subline"><%= t("reports.wb_ads.fields.recommendation_bid", value: product.recommendation_bid_kopecks ? wb_ads_metric(product.recommendation_bid_kopecks.to_d / 100, type: :currency) : t("common.empty_value")) %></small></td>
              <td class="numeric"><%= wb_ads_metric(row[:spend], type: :currency) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:views]) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:clicks]) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:add_to_cart]) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:orders]) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:revenue], type: :currency) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:ctr], type: :percentage) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:cpc], type: :currency) %></td>
              <td class="numeric"><%= wb_ads_metric(row[:avg_position], type: :decimal) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
