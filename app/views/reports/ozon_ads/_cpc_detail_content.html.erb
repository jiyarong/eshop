<div class="inventory-drawer__content ozon-ads-drawer-content">
  <%= render "summary", summary: @summary %>
  <div class="table-scroll"><table class="inventory-list-table ozon-ads-table">
    <thead><tr><th><%= t("reports.ozon_ads.fields.internal_sku") %></th><th><%= t("reports.ozon_ads.fields.product") %></th><th><%= t("reports.ozon_ads.fields.bid") %></th>
      <th><%= t("reports.ozon_ads.fields.price") %></th><th><%= t("reports.ozon_ads.metrics.spend") %></th><th><%= t("reports.ozon_ads.metrics.revenue") %></th>
      <th><%= t("reports.ozon_ads.metrics.orders") %></th><th><%= t("reports.ozon_ads.metrics.impressions") %></th><th><%= t("reports.ozon_ads.metrics.clicks") %></th>
      <th><%= t("reports.ozon_ads.metrics.cart_additions") %></th><th><%= t("reports.ozon_ads.metrics.ctr") %></th><th><%= t("reports.ozon_ads.metrics.avg_cpc") %></th></tr></thead>
    <tbody><% @rows.each do |row| %><tr><td><strong><%= row[:sku]&.sku_code || "-" %></strong><small class="ozon-ads-product-subline"><%= row[:product].ozon_sku_id %></small></td>
      <td><strong><%= row[:raw_product]&.name || row[:product].title || "-" %></strong><small class="ozon-ads-product-subline"><%= row[:raw_product]&.offer_id %></small></td>
      <td class="numeric"><%= row[:product].bid ? number_to_currency(row[:product].bid, unit: "₽", format: "%n %u") : "-" %></td>
      <td class="numeric"><%= row[:product].price ? number_to_currency(row[:product].price, unit: "₽", format: "%n %u") : "-" %></td>
      <td class="numeric"><%= number_to_currency(row[:spend], unit: "₽", format: "%n %u") %></td><td class="numeric"><%= number_to_currency(row[:ad_revenue], unit: "₽", format: "%n %u") %></td>
      <td class="numeric"><%= row[:orders_count].to_i %></td><td class="numeric"><%= row[:impressions].to_i %></td><td class="numeric"><%= row[:clicks].to_i %></td>
      <td class="numeric"><%= row[:cart_additions].to_i %></td><td class="numeric"><%= row[:ctr] ? number_to_percentage(row[:ctr], precision: 2) : "-" %></td>
      <td class="numeric"><%= row[:avg_cpc] ? number_to_currency(row[:avg_cpc], unit: "₽", format: "%n %u") : "-" %></td>
    </tr><% end %></tbody>
  </table></div>
</div>
