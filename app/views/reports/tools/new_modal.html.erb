<%= turbo_frame_tag "erp_modal" do %>
  <div class="erp-modal-backdrop" data-controller="modal" data-action="click->modal#closeOnBackdrop">
    <section class="erp-modal erp-modal--wide" role="dialog" aria-modal="true" aria-labelledby="tool-new-modal-title">
      <div class="erp-modal__header">
        <h2 id="tool-new-modal-title"><%= t("reports.tools.new.title") %></h2>
        <button class="icon-button" type="button" aria-label="<%= t("common.actions.close") %>" data-action="modal#close">
          <i class="bi bi-x-lg" aria-hidden="true"></i>
        </button>
      </div>

      <p class="sub"><%= t("reports.tools.new.subtitle") %></p>

      <% default_definition = @tool_definitions.first %>
      <div data-tool-picker-root>
        <div class="field">
        <label for="tool_path"><%= t("reports.tools.new.tool_label") %></label>
        <select id="tool_path" name="tool_path" class="input">
          <% @tool_definitions.each do |definition| %>
            <option value="<%= report_tool_path(definition.tool_type) %>"><%= definition.name %></option>
          <% end %>
        </select>
        </div>

        <div class="hstack" style="justify-content: flex-end; margin-top: 18px;">
          <%= link_to t("reports.tools.actions.open_tool"),
                      default_definition.present? ? report_tool_path(default_definition.tool_type) : reports_tools_path,
                      class: "btn btn-primary",
                      onclick: "this.href = this.closest('[data-tool-picker-root]').querySelector(\"select[name='tool_path']\").value;",
                      data: { tool_open_link: true, turbo_frame: "tool_drawer", action: "click->modal#close" } %>
        </div>
      </div>
    </section>
  </div>
<% end %>
