<% content_for :page_heading, t("reports.sku_detail.title") %>

<div class="resource-header">
  <div>
    <p class="resource-eyebrow"><%= t("reports.sku_detail.title") %></p>
    <h1 class="page-title"><%= @sku.sku_code %></h1>
  </div>
  <div class="resource-actions">
    <%= link_to t("reports.sku_detail.actions.back_to_list"), "/reports/skus", class: "button button-secondary" %>
    <%= link_to t("reports.sku_detail.actions.edit_profile"), erp_edit_sku_path(@sku), class: "button" %>
  </div>
</div>

<%= turbo_frame_tag "erp_modal" %>

<section class="panel sku-detail-hero">
  <div class="sku-detail-identity">
    <span class="status-pill <%= @sku.is_active ? "is-active" : "is-muted" %>">
      <%= t(@sku.is_active ? "reports.sku_detail.status.active" : "reports.sku_detail.status.inactive") %>
    </span>
    <h2><%= report_value(@sku.product_name) %></h2>
    <p><%= report_value(@sku.product_name_ru) %></p>
  </div>

  <div class="summary-grid">
    <div class="weekly-profit-summary-card">
      <div class="summary-label"><%= t("reports.sku_detail.summary.last_30_days_net_sales") %></div>
      <div class="summary-value"><%= @overview_summary[:net_quantity] %></div>
    </div>
    <div class="weekly-profit-summary-card">
      <div class="summary-label"><%= t("reports.sku_detail.summary.last_30_days_revenue") %></div>
      <div class="summary-value"><%= report_value(@overview_summary[:gross_revenue]) %></div>
    </div>
    <div class="weekly-profit-summary-card">
      <div class="summary-label"><%= t("reports.sku_detail.summary.last_30_days_returns") %></div>
      <div class="summary-value"><%= @overview_summary[:return_quantity] %></div>
    </div>
    <div class="weekly-profit-summary-card">
      <div class="summary-label"><%= t("reports.sku_detail.summary.store_count") %></div>
      <div class="summary-value"><%= @overview_store_count %></div>
    </div>
  </div>
</section>

<nav class="sku-detail-tabs" aria-label="<%= t("reports.sku_detail.tabs.aria_label") %>">
  <% %w[basic inventory costs stores trend].each do |tab| %>
    <%= link_to t("reports.sku_detail.tabs.#{tab}"), sku_detail_tab_path(tab), aria: (@active_tab == tab ? { current: "page" } : nil) %>
  <% end %>
</nav>

<div class="report-stack">
