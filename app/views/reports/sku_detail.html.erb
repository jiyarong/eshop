        <dd><%= report_value(@sku.model) %></dd>
        <dt><%= t("reports.sku_detail.fields.quality_grade") %></dt>
        <dd><%= report_value(@sku.quality_grade) %></dd>
        <dt><%= t("reports.sku_detail.fields.features") %></dt>
        <dd><%= report_value(@sku.features) %></dd>
        <dt><%= t("reports.sku_detail.fields.owner") %></dt>
        <dd><%= report_value(@sku.owner_name) %></dd>
        <dt><%= t("reports.sku_detail.fields.note") %></dt>
        <dd><%= report_value(@sku.memo) %></dd>
