    <%= render "shared/sku_product_bindings",
               sku: @sku,
               sku_products: @sku_products,
               title_i18n_key: "reports.sku_detail.sections.platform_product_bindings",
               empty_i18n_key: "reports.sku_detail.empty.sku_products",
               show_sku_code: false,
               show_actions: false,
               actions_path: erp_sku_sku_products_path(@sku) %>
  <% elsif @active_tab == "inventory" %>
    <section class="panel">
      <div class="summary-grid">
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.inventory.received_quantity") %></div>
          <div class="summary-value"><%= @inventory_summary[:received_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.inventory.sales_quantity") %></div>
          <div class="summary-value"><%= @inventory_summary[:sales_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.inventory.return_quantity") %></div>
          <div class="summary-value"><%= @inventory_summary[:return_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.inventory.platform_stock") %></div>
          <div class="summary-value"><%= @inventory_summary[:platform_stock] %></div>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.inventory_reconciliation") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("reports.sku_detail.fields.platform") %></th>
              <th><%= t("reports.sku_detail.fields.store") %></th>
              <th><%= t("reports.sku_detail.inventory.sales_quantity") %></th>
              <th><%= t("reports.sku_detail.inventory.return_quantity") %></th>
              <th><%= t("reports.sku_detail.inventory.supply_quantity") %></th>
              <th><%= t("reports.sku_detail.inventory.platform_stock") %></th>
              <th><%= t("reports.sku_detail.inventory.latest_synced_at") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @inventory_store_rows.any? %>
              <% @inventory_store_rows.each do |row| %>
                <tr>
                  <td><%= platform_label_for_sales(row[:platform]) %></td>
                  <td><%= report_value(row[:store_name]) %></td>
                  <td><%= row[:sales_quantity] %></td>
                  <td><%= row[:return_quantity] %></td>
                  <td><%= row[:supply_quantity] %></td>
                  <td><%= row[:platform_stock] %></td>
                  <td><%= display_time(row[:latest_synced_at]) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="7" class="empty-state"><%= t("reports.sku_detail.empty.inventory_overview") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.latest_inventory_levels") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("reports.sku_detail.fields.platform") %></th>
              <th><%= t("reports.sku_detail.fields.store") %></th>
              <th><%= t("reports.sku_detail.fields.fulfillment_mode") %></th>
              <th><%= t("reports.sku_detail.inventory.quantity") %></th>
              <th><%= t("reports.sku_detail.inventory.latest_synced_at") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @latest_inventory_levels.any? %>
              <% @latest_inventory_levels.each do |level| %>
                <tr>
                  <td><%= platform_label_for_sales(level.platform) %></td>
                  <td><%= report_value(level.store_name) %></td>
                  <td><%= level.fulfillment_type.upcase %></td>
                  <td><%= level.quantity %></td>
                  <td><%= display_time(level.synced_at) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="empty-state"><%= t("reports.sku_detail.empty.inventory_levels") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% elsif @active_tab == "costs" %>
    <section class="panel">
      <div class="table-section-header">
        <h2 class="section-title"><%= t("reports.sku_detail.sections.predicted_cost_configuration") %></h2>
        <%= link_to new_report_sku_predicted_cost_path(@sku.sku_code, request.query_parameters.slice(:locale)), class: "button", data: { turbo_frame: "erp_modal" } do %>
          <%= t("reports.sku_detail.actions.add_predicted_cost") %>
        <% end %>
      </div>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("reports.sku_detail.fields.predicted_cost") %></th>
              <th><%= t("reports.sku_detail.fields.currency") %></th>
              <th><%= t("reports.sku_detail.fields.start_date") %></th>
              <th><%= t("reports.sku_detail.fields.end_date") %></th>
              <th><%= t("reports.sku_detail.fields.note") %></th>
              <th><%= t("reports.sku_detail.fields.created_at") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @predicted_costs.any? %>
              <% @predicted_costs.each do |cost| %>
                <tr>
                  <td><%= report_value(cost.cost_money) %></td>
                  <td><%= cost.cost_currency %></td>
                  <td><%= cost.effective_from %></td>
                  <td><%= report_value(cost.effective_to) %></td>
                  <td><%= report_value(cost.note) %></td>
                  <td><%= display_time(cost.created_at) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="empty-state"><%= t("reports.sku_detail.empty.predicted_costs") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.sku_base_cost") %></h2>
      <% if @sku_cost %>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th><%= t("reports.sku_detail.fields.purchase_price_cny") %></th>
                <th><%= t("reports.sku_detail.fields.freight_to_by_cny") %></th>
                <th><%= t("reports.sku_detail.fields.customs_misc_cny") %></th>
                <th><%= t("reports.sku_detail.fields.customs_duty_cny") %></th>
                <th><%= t("reports.sku_detail.fields.import_vat_cny") %></th>
                <th><%= t("reports.sku_detail.fields.goods_cost_cny") %></th>
                <th><%= t("reports.sku_detail.fields.package_size") %></th>
                <th><%= t("reports.sku_detail.fields.volume_l") %></th>
                <th><%= t("reports.sku_detail.fields.misc_cost_cny") %></th>
                <th><%= t("reports.sku_detail.fields.damage_rate") %></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><%= report_value(@sku_cost.purchase_price_cny) %></td>
                <td><%= report_value(@sku_cost.freight_to_by_cny) %></td>
                <td><%= report_value(@sku_cost.customs_misc_cny) %></td>
                <td><%= report_value(@sku_cost.customs_duty_cny) %></td>
                <td><%= report_value(@sku_cost.import_vat_cny) %></td>
                <td><%= report_value(@sku_cost.goods_cost_cny) %></td>
                <td><%= [@sku_cost.pkg_length_cm, @sku_cost.pkg_width_cm, @sku_cost.pkg_height_cm].compact_blank.join(" x ").presence || "-" %></td>
                <td><%= report_value(@sku_cost.pkg_volume_l) %></td>
                <td><%= report_value(@sku_cost.misc_cost_cny) %></td>
                <td><%= report_value(@sku_cost.damage_rate) %></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state"><%= t("reports.sku_detail.empty.cost_data") %></div>
      <% end %>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.wb_cost") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("reports.sku_detail.fields.delivery_mode") %></th>
              <th><%= t("reports.sku_detail.fields.company_type") %></th>
              <th><%= t("reports.sku_detail.fields.target_price_rub") %></th>
              <th><%= t("reports.sku_detail.fields.revenue_cny") %></th>
              <th><%= t("reports.sku_detail.fields.platform_freight_cny") %></th>
              <th><%= t("reports.sku_detail.fields.ad_spend_cny") %></th>
              <th><%= t("reports.sku_detail.fields.total_cost_cny") %></th>
              <th><%= t("reports.sku_detail.fields.profit_cny") %></th>
              <th><%= t("reports.sku_detail.fields.margin") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @wb_costs.any? %>
              <% @wb_costs.each do |cost| %>
                <tr>
                  <td><%= cost.delivery_mode %></td>
                  <td><%= cost.company_type %></td>
                  <td><%= report_value(cost.target_price_rub) %></td>
                  <td><%= report_value(cost.revenue_cny) %></td>
                  <td><%= report_value(cost.wb_platform_freight_cny) %></td>
                  <td><%= report_value(cost.wb_ad_spend_cny) %></td>
                  <td><%= report_value(cost.wb_total_cost_cny) %></td>
                  <td class="<%= "metric-negative" if cost.profit_cny.negative? %>"><%= report_value(cost.profit_cny) %></td>
                  <td class="<%= "metric-negative" if cost.margin.negative? %>"><%= cost.margin_pct %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="9" class="empty-state"><%= t("reports.sku_detail.empty.wb_costs") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.ozon_cost") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("reports.sku_detail.fields.delivery_mode") %></th>
              <th><%= t("reports.sku_detail.fields.company_type") %></th>
              <th><%= t("reports.sku_detail.fields.rf_price_rub") %></th>
              <th><%= t("reports.sku_detail.fields.by_price_rub") %></th>
              <th><%= t("reports.sku_detail.fields.rf_revenue_cny") %></th>
              <th><%= t("reports.sku_detail.fields.by_revenue_cny") %></th>
              <th><%= t("reports.sku_detail.fields.platform_freight_cny") %></th>
              <th><%= t("reports.sku_detail.fields.rf_total_cost_cny") %></th>
              <th><%= t("reports.sku_detail.fields.by_total_cost_cny") %></th>
              <th><%= t("reports.sku_detail.fields.rf_profit_cny") %></th>
              <th><%= t("reports.sku_detail.fields.by_profit_cny") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @ozon_costs.any? %>
              <% @ozon_costs.each do |cost| %>
                <tr>
                  <td><%= cost.delivery_mode %></td>
                  <td><%= cost.company_type %></td>
                  <td><%= report_value(cost.target_price_rf_rub) %></td>
                  <td><%= report_value(cost.target_price_by_rub) %></td>
                  <td><%= report_value(cost.ozon_revenue_rf_cny) %></td>
                  <td><%= report_value(cost.ozon_revenue_by_cny) %></td>
                  <td><%= report_value(cost.ozon_platform_freight_cny) %></td>
                  <td><%= report_value(cost.ozon_total_cost_rf_cny) %></td>
                  <td><%= report_value(cost.ozon_total_cost_by_cny) %></td>
                  <td class="<%= "metric-negative" if cost.ozon_profit_rf_cny.negative? %>"><%= report_value(cost.ozon_profit_rf_cny) %></td>
                  <td class="<%= "metric-negative" if cost.ozon_profit_by_cny.negative? %>"><%= report_value(cost.ozon_profit_by_cny) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="11" class="empty-state"><%= t("reports.sku_detail.empty.ozon_costs") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% elsif @active_tab == "stores" %>
    <section class="panel">
      <%= form_with url: report_sku_path(@sku.sku_code), method: :get, local: true, html: { class: "report-form" } do %>
        <input type="hidden" name="tab" value="stores">
        <div class="field">
          <label for="from_date"><%= t("reports.sku_detail.filters.start_date") %></label>
          <input id="from_date" type="date" name="from_date" value="<%= @from_date %>">
        </div>
        <div class="field">
          <label for="to_date"><%= t("reports.sku_detail.filters.end_date") %></label>
          <input id="to_date" type="date" name="to_date" value="<%= @to_date %>">
        </div>
        <div class="field">
          <label for="platform"><%= t("reports.sku_detail.filters.platform") %></label>
          <select id="platform" name="platform">
            <option value=""><%= t("reports.sku_detail.filters.all_platforms") %></option>
            <option value="ozon" <%= "selected" if @selected_platform == "ozon" %>>Ozon</option>
            <option value="wb" <%= "selected" if @selected_platform == "wb" %>>WB</option>
            <option value="amazon" <%= "selected" if @selected_platform == "amazon" %>>Amazon</option>
          </select>
        </div>
        <div class="field">
          <label for="store_id"><%= t("reports.sku_detail.filters.store") %></label>
          <select id="store_id" name="store_id">
            <option value=""><%= t("reports.sku_detail.filters.all_stores") %></option>
            <% @stores.each do |store| %>
              <option value="<%= store.id %>" <%= "selected" if @selected_store_id.to_s == store.id.to_s %>><%= store.platform.upcase %> / <%= store.store_name %></option>
            <% end %>
          </select>
        </div>
        <button class="button" type="submit"><%= t("reports.sku_detail.filters.submit") %></button>
      <% end %>
    </section>

    <section class="panel">
      <div class="summary-grid">
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.metrics.units_sold") %></div>
          <div class="summary-value"><%= @sku_sales_summary[:sales_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.metrics.returned_units") %></div>
          <div class="summary-value"><%= @sku_sales_summary[:return_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.metrics.net_sales") %></div>
          <div class="summary-value"><%= @sku_sales_summary[:net_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.metrics.order_count") %></div>
          <div class="summary-value"><%= @sku_sales_summary[:order_count] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.metrics.revenue") %></div>
          <div class="summary-value"><%= report_value(@sku_sales_summary[:gross_revenue]) %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("reports.sku_detail.metrics.average_price") %></div>
          <div class="summary-value"><%= @sku_sales_summary[:sales_quantity].positive? ? report_value(@sku_sales_summary[:gross_revenue] / @sku_sales_summary[:sales_quantity]) : "-" %></div>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.store_sales") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("reports.sku_detail.fields.platform") %></th>
              <th><%= t("reports.sku_detail.fields.store") %></th>
              <th><%= t("reports.sku_detail.metrics.units_sold") %></th>
              <th><%= t("reports.sku_detail.metrics.returned_units") %></th>
              <th><%= t("reports.sku_detail.metrics.net_sales") %></th>
              <th><%= t("reports.sku_detail.metrics.order_count") %></th>
              <th><%= t("reports.sku_detail.metrics.revenue") %></th>
              <th>Payout</th>
              <th><%= t("reports.sku_detail.metrics.commission") %></th>
              <th><%= t("reports.sku_detail.metrics.discount") %></th>
              <th><%= t("reports.sku_detail.metrics.average_price") %></th>
              <th><%= t("reports.sku_detail.fields.fulfillment_mode") %></th>
              <th><%= t("reports.sku_detail.fields.last_ordered_at") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @sku_sales_rows.any? %>
              <% @sku_sales_rows.each do |row| %>
                <tr>
                  <td><%= platform_label_for_sales(row[:platform]) %></td>
                  <td><%= report_value(row[:store_name]) %></td>
                  <td><%= row[:sales_quantity] %></td>
                  <td><%= row[:return_quantity] %></td>
                  <td><%= row[:net_quantity] %></td>
                  <td><%= row[:order_count] %></td>
                  <td><%= report_value(row[:gross_revenue]) %></td>
                  <td><%= report_value(row[:payout]) %></td>
                  <td><%= report_value(row[:commission]) %></td>
                  <td><%= report_value(row[:discount]) %></td>
                  <td><%= report_value(row[:average_unit_price]) %></td>
                  <td><%= report_value(row[:fulfillment_types]) %></td>
                  <td><%= display_time(row[:last_ordered_at]) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="13" class="empty-state"><%= t("reports.sku_detail.empty.order_data") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% else %>
    <section class="panel">
      <%= form_with url: report_sku_path(@sku.sku_code), method: :get, local: true, html: { class: "report-form" } do %>
        <input type="hidden" name="tab" value="trend">
        <div class="field">
          <label for="trend_from_date"><%= t("reports.sku_detail.filters.start_date") %></label>
          <input id="trend_from_date" type="date" name="from_date" value="<%= @from_date %>">
        </div>
        <div class="field">
          <label for="trend_to_date"><%= t("reports.sku_detail.filters.end_date") %></label>
          <input id="trend_to_date" type="date" name="to_date" value="<%= @to_date %>">
        </div>
        <div class="field">
          <label for="period"><%= t("reports.sku_detail.filters.period") %></label>
          <select id="period" name="period">
            <option value="day" <%= "selected" if @period == "day" %>><%= t("reports.sku_detail.periods.day") %></option>
            <option value="week" <%= "selected" if @period == "week" %>><%= t("reports.sku_detail.periods.week") %></option>
            <option value="month" <%= "selected" if @period == "month" %>><%= t("reports.sku_detail.periods.month") %></option>
          </select>
        </div>
        <div class="field">
          <label for="grain"><%= t("reports.sku_detail.filters.grain") %></label>
          <select id="grain" name="grain">
            <option value="store" <%= "selected" if @grain == "store" %>><%= t("reports.sku_detail.grains.store") %></option>
            <option value="platform" <%= "selected" if @grain == "platform" %>><%= t("reports.sku_detail.grains.platform") %></option>
            <option value="sku" <%= "selected" if @grain == "sku" %>><%= t("reports.sku_detail.grains.sku") %></option>
          </select>
        </div>
        <button class="button" type="submit"><%= t("reports.sku_detail.filters.submit") %></button>
      <% end %>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.sales_trend_chart") %></h2>
      <% if @sku_sales_chart_series.any? %>
        <script src="https://cdn.jsdelivr.net/npm/echarts@5.6.0/dist/echarts.min.js"></script>
        <div id="sku-detail-sales-chart" data-chart="sku-detail-sales" style="width: 100%; height: 360px;"></div>
        <script id="sku-detail-sales-chart-data" type="application/json"><%= raw JSON.generate(@sku_sales_chart_option) %></script>
        <script>
          (() => {
            const renderSkuDetailSalesChart = () => {
              const element = document.getElementById("sku-detail-sales-chart");
              const dataElement = document.getElementById("sku-detail-sales-chart-data");
              if (!element || !dataElement || !window.echarts) return;

              const chart = window.echarts.getInstanceByDom(element) || window.echarts.init(element);
              chart.setOption(JSON.parse(dataElement.textContent));
              window.addEventListener("resize", () => chart.resize(), { once: true });
            };

            document.addEventListener("turbo:load", renderSkuDetailSalesChart);
            document.addEventListener("DOMContentLoaded", renderSkuDetailSalesChart);
            renderSkuDetailSalesChart();
          })();
        </script>
      <% else %>
        <div class="empty-state"><%= t("reports.sku_detail.empty.order_data") %></div>
      <% end %>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("reports.sku_detail.sections.trend_details") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("reports.sku_detail.fields.period") %></th>
              <th>SKU</th>
              <% unless @grain == "sku" %>
                <th><%= t("reports.sku_detail.fields.platform") %></th>
              <% end %>
              <% if @grain == "store" %>
                <th><%= t("reports.sku_detail.fields.store") %></th>
              <% end %>
              <th><%= t("reports.sku_detail.metrics.units_sold") %></th>
              <th><%= t("reports.sku_detail.metrics.returned_units") %></th>
              <th><%= t("reports.sku_detail.metrics.net_sales") %></th>
              <th><%= t("reports.sku_detail.metrics.order_count") %></th>
              <th><%= t("reports.sku_detail.metrics.revenue") %></th>
              <th>Payout</th>
              <th><%= t("reports.sku_detail.metrics.commission") %></th>
              <th><%= t("reports.sku_detail.metrics.discount") %></th>
              <th><%= t("reports.sku_detail.metrics.average_price") %></th>
              <th><%= t("reports.sku_detail.fields.fulfillment_mode") %></th>
            </tr>
          </thead>
          <tbody>
            <% if @sku_sales_rows.any? %>
              <% @sku_sales_rows.each do |row| %>
                <tr>
                  <td><%= row[:period_start] %></td>
                  <td><%= row[:sku_code] %></td>
                  <% unless @grain == "sku" %>
                    <td><%= platform_label_for_sales(row[:platform]) %></td>
                  <% end %>
                  <% if @grain == "store" %>
                    <td><%= report_value(row[:store_name]) %></td>
                  <% end %>
                  <td><%= row[:sales_quantity] %></td>
                  <td><%= row[:return_quantity] %></td>
                  <td><%= row[:net_quantity] %></td>
                  <td><%= row[:order_count] %></td>
                  <td><%= report_value(row[:gross_revenue]) %></td>
                  <td><%= report_value(row[:payout]) %></td>
                  <td><%= report_value(row[:commission]) %></td>
                  <td><%= report_value(row[:discount]) %></td>
                  <td><%= report_value(row[:average_unit_price]) %></td>
                  <td><%= report_value(row[:fulfillment_types]) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="<%= @grain == "store" ? 14 : (@grain == "platform" ? 13 : 12) %>" class="empty-state"><%= t("reports.sku_detail.empty.order_data") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
