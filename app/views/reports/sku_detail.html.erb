<% content_for :page_heading, "SKU 详情" %>

<div class="resource-header">
  <div>
    <p class="resource-eyebrow">SKU 详情</p>
    <h1 class="page-title"><%= @sku.sku_code %></h1>
  </div>
  <div class="resource-actions">
    <%= link_to "返回列表", "/reports/skus", class: "button button-secondary" %>
    <%= link_to "编辑资料", erp_edit_sku_path(@sku), class: "button" %>
  </div>
</div>

<section class="panel sku-detail-hero">
  <div class="sku-detail-identity">
    <span class="status-pill <%= @sku.is_active ? "is-active" : "is-muted" %>">
      <%= @sku.is_active ? "上架" : "下架" %>
    </span>
    <h2><%= report_value(@sku.product_name) %></h2>
    <p><%= report_value(@sku.product_name_ru) %></p>
  </div>

  <div class="summary-grid">
    <div class="weekly-profit-summary-card">
      <div class="summary-label">最近30天净销量</div>
      <div class="summary-value"><%= @overview_summary[:net_quantity] %></div>
    </div>
    <div class="weekly-profit-summary-card">
      <div class="summary-label">最近30天销售额</div>
      <div class="summary-value"><%= report_value(@overview_summary[:gross_revenue]) %></div>
    </div>
    <div class="weekly-profit-summary-card">
      <div class="summary-label">最近30天退货</div>
      <div class="summary-value"><%= @overview_summary[:return_quantity] %></div>
    </div>
    <div class="weekly-profit-summary-card">
      <div class="summary-label">涉及店铺</div>
      <div class="summary-value"><%= @overview_store_count %></div>
    </div>
  </div>
</section>

<nav class="sku-detail-tabs" aria-label="SKU详情分组">
  <% [["basic", "基础配置"], ["costs", "成本情况"], ["stores", "各店铺销量情况"], ["trend", "销量历史趋势"]].each do |tab, label| %>
    <%= link_to label, sku_detail_tab_path(tab), aria: (@active_tab == tab ? { current: "page" } : nil) %>
  <% end %>
</nav>

<div class="report-stack">
  <% if @active_tab == "basic" %>
    <section class="panel">
      <h2 class="section-title">基础信息</h2>
      <dl class="definition-list">
        <dt>SKU编码</dt>
        <dd><%= @sku.sku_code %></dd>
        <dt>中文名</dt>
        <dd><%= report_value(@sku.product_name) %></dd>
        <dt>俄文名</dt>
        <dd><%= report_value(@sku.product_name_ru) %></dd>
        <dt>类目</dt>
        <dd><%= report_value(@sku.sku_category&.name) %></dd>
        <dt>主SKU</dt>
        <dd><%= report_value(@sku.master_sku&.master_sku_code) %></dd>
        <dt>状态</dt>
        <dd><%= @sku.is_active ? "上架" : "下架" %></dd>
        <dt>创建时间</dt>
        <dd><%= report_value(@sku.created_at&.strftime("%Y-%m-%d %H:%M")) %></dd>
        <dt>更新时间</dt>
        <dd><%= report_value(@sku.updated_at&.strftime("%Y-%m-%d %H:%M")) %></dd>
      </dl>
    </section>

    <section class="panel">
      <h2 class="section-title">商品属性</h2>
      <dl class="definition-list">
        <dt>颜色</dt>
        <dd><%= report_value(@sku.color) %></dd>
        <dt>规格</dt>
        <dd><%= report_value(@sku.spec) %></dd>
        <dt>尺寸</dt>
        <dd><%= report_value(@sku.size) %></dd>
        <dt>重量 kg</dt>
        <dd><%= report_value(@sku.weight_kg) %></dd>
        <dt>体积 L</dt>
        <dd><%= report_value(@sku.volume_l) %></dd>
        <dt>型号</dt>
        <dd><%= report_value(@sku.model) %></dd>
        <dt>品质</dt>
        <dd><%= report_value(@sku.quality_grade) %></dd>
        <dt>特点</dt>
        <dd><%= report_value(@sku.features) %></dd>
        <dt>负责人</dt>
        <dd><%= report_value(@sku.owner_name) %></dd>
        <dt>备注</dt>
        <dd><%= report_value(@sku.memo) %></dd>
      </dl>
    </section>

    <section class="panel">
      <h2 class="section-title">店铺上架配置</h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>平台</th>
              <th>店铺</th>
              <th>状态</th>
              <th>外部 ID</th>
              <th>上架日期</th>
              <th>负责人</th>
            </tr>
          </thead>
          <tbody>
            <% if @store_assignments.any? %>
              <% @store_assignments.each do |assignment| %>
                <tr>
                  <td><%= platform_label_for_sales(assignment.platform) %></td>
                  <td><%= assignment.store_display_name %></td>
                  <td><%= assignment.is_active ? "启用" : "停用" %></td>
                  <td><%= report_value(assignment.external_id) %></td>
                  <td><%= report_value(assignment.listed_at) %></td>
                  <td><%= report_value(assignment.owner_name) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="empty-state">暂无店铺上架配置</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% elsif @active_tab == "costs" %>
    <section class="panel">
      <h2 class="section-title">SKU 基础成本</h2>
      <% if @sku_cost %>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>采购价 CNY</th>
                <th>到白俄运费 CNY</th>
                <th>清关杂费 CNY</th>
                <th>关税额 CNY</th>
                <th>进口增值税 CNY</th>
                <th>货物总成本 CNY</th>
                <th>包装尺寸</th>
                <th>升量 L</th>
                <th>杂费 CNY</th>
                <th>货损率</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><%= report_value(@sku_cost.purchase_price_cny) %></td>
                <td><%= report_value(@sku_cost.freight_to_by_cny) %></td>
                <td><%= report_value(@sku_cost.customs_misc_cny) %></td>
                <td><%= report_value(@sku_cost.customs_duty_cny) %></td>
                <td><%= report_value(@sku_cost.import_vat_cny) %></td>
                <td><%= report_value(@sku_cost.goods_cost_cny) %></td>
                <td><%= [@sku_cost.pkg_length_cm, @sku_cost.pkg_width_cm, @sku_cost.pkg_height_cm].compact_blank.join(" x ").presence || "-" %></td>
                <td><%= report_value(@sku_cost.pkg_volume_l) %></td>
                <td><%= report_value(@sku_cost.misc_cost_cny) %></td>
                <td><%= report_value(@sku_cost.damage_rate) %></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state">暂无成本数据</div>
      <% end %>
    </section>

    <section class="panel">
      <h2 class="section-title">WB 成本</h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>配送模式</th>
              <th>公司类型</th>
              <th>目标售价 RUB</th>
              <th>收入 CNY</th>
              <th>平台运费 CNY</th>
              <th>广告费 CNY</th>
              <th>最终成本 CNY</th>
              <th>利润 CNY</th>
              <th>利润率</th>
            </tr>
          </thead>
          <tbody>
            <% if @wb_costs.any? %>
              <% @wb_costs.each do |cost| %>
                <tr>
                  <td><%= cost.delivery_mode %></td>
                  <td><%= cost.company_type %></td>
                  <td><%= report_value(cost.target_price_rub) %></td>
                  <td><%= report_value(cost.revenue_cny) %></td>
                  <td><%= report_value(cost.wb_platform_freight_cny) %></td>
                  <td><%= report_value(cost.wb_ad_spend_cny) %></td>
                  <td><%= report_value(cost.wb_total_cost_cny) %></td>
                  <td class="<%= "metric-negative" if cost.profit_cny.negative? %>"><%= report_value(cost.profit_cny) %></td>
                  <td class="<%= "metric-negative" if cost.margin.negative? %>"><%= cost.margin_pct %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="9" class="empty-state">暂无 WB 成本数据</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title">Ozon 成本</h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>配送模式</th>
              <th>公司类型</th>
              <th>俄罗斯售价 RUB</th>
              <th>白俄售价 RUB</th>
              <th>俄罗斯收入 CNY</th>
              <th>白俄收入 CNY</th>
              <th>平台运费 CNY</th>
              <th>俄罗斯最终成本 CNY</th>
              <th>白俄最终成本 CNY</th>
              <th>俄罗斯利润 CNY</th>
              <th>白俄利润 CNY</th>
            </tr>
          </thead>
          <tbody>
            <% if @ozon_costs.any? %>
              <% @ozon_costs.each do |cost| %>
                <tr>
                  <td><%= cost.delivery_mode %></td>
                  <td><%= cost.company_type %></td>
                  <td><%= report_value(cost.target_price_rf_rub) %></td>
                  <td><%= report_value(cost.target_price_by_rub) %></td>
                  <td><%= report_value(cost.ozon_revenue_rf_cny) %></td>
                  <td><%= report_value(cost.ozon_revenue_by_cny) %></td>
                  <td><%= report_value(cost.ozon_platform_freight_cny) %></td>
                  <td><%= report_value(cost.ozon_total_cost_rf_cny) %></td>
                  <td><%= report_value(cost.ozon_total_cost_by_cny) %></td>
                  <td class="<%= "metric-negative" if cost.ozon_profit_rf_cny.negative? %>"><%= report_value(cost.ozon_profit_rf_cny) %></td>
                  <td class="<%= "metric-negative" if cost.ozon_profit_by_cny.negative? %>"><%= report_value(cost.ozon_profit_by_cny) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="11" class="empty-state">暂无 Ozon 成本数据</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% elsif @active_tab == "stores" %>
    <section class="panel">
      <%= form_with url: report_sku_path(@sku.sku_code), method: :get, local: true, html: { class: "report-form" } do %>
        <input type="hidden" name="tab" value="stores">
        <div class="field">
          <label for="from_date">开始日期</label>
          <input id="from_date" type="date" name="from_date" value="<%= @from_date %>">
        </div>
        <div class="field">
          <label for="to_date">结束日期</label>
          <input id="to_date" type="date" name="to_date" value="<%= @to_date %>">
        </div>
        <div class="field">
          <label for="platform">平台</label>
          <select id="platform" name="platform">
            <option value="">全部平台</option>
            <option value="ozon" <%= "selected" if @selected_platform == "ozon" %>>Ozon</option>
            <option value="wb" <%= "selected" if @selected_platform == "wb" %>>WB</option>
            <option value="amazon" <%= "selected" if @selected_platform == "amazon" %>>Amazon</option>
          </select>
        </div>
        <div class="field">
          <label for="store_id">店铺</label>
          <select id="store_id" name="store_id">
            <option value="">全部店铺</option>
            <% @stores.each do |store| %>
              <option value="<%= store.id %>" <%= "selected" if @selected_store_id.to_s == store.id.to_s %>><%= store.platform.upcase %> / <%= store.store_name %></option>
            <% end %>
          </select>
        </div>
        <button class="button" type="submit">查询</button>
      <% end %>
    </section>

    <section class="panel">
      <div class="summary-grid">
        <div class="weekly-profit-summary-card">
          <div class="summary-label">销售件数</div>
          <div class="summary-value"><%= @sku_sales_summary[:sales_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">退货件数</div>
          <div class="summary-value"><%= @sku_sales_summary[:return_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">净销量</div>
          <div class="summary-value"><%= @sku_sales_summary[:net_quantity] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">订单数</div>
          <div class="summary-value"><%= @sku_sales_summary[:order_count] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">销售额</div>
          <div class="summary-value"><%= report_value(@sku_sales_summary[:gross_revenue]) %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">均价</div>
          <div class="summary-value"><%= @sku_sales_summary[:sales_quantity].positive? ? report_value(@sku_sales_summary[:gross_revenue] / @sku_sales_summary[:sales_quantity]) : "-" %></div>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title">店铺销量</h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>平台</th>
              <th>店铺</th>
              <th>销售件数</th>
              <th>退货件数</th>
              <th>净销量</th>
              <th>订单数</th>
              <th>销售额</th>
              <th>Payout</th>
              <th>佣金</th>
              <th>折扣</th>
              <th>均价</th>
              <th>履约模式</th>
              <th>最近出单时间</th>
            </tr>
          </thead>
          <tbody>
            <% if @sku_sales_rows.any? %>
              <% @sku_sales_rows.each do |row| %>
                <tr>
                  <td><%= platform_label_for_sales(row[:platform]) %></td>
                  <td><%= report_value(row[:store_name]) %></td>
                  <td><%= row[:sales_quantity] %></td>
                  <td><%= row[:return_quantity] %></td>
                  <td><%= row[:net_quantity] %></td>
                  <td><%= row[:order_count] %></td>
                  <td><%= report_value(row[:gross_revenue]) %></td>
                  <td><%= report_value(row[:payout]) %></td>
                  <td><%= report_value(row[:commission]) %></td>
                  <td><%= report_value(row[:discount]) %></td>
                  <td><%= report_value(row[:average_unit_price]) %></td>
                  <td><%= report_value(row[:fulfillment_types]) %></td>
                  <td><%= report_value(row[:last_ordered_at]&.strftime("%Y-%m-%d %H:%M")) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="13" class="empty-state">当前筛选范围内没有订单数据</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% else %>
    <section class="panel">
      <%= form_with url: report_sku_path(@sku.sku_code), method: :get, local: true, html: { class: "report-form" } do %>
        <input type="hidden" name="tab" value="trend">
        <div class="field">
          <label for="trend_from_date">开始日期</label>
          <input id="trend_from_date" type="date" name="from_date" value="<%= @from_date %>">
        </div>
        <div class="field">
          <label for="trend_to_date">结束日期</label>
          <input id="trend_to_date" type="date" name="to_date" value="<%= @to_date %>">
        </div>
        <div class="field">
          <label for="period">周期</label>
          <select id="period" name="period">
            <option value="day" <%= "selected" if @period == "day" %>>日</option>
            <option value="week" <%= "selected" if @period == "week" %>>周</option>
            <option value="month" <%= "selected" if @period == "month" %>>月</option>
          </select>
        </div>
        <div class="field">
          <label for="grain">维度</label>
          <select id="grain" name="grain">
            <option value="store" <%= "selected" if @grain == "store" %>>店铺</option>
            <option value="platform" <%= "selected" if @grain == "platform" %>>平台</option>
            <option value="sku" <%= "selected" if @grain == "sku" %>>汇总</option>
          </select>
        </div>
        <button class="button" type="submit">查询</button>
      <% end %>
    </section>

    <section class="panel">
      <h2 class="section-title">净销量 / 销售额趋势</h2>
      <% if @sku_sales_chart_series.any? %>
        <script src="https://cdn.jsdelivr.net/npm/echarts@5.6.0/dist/echarts.min.js"></script>
        <div id="sku-detail-sales-chart" data-chart="sku-detail-sales" style="width: 100%; height: 360px;"></div>
        <script id="sku-detail-sales-chart-data" type="application/json"><%= raw JSON.generate(@sku_sales_chart_option) %></script>
        <script>
          (() => {
            const renderSkuDetailSalesChart = () => {
              const element = document.getElementById("sku-detail-sales-chart");
              const dataElement = document.getElementById("sku-detail-sales-chart-data");
              if (!element || !dataElement || !window.echarts) return;

              const chart = window.echarts.getInstanceByDom(element) || window.echarts.init(element);
              chart.setOption(JSON.parse(dataElement.textContent));
              window.addEventListener("resize", () => chart.resize(), { once: true });
            };

            document.addEventListener("turbo:load", renderSkuDetailSalesChart);
            document.addEventListener("DOMContentLoaded", renderSkuDetailSalesChart);
            renderSkuDetailSalesChart();
          })();
        </script>
      <% else %>
        <div class="empty-state">当前筛选范围内没有订单数据</div>
      <% end %>
    </section>

    <section class="panel">
      <h2 class="section-title">趋势明细</h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>周期</th>
              <th>SKU</th>
              <% unless @grain == "sku" %>
                <th>平台</th>
              <% end %>
              <% if @grain == "store" %>
                <th>店铺</th>
              <% end %>
              <th>销售件数</th>
              <th>退货件数</th>
              <th>净销量</th>
              <th>订单数</th>
              <th>销售额</th>
              <th>Payout</th>
              <th>佣金</th>
              <th>折扣</th>
              <th>均价</th>
              <th>履约模式</th>
            </tr>
          </thead>
          <tbody>
            <% if @sku_sales_rows.any? %>
              <% @sku_sales_rows.each do |row| %>
                <tr>
                  <td><%= row[:period_start] %></td>
                  <td><%= row[:sku_code] %></td>
                  <% unless @grain == "sku" %>
                    <td><%= platform_label_for_sales(row[:platform]) %></td>
                  <% end %>
                  <% if @grain == "store" %>
                    <td><%= report_value(row[:store_name]) %></td>
                  <% end %>
                  <td><%= row[:sales_quantity] %></td>
                  <td><%= row[:return_quantity] %></td>
                  <td><%= row[:net_quantity] %></td>
                  <td><%= row[:order_count] %></td>
                  <td><%= report_value(row[:gross_revenue]) %></td>
                  <td><%= report_value(row[:payout]) %></td>
                  <td><%= report_value(row[:commission]) %></td>
                  <td><%= report_value(row[:discount]) %></td>
                  <td><%= report_value(row[:average_unit_price]) %></td>
                  <td><%= report_value(row[:fulfillment_types]) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="<%= @grain == "store" ? 14 : (@grain == "platform" ? 13 : 12) %>" class="empty-state">当前筛选范围内没有订单数据</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
