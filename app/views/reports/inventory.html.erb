<h1 class="page-title"><%= t("reports.inventory.title") %></h1>

<div class="report-stack">
  <section class="panel">
    <form action="/reports/inventory" method="get" class="report-form">
      <% if params[:locale].present? %>
        <input type="hidden" name="locale" value="<%= params[:locale] %>">
      <% end %>
      <div class="field">
        <label for="inventory_sku"><%= t("reports.inventory.filters.sku") %></label>
        <input id="inventory_sku"
               type="search"
               name="sku"
               value="<%= @sku_query %>"
               placeholder="<%= t("reports.inventory.filters.sku_placeholder") %>">
      </div>

      <%= render "shared/responsible_user_filters",
        field_class: "",
        dom_id_prefix: "inventory-responsible-user-filter" %>

      <div class="field">
        <label for="inventory_turnover_days_min"><%= t("reports.inventory.filters.turnover_days_min") %></label>
        <input id="inventory_turnover_days_min"
               type="number"
               step="0.01"
               name="turnover_days_min"
               value="<%= @turnover_days_min_query %>">
      </div>

      <div class="field">
        <label for="inventory_turnover_days_max"><%= t("reports.inventory.filters.turnover_days_max") %></label>
        <input id="inventory_turnover_days_max"
               type="number"
               step="0.01"
               name="turnover_days_max"
               value="<%= @turnover_days_max_query %>">
      </div>

      <div class="field">
        <label for="inventory_procurement_turnover_days_min"><%= t("reports.inventory.filters.procurement_turnover_days_min") %></label>
        <input id="inventory_procurement_turnover_days_min"
               type="number"
               step="0.01"
               name="procurement_turnover_days_min"
               value="<%= @procurement_turnover_days_min_query %>">
      </div>

      <div class="field">
        <label for="inventory_procurement_turnover_days_max"><%= t("reports.inventory.filters.procurement_turnover_days_max") %></label>
        <input id="inventory_procurement_turnover_days_max"
               type="number"
               step="0.01"
               name="procurement_turnover_days_max"
               value="<%= @procurement_turnover_days_max_query %>">
      </div>

      <button class="button" type="submit"><%= t("reports.inventory.filters.submit") %></button>
      <% if inventory_filters_active? %>
        <%= link_to t("reports.inventory.filters.reset"), "/reports/inventory", class: "button button-secondary" %>
      <% end %>
    </form>
  </section>

  <section class="panel inventory-volume-summary">
    <div class="summary-grid">
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("reports.inventory.fields.pending_stock") %></div>
        <div class="summary-value"><%= inventory_volume_m3_text(@inventory_volume_summary[:pending_stock_volume_m3]) %></div>
      </div>
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("reports.inventory.fields.book_available_stock") %></div>
        <div class="summary-value"><%= inventory_volume_m3_text(@inventory_volume_summary[:book_available_stock_volume_m3]) %></div>
      </div>
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("reports.inventory.fields.platform_inbound") %></div>
        <div class="summary-value"><%= inventory_volume_m3_text(@inventory_volume_summary[:platform_inbound_stock_volume_m3]) %></div>
      </div>
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("reports.inventory.fields.platform_stock") %></div>
        <div class="summary-value"><%= inventory_volume_m3_text(@inventory_volume_summary[:platform_stock_volume_m3]) %></div>
      </div>
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("reports.inventory.fields.overseas_available_stock") %></div>
        <div class="summary-value"><%= inventory_volume_m3_text(@inventory_volume_summary[:overseas_available_stock_volume_m3]) %></div>
      </div>
    </div>
  </section>

  <section class="panel">
    <div class="table-scroll">
      <table class="inventory-list-table">
        <thead>
          <tr>
            <th><%= t("reports.inventory.fields.sku") %></th>
            <th><%= t("reports.sku_detail.fields.product_name") %></th>
            <th><%= t("reports.inventory.fields.pending_stock") %></th>
            <th><%= t("reports.inventory.fields.book_available_stock") %></th>
            <th><%= t("reports.inventory.fields.platform_inbound") %></th>
            <th><%= t("reports.inventory.fields.platform_stock") %></th>
            <th><%= t("reports.inventory.fields.overseas_available_stock") %></th>
            <th><%= t("reports.inventory.fields.daily_sales_velocity") %></th>
            <th><%= t("reports.inventory.fields.turnover_days") %></th>
            <th><%= t("reports.inventory.fields.turnover_days_with_procurement") %></th>
            <th><%= t("reports.inventory.fields.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% if @inventory_rows.any? %>
            <% @inventory_rows.each do |row| %>
              <% available_stock = row[:available_stock].to_i %>
              <% book_stock = row[:book_stock].to_i %>
              <% platform_inbound_stock = row[:platform_inbound_stock].to_i %>
              <% platform_stock = row[:platform_stock].to_i %>
              <% incoming_quantity = row[:incoming_quantity].to_i %>
              <% dimensions_text = inventory_dimensions_text(row[:pkg_length_cm], row[:pkg_width_cm], row[:pkg_height_cm]) %>
              <% incoming_volume_text = inventory_estimated_volume_text(incoming_quantity, row[:unit_volume_l]) %>
              <% book_volume_text = inventory_estimated_volume_text(book_stock, row[:unit_volume_l]) %>
              <% platform_inbound_volume_text = inventory_estimated_volume_text(platform_inbound_stock, row[:unit_volume_l]) %>
              <% platform_volume_text = inventory_estimated_volume_text(platform_stock, row[:unit_volume_l]) %>
              <% available_volume_text = inventory_estimated_volume_text(available_stock, row[:unit_volume_l]) %>
              <% daily_sales_velocity = row[:daily_sales_velocity] %>
              <% turnover_days = row[:turnover_days] %>
              <% turnover_days_with_procurement = row[:turnover_days_with_procurement] %>
              <% marketing_grade = row[:marketing_grade].presence %>
              <% marketing_stage = row[:marketing_stage].presence %>
              <tr class="inventory-list-table__row">
                <td>
                  <div class="inventory-list-table__sku-line">
                    <%= link_to row[:sku_code],
                                report_inventory_detail_path(row[:sku_code], locale: params[:locale].presence),
                                class: "inventory-list-table__sku-link",
                                data: { turbo_frame: "inventory_drawer" } %>
                    <span class="inventory-list-table__marketing-tags">
                      <% if marketing_grade.present? %>
                        <span class="marketing-tag marketing-grade--<%= marketing_grade.downcase %>"><%= marketing_grade %></span>
                      <% else %>
                        <span class="marketing-tag marketing-tag--unset"><%= t("erp.sku_marketing_states.labels.grade_unset") %></span>
                      <% end %>
                      <% if marketing_stage.present? %>
                        <span class="marketing-tag marketing-stage--<%= marketing_stage %>"><%= marketing_stage.upcase %></span>
                      <% else %>
                        <span class="marketing-tag marketing-tag--unset"><%= t("erp.sku_marketing_states.labels.stage_unset") %></span>
                      <% end %>
                    </span>
                  </div>
                  <% if dimensions_text.present? %>
                    <div class="inventory-list-table__subline"><%= dimensions_text %></div>
                  <% end %>
                </td>
                <td class="inventory-list-table__name-cell">
                  <div class="inventory-list-table__name"><%= report_value(row[:product_name]) %></div>
                  <div class="inventory-list-table__subline"><%= report_value(row[:product_name_ru]) %></div>
                </td>
                <td class="numeric inventory-list-table__metric inventory-list-table__metric--warning">
                  <div><%= incoming_quantity %></div>
                  <% if incoming_volume_text.present? %>
                    <div class="inventory-list-table__subline"><%= incoming_volume_text %></div>
                  <% end %>
                </td>
                <td class="numeric inventory-list-table__metric">
                  <div><%= book_stock %></div>
                  <% if book_volume_text.present? %>
                    <div class="inventory-list-table__subline"><%= book_volume_text %></div>
                  <% end %>
                </td>
                <td class="numeric inventory-list-table__metric inventory-list-table__metric--warning">
                  <div><%= platform_inbound_stock %></div>
                  <% if platform_inbound_volume_text.present? %>
                    <div class="inventory-list-table__subline"><%= platform_inbound_volume_text %></div>
                  <% end %>
                </td>
                <td class="numeric inventory-list-table__metric">
                  <div><%= platform_stock %></div>
                  <% if platform_volume_text.present? %>
                    <div class="inventory-list-table__subline"><%= platform_volume_text %></div>
                  <% end %>
                </td>
                <td class="numeric inventory-list-table__metric inventory-list-table__metric--primary">
                  <div><%= available_stock %></div>
                  <% if available_volume_text.present? %>
                    <div class="inventory-list-table__subline"><%= available_volume_text %></div>
                  <% end %>
                </td>
                <td class="numeric inventory-list-table__metric"><%= daily_sales_velocity.present? ? format("%.2f", daily_sales_velocity.to_d) : "-" %></td>
                <td class="numeric inventory-list-table__metric"><%= turnover_days.present? ? format("%.2f", turnover_days.to_d) : "-" %></td>
                <td class="numeric inventory-list-table__metric"><%= turnover_days_with_procurement.present? ? format("%.2f", turnover_days_with_procurement.to_d) : "-" %></td>
                <td class="inventory-list-table__actions-cell">
                  <div class="resource-actions inventory-list-table__actions">
                    <%= link_to t("reports.inventory.actions.view_details"),
                                report_inventory_detail_path(row[:sku_code], locale: params[:locale].presence),
                                class: "inventory-list-table__detail-link",
                                data: { turbo_frame: "inventory_drawer" },
                                aria: { label: t("reports.inventory.actions.view_details") } %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="11" class="empty-state"><%= t("reports.inventory.empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @inventory_rows.respond_to?(:total_pages) && @inventory_rows.total_pages > 1 %>
      <%= render "inventory_pagination", inventory_rows: @inventory_rows %>
    <% end %>
  </section>

  <%= turbo_frame_tag "inventory_drawer" %>
</div>
