<h1 class="page-title"><%= t("reports.inventory.title") %></h1>

<div class="report-stack">
  <section class="panel">
    <%= form_with url: "/reports/inventory", method: :get, local: true, html: { class: "report-form" } do |form| %>
      <div class="field">
        <%= form.label :sku, t("reports.inventory.filters.sku") %>
        <%= form.search_field :sku, value: @sku_query, placeholder: t("reports.inventory.filters.sku_placeholder") %>
      </div>

      <%= form.button t("reports.inventory.filters.submit"), class: "button", type: "submit" %>
      <% if @sku_query.present? %>
        <%= link_to t("reports.inventory.filters.reset"), "/reports/inventory", class: "button button-secondary" %>
      <% end %>
    <% end %>
  </section>

  <section class="panel">
    <h2 class="section-title"><%= t("reports.inventory.sections.inventory_list") %></h2>
    <div class="table-scroll">
      <table class="inventory-list-table">
        <thead>
          <tr>
            <th><%= t("reports.inventory.fields.sku") %></th>
            <th><%= t("reports.inventory.fields.purchase_quantity") %></th>
            <th><%= t("reports.inventory.fields.wb_fbs") %></th>
            <th><%= t("reports.inventory.fields.wb_fbw") %></th>
            <th><%= t("reports.inventory.fields.wb_return") %></th>
            <th><%= t("reports.inventory.fields.wb_net") %></th>
            <th><%= t("reports.inventory.fields.ozon_sales") %></th>
            <th><%= t("reports.inventory.fields.ozon_return") %></th>
            <th><%= t("reports.inventory.fields.net_sales") %></th>
            <th><%= t("reports.inventory.fields.book_stock") %></th>
            <th><%= t("reports.inventory.fields.wb_fbw_available") %></th>
            <th><%= t("reports.inventory.fields.wb_fbs_available") %></th>
            <th><%= t("reports.inventory.fields.ozon_fbo") %></th>
            <th><%= t("reports.inventory.fields.ozon_fbs") %></th>
            <th><%= t("reports.inventory.fields.platform_stock") %></th>
            <th><%= t("reports.inventory.fields.belarus_available") %></th>
            <th><%= t("reports.inventory.fields.cache_updated_at") %></th>
            <th><%= t("reports.inventory.fields.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% if @inventory_rows.any? %>
            <% @inventory_rows.each do |row| %>
              <tr>
                <td><%= link_to truncate(row[:sku_code]), report_sku_path(row[:sku_code], tab: 'inventory') %></td>
                <td class="numeric"><%= row[:purchase_quantity] %></td>
                <td class="numeric"><%= row[:wb_fbs] %></td>
                <td class="numeric"><%= row[:wb_fbw] %></td>
                <td class="numeric"><%= row[:wb_return] %></td>
                <td class="numeric"><%= row[:wb_net] %></td>
                <td class="numeric"><%= row[:ozon_sales] %></td>
                <td class="numeric"><%= row[:ozon_return] %></td>
                <td class="numeric"><%= row[:net_sales] %></td>
                <td class="numeric"><%= row[:book_stock] %></td>
                <td class="numeric"><%= row[:wb_fbw_available] %></td>
                <td class="numeric"><%= row[:wb_fbs_available] %></td>
                <td class="numeric"><%= row[:ozon_fbo] %></td>
                <td class="numeric"><%= row[:ozon_fbs] %></td>
                <td class="numeric"><%= row[:platform_stock] %></td>
                <td class="numeric"><%= row[:belarus_available] %></td>
                <td><%= display_time(row[:cache_updated_at]) %></td>
                <td>
                  <%= button_to t("reports.inventory.actions.refresh_cache"), refresh_report_inventory_cache_path(row[:sku_code]), params: { sku: @sku_query.presence, locale: params[:locale].presence }, class: "button button-secondary", form: { class: "inline-form" } %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="18" class="empty-state"><%= t("reports.inventory.empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
