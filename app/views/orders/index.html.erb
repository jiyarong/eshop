<main class="page">
  <h1 class="page-title"><%= t("orders.index.title") %></h1>

  <section class="panel">
    <%= search_form_for @search, url: orders_path, method: :get, html: { class: "report-form" } do |form| %>
      <div class="field">
        <label for="platform"><%= t("orders.fields.platform") %></label>
        <select id="platform" name="q[platform_eq]">
          <option value=""><%= t("orders.filters.all_platforms") %></option>
          <% %w[ozon wb amazon].each do |platform| %>
            <option value="<%= platform %>" <%= "selected" if @q_params["platform_eq"] == platform %>><%= platform_label(platform) %></option>
          <% end %>
        </select>
      </div>

      <div class="field">
        <label for="store_id"><%= t("orders.fields.store") %></label>
        <select id="store_id" name="q[store_id_eq]">
          <option value=""><%= t("orders.filters.all_stores") %></option>
          <% @stores.each do |store| %>
            <option value="<%= store.id %>" <%= "selected" if @q_params["store_id_eq"].to_s == store.id.to_s %>>
              <%= platform_label(store.platform) %> / <%= store.store_name %>
            </option>
          <% end %>
        </select>
      </div>

      <div class="field">
        <label for="status"><%= t("orders.fields.status") %></label>
        <select id="status" name="q[order_status_eq]">
          <option value=""><%= t("orders.filters.all_statuses") %></option>
          <% Ec::Order::STATUSES.values.each do |status| %>
            <option value="<%= status %>" <%= "selected" if @q_params["order_status_eq"] == status %>><%= order_status_label(status) %></option>
          <% end %>
        </select>
      </div>

      <div class="field field--time-range">
        <label for="orders-time-range-trigger"><%= t("orders.filters.date_range") %></label>
        <%= render "shared/time_range_selector",
                   id: "orders-time-range",
                   from_date: @date_params["ordered_at_gteq"],
                   to_date: @date_params["ordered_at_lteq_end_of_day"],
                   submit_on_apply: true %>
      </div>

      <div class="field" data-controller="date-picker" data-date-picker-date-format-value="Y-m-d">
        <label for="process_from_date"><%= t("orders.filters.process_from_date") %></label>
        <input id="process_from_date" type="text" inputmode="numeric" name="q[in_process_at_gteq]" value="<%= @date_params["in_process_at_gteq"] %>" data-date-picker-target="input">
      </div>

      <div class="field" data-controller="date-picker" data-date-picker-date-format-value="Y-m-d">
        <label for="process_to_date"><%= t("orders.filters.process_to_date") %></label>
        <input id="process_to_date" type="text" inputmode="numeric" name="q[in_process_at_lteq_end_of_day]" value="<%= @date_params["in_process_at_lteq_end_of_day"] %>" data-date-picker-target="input">
      </div>

      <div class="field">
        <label for="q"><%= t("orders.filters.search") %></label>
        <input id="q" type="search" name="q[external_order_number_or_external_order_id_or_fulfillments_external_fulfillment_id_or_items_offer_id_or_items_platform_sku_id_or_items_sku_code_cont]" value="<%= @q_params["external_order_number_or_external_order_id_or_fulfillments_external_fulfillment_id_or_items_offer_id_or_items_platform_sku_id_or_items_sku_code_cont"] %>" placeholder="<%= t("orders.filters.search_placeholder") %>">
      </div>

      <button class="button" type="submit"><%= t("orders.filters.submit") %></button>
    <% end %>
  </section>

  <div class="report-stack">
    <section class="panel">
      <h2 class="section-title"><%= t("orders.index.status_overview") %></h2>
      <div class="summary-grid">
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("orders.summary.total") %></div>
          <div class="summary-value"><%= @summary[:total] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("orders.summary.processing") %></div>
          <div class="summary-value"><%= @summary[:processing] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("orders.summary.shipped") %></div>
          <div class="summary-value"><%= @summary[:shipped] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("orders.summary.delivered") %></div>
          <div class="summary-value"><%= @summary[:delivered] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label"><%= t("orders.summary.closed") %></div>
          <div class="summary-value"><%= @summary[:closed] %></div>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("orders.index.order_list") %></h2>

      <% if @orders.empty? %>
        <div class="empty-state"><%= t("orders.index.empty") %></div>
      <% else %>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th><%= t("orders.fields.platform") %></th>
                <th><%= t("orders.fields.store") %></th>
                <th><%= t("orders.fields.status") %></th>
                <th><%= t("orders.fields.fulfillment_mode") %></th>
                <th><%= t("orders.fields.external_order_number") %></th>
                <th><%= t("orders.fields.ordered_at") %></th>
                <th><%= t("orders.fields.sku_linked") %></th>
                <th><%= t("orders.fields.city") %></th>
                <th><%= t("orders.fields.sku_quantity") %></th>
                <th><%= t("orders.fields.synced_at") %></th>
                <th><%= t("orders.fields.actions") %></th>
              </tr>
            </thead>
            <tbody>
              <% @orders.each do |order| %>
                <tr>
                  <td><%= platform_label(order.platform) %></td>
                  <td><%= order.store.store_name %></td>
                  <td title="<%= order_status_title(order) %>"><%= order_status_label(order.order_status) %></td>
                  <td><%= order_fulfillment_types(order) %></td>
                  <td>
                    <% if platform_order_url(order).present? %>
                      <%= link_to truncated_order_number(order), platform_order_url(order), title: display_value(order.external_order_number), target: "_blank", rel: "noopener" %>
                    <% else %>
                      <%= link_to truncated_order_number(order), order_path(order), title: display_value(order.external_order_number) %>
                    <% end %>
                  </td>
                  <td><%= display_time(order.ordered_at) %></td>
                  <td><%= t(order_sku_linked?(order) ? "common.yes" : "common.no") %></td>
                  <td><%= display_value(order.buyer_city) %></td>
                  <td>
                    <% order.items.each_with_index do |item, index| %>
                      <% sku = sku_for_order_item(item) %>
                      <%= " / " if index.positive? %>
                      <% if sku.present? %>
                        <%= link_to order_item_sku_label(item), erp_sku_path(sku) %>
                      <% else %>
                        <%= order_item_sku_label(item) %>
                      <% end %>
                    <% end %>
                    / <%= order.items.sum { |item| item.quantity.to_i } %>
                  </td>
                  <td><%= display_time(order.synced_at) %></td>
                  <td><%= link_to t("orders.actions.view_details"), order_path(order) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
      <%= paginate @orders %>
    </section>
  </div>
</main>
