<main class="page">
  <h1 class="page-title">订单中心</h1>

  <section class="panel">
    <%= form_with url: "/orders", method: :get, local: true, class: "report-form" do %>
      <div class="field">
        <label for="platform">平台</label>
        <select id="platform" name="platform">
          <option value="">全部平台</option>
          <% %w[ozon wb amazon].each do |platform| %>
            <option value="<%= platform %>" <%= "selected" if @platform == platform %>><%= platform_label(platform) %></option>
          <% end %>
        </select>
      </div>

      <div class="field">
        <label for="store_id">店铺</label>
        <select id="store_id" name="store_id">
          <option value="">全部店铺</option>
          <% @stores.each do |store| %>
            <option value="<%= store.id %>" <%= "selected" if @store_id.to_s == store.id.to_s %>>
              <%= platform_label(store.platform) %> / <%= store.store_name %>
            </option>
          <% end %>
        </select>
      </div>

      <div class="field">
        <label for="status">状态</label>
        <select id="status" name="status">
          <option value="">全部状态</option>
          <% Ec::Order::STATUSES.values.each do |status| %>
            <option value="<%= status %>" <%= "selected" if @status == status %>><%= order_status_label(status) %></option>
          <% end %>
        </select>
      </div>

      <div class="field">
        <label for="from_date">开始日期</label>
        <input id="from_date" type="date" name="from_date" value="<%= @from_date %>">
      </div>

      <div class="field">
        <label for="to_date">结束日期</label>
        <input id="to_date" type="date" name="to_date" value="<%= @to_date %>">
      </div>

      <div class="field">
        <label for="q">搜索</label>
        <input id="q" type="search" name="q" value="<%= @q %>" placeholder="订单号 / 履约单 / SKU">
      </div>

      <button class="button" type="submit">查询</button>
    <% end %>
  </section>

  <div class="report-stack">
    <section class="panel">
      <h2 class="section-title">状态概览</h2>
      <div class="summary-grid">
        <div class="weekly-profit-summary-card">
          <div class="summary-label">订单数</div>
          <div class="summary-value"><%= @summary[:total] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">待处理/处理中</div>
          <div class="summary-value"><%= @summary[:processing] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">配送中</div>
          <div class="summary-value"><%= @summary[:shipped] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">已签收</div>
          <div class="summary-value"><%= @summary[:delivered] %></div>
        </div>
        <div class="weekly-profit-summary-card">
          <div class="summary-label">取消/退货</div>
          <div class="summary-value"><%= @summary[:closed] %></div>
        </div>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title">订单列表</h2>

      <% if @orders.empty? %>
        <div class="empty-state">当前筛选条件下暂无订单。</div>
      <% else %>
        <div class="table-scroll">
          <table>
            <thead>
              <tr>
                <th>平台</th>
                <th>店铺</th>
                <th>状态</th>
                <th>源状态</th>
                <th>源子状态</th>
                <th>平台订单号</th>
                <th>履约单号</th>
                <th>下单时间</th>
                <th>处理时间</th>
                <th>城市</th>
                <th>商品/数量</th>
                <th>同步时间</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              <% @orders.each do |order| %>
                <% fulfillment_ids = order.fulfillments.map(&:external_fulfillment_id).join(" / ") %>
                <% quantity = order.items.sum { |item| item.quantity.to_i } %>
                <tr>
                  <td><%= platform_label(order.platform) %></td>
                  <td><%= order.store.store_name %></td>
                  <td><%= order_status_label(order.order_status) %></td>
                  <td><%= display_value(order.source_status) %></td>
                  <td><%= display_value(order.source_substatus) %></td>
                  <td><%= display_value(order.external_order_number) %></td>
                  <td><%= display_value(fulfillment_ids) %></td>
                  <td><%= order.ordered_at&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
                  <td><%= order.in_process_at&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
                  <td><%= display_value(order.buyer_city) %></td>
                  <td><%= order.items.size %> / <%= quantity %></td>
                  <td><%= order.synced_at&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
                  <td><%= link_to "查看详情", order_path(order) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>
  </div>
</main>
