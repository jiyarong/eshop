<main class="page">
  <h1 class="page-title"><%= t("orders.show.title", number: @order.external_order_number) %></h1>

  <section class="panel">
    <div class="report-meta">
      <%= link_to t("orders.actions.back_to_orders"), orders_path %>
    </div>

    <div class="summary-grid">
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("orders.show.summary.platform_store") %></div>
        <div class="summary-value"><%= platform_label(@order.platform) %> / <%= @order.store.store_name %></div>
      </div>
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("orders.show.summary.unified_status") %></div>
        <div class="summary-value"><%= order_status_label(@order.order_status) %></div>
      </div>
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("orders.fields.source_status") %></div>
        <div class="summary-value"><%= display_value(@order.source_status) %></div>
      </div>
      <div class="weekly-profit-summary-card">
        <div class="summary-label"><%= t("orders.show.summary.city_country") %></div>
        <div class="summary-value"><%= display_value([@order.buyer_city, @order.buyer_country].compact_blank.join(" / ")) %></div>
      </div>
    </div>
  </section>

  <div class="report-stack">
    <section class="panel">
      <h2 class="section-title"><%= t("orders.show.sections.order_information") %></h2>
      <div class="table-scroll">
        <table>
          <tbody>
            <tr><th><%= t("orders.fields.external_order_id") %></th><td><%= display_value(@order.external_order_id) %></td></tr>
            <tr><th><%= t("orders.fields.external_order_number") %></th><td><%= display_value(@order.external_order_number) %></td></tr>
            <tr><th><%= t("orders.fields.source_substatus") %></th><td><%= display_value(@order.source_substatus) %></td></tr>
            <tr><th><%= t("orders.fields.ordered_at") %></th><td><%= display_time(@order.ordered_at) %></td></tr>
            <tr><th><%= t("orders.fields.in_process_at") %></th><td><%= display_time(@order.in_process_at) %></td></tr>
            <tr><th><%= t("orders.fields.completed_at") %></th><td><%= display_time(@order.completed_at) %></td></tr>
            <tr><th><%= t("orders.fields.cancelled_at") %></th><td><%= display_time(@order.cancelled_at) %></td></tr>
            <tr><th><%= t("orders.fields.payment_method") %></th><td><%= display_value(@order.payment_method_source) %></td></tr>
            <tr><th><%= t("orders.fields.synced_at") %></th><td><%= display_time(@order.synced_at) %></td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("orders.show.sections.fulfillment_tracking") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("orders.fields.mode") %></th>
              <th><%= t("orders.fields.status") %></th>
              <th><%= t("orders.fields.source_status") %></th>
              <th><%= t("orders.fields.source_substatus") %></th>
              <th><%= t("orders.fields.warehouse") %></th>
              <th><%= t("orders.fields.delivery_method") %></th>
              <th><%= t("orders.fields.tracking_number") %></th>
              <th><%= t("orders.fields.shipped_at") %></th>
              <th><%= t("orders.fields.delivered_at") %></th>
              <th><%= t("orders.fields.raw_source") %></th>
            </tr>
          </thead>
          <tbody>
            <% @order.fulfillments.each do |fulfillment| %>
              <tr>
                <td><%= fulfillment_label(fulfillment.fulfillment_type) %></td>
                <td><%= order_status_label(fulfillment.status) %></td>
                <td><%= display_value(fulfillment.source_status) %></td>
                <td><%= display_value(fulfillment.source_substatus) %></td>
                <td><%= display_value(fulfillment.warehouse_name) %></td>
                <td><%= display_value(fulfillment.delivery_method_name || fulfillment.delivery_type_source) %></td>
                <td><%= display_value(fulfillment.tracking_number) %></td>
                <td><%= display_time(fulfillment.shipped_at) %></td>
                <td><%= display_time(fulfillment.delivered_at) %></td>
                <td><%= display_value(fulfillment.raw_source_type) %>#<%= display_value(fulfillment.raw_source_id) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("orders.show.sections.items") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("orders.fields.platform_sku") %></th>
              <th>Offer ID</th>
              <th><%= t("orders.fields.internal_sku") %></th>
              <th><%= t("orders.fields.product_name") %></th>
              <th><%= t("orders.fields.source_product_name") %></th>
              <th><%= t("orders.fields.quantity") %></th>
              <th><%= t("orders.fields.unit_price") %></th>
              <th><%= t("orders.fields.old_price") %></th>
              <th><%= t("orders.fields.currency") %></th>
              <th><%= t("orders.fields.commission") %></th>
              <th><%= t("orders.fields.discount") %></th>
            </tr>
          </thead>
          <tbody>
            <% @order.items.each do |item| %>
              <% sku = sku_for_order_item(item) %>
              <tr>
                <td><%= display_value(item.platform_sku_id) %></td>
                <td><%= display_value(item.offer_id) %></td>
                <td><%= display_value(order_item_sku_label(item)) %></td>
                <td title="<%= display_value(sku&.product_name) %>"><%= truncated_display_value(sku&.product_name) %></td>
                <td title="<%= display_value(item.product_name_source) %>"><%= truncated_display_value(item.product_name_source) %></td>
                <td><%= item.quantity %></td>
                <td><%= money_value(item.unit_price) %></td>
                <td><%= money_value(item.old_unit_price) %></td>
                <td><%= display_value(item.currency_code) %></td>
                <td><%= money_value(item.commission_amount) %></td>
                <td><%= money_value(item.discount_amount) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("orders.show.sections.sku_details") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("orders.fields.image") %></th>
              <th><%= t("orders.fields.product_name") %></th>
              <th>Ozon Product ID</th>
              <th><%= t("orders.fields.platform_sku") %></th>
              <th>Offer ID</th>
              <th><%= t("orders.fields.price") %></th>
              <th><%= t("orders.fields.marketing_price") %></th>
              <th><%= t("orders.fields.old_price") %></th>
              <th><%= t("orders.fields.currency") %></th>
              <th><%= t("orders.fields.fbo_stock") %></th>
              <th><%= t("orders.fields.fbs_stock") %></th>
              <th><%= t("orders.fields.barcode") %></th>
              <th><%= t("orders.fields.synced_at") %></th>
            </tr>
          </thead>
          <tbody>
            <% detail_rows = @order.items.map { |item| [item, ozon_product_details_for(item)] }.select { |_item, details| details[:product].present? } %>
            <% if detail_rows.any? %>
              <% detail_rows.each do |item, details| %>
                <% product = details[:product] %>
                <% price = details[:price] %>
                <% stock = details[:stock] %>
                <% image_url = ozon_product_image_url(product) %>
                <tr>
                  <td>
                    <% if image_url.present? %>
                      <%= image_tag image_url, alt: product.name.presence || item.product_name_source.presence || item.offer_id, style: "width: 56px; height: 56px; object-fit: cover; border-radius: 6px;" %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td title="<%= display_value(product.name) %>"><%= truncated_display_value(product.name) %></td>
                  <td><%= product.ozon_product_id %></td>
                  <td><%= display_value(item.platform_sku_id) %></td>
                  <td><%= display_value(product.offer_id || item.offer_id) %></td>
                  <td><%= money_value(price&.price) %></td>
                  <td><%= money_value(price&.marketing_price) %></td>
                  <td><%= money_value(price&.old_price) %></td>
                  <td><%= display_value(price&.currency_code || product.currency_code) %></td>
                  <td><%= stock ? "#{stock.present_fbo.to_i} / #{stock.reserved_fbo.to_i}" : "-" %></td>
                  <td><%= stock ? "#{stock.present_fbs.to_i} / #{stock.reserved_fbs.to_i}" : "-" %></td>
                  <td><%= display_value(product.barcodes&.join(" / ")) %></td>
                  <td><%= display_time([product.synced_at, price&.synced_at, stock&.synced_at].compact.max) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="13"><%= t("orders.show.empty_sku_details") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2 class="section-title"><%= t("orders.show.sections.source_links") %></h2>
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th><%= t("orders.fields.source_type") %></th>
              <th><%= t("orders.fields.source_id") %></th>
              <th><%= t("orders.fields.role") %></th>
              <th><%= t("orders.fields.synced_at") %></th>
            </tr>
          </thead>
          <tbody>
            <% @order.source_links.each do |link| %>
              <tr>
                <td><%= link.source_type %></td>
                <td><%= link.source_id %></td>
                <td><%= link.source_role %></td>
                <td><%= display_time(link.synced_at) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</main>
