      "height": 25,
      "text": "WB 订单映射（特殊逻辑）：1条 raw_wb_orders = 1件商品（非传统 1订单N商品）",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#e67700",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
