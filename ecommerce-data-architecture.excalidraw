      "version": 1
    },
    {
      "id": "wb_mapping_body",
      "type": "text",
      "x": 85,
      "y": 880,
      "width": 830,
      "height": 100,
      "text": "按 order_uid 聚合  ────────────────────────────────────────────→  ec_orders（一次购物）\n按 order_uid + chrt_id 分组，COUNT=数量  ──────────────────→  ec_order_items\n关联：order_uid（实时 API 篮子级 ID）↔ g_number（统计 API），通过 srid 字段回填",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#664d03",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "seed": 130,
      "version": 1
